---
import '../styles/platform.css';

interface Props {
  title: string;
  pageTitle?: string;
  userName?: string;
  userEmail?: string;
}

const { title, pageTitle = title, userName = 'Admin', userEmail } = Astro.props;

const pathname = Astro.url.pathname;
const navItems = [
  { label: 'Overview', href: '/admin' },
  { label: 'Students', href: '/admin/students' },
  { label: 'Subjects & Chapters', href: '/admin/subjects' },
  { label: 'Tests', href: '/admin/tests' },
  { label: 'Questions', href: '/admin/questions' },
];

const isActive = (label: string, href: string) => {
  if (label === 'Overview') {
    return pathname === '/admin';
  }

  if (label === 'Subjects & Chapters') {
    return pathname.startsWith('/admin/subjects') || pathname.startsWith('/admin/topics');
  }

  if (label === 'Tests') {
    return pathname === '/admin/tests';
  }

  if (label === 'Questions') {
    return pathname.startsWith('/admin/questions') || /^\/admin\/tests\/[^/]+$/.test(pathname);
  }

  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="admin-app">
    <div class="admin-shell">
      <aside class="admin-sidebar">
        <div class="admin-sidebar__top">
          <a href="/admin" class="admin-brand">
            <img src="/images/logo.jpeg" alt="Dream Neet Academy logo" class="admin-brand__logo" />
            <div>
              <div class="admin-brand__title">Dream Neet Academy</div>
              <div class="admin-brand__sub">Admin Panel</div>
            </div>
          </a>
        </div>

        <div class="admin-sidebar__nav-wrap">
          <div class="admin-sidebar__label">Management</div>

          <nav class="admin-sidebar__nav" aria-label="Admin management">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={['admin-sidebar__link', { 'admin-sidebar__link--active': isActive(item.label, item.href) }]}
              >
                <span class="admin-sidebar__icon" aria-hidden="true">
                  {
                    item.label === 'Overview' ? (
                      <svg viewBox="0 0 24 24">
                        <path d="M4 4h7v7H4z"></path>
                        <path d="M13 4h7v4h-7z"></path>
                        <path d="M13 10h7v10h-7z"></path>
                        <path d="M4 13h7v7H4z"></path>
                      </svg>
                    ) : item.label === 'Students' ? (
                      <svg viewBox="0 0 24 24">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9.5" cy="7" r="3"></circle>
                        <path d="M20 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 4.13a4 4 0 0 1 0 7.75"></path>
                      </svg>
                    ) : item.label === 'Subjects & Chapters' ? (
                      <svg viewBox="0 0 24 24">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                        <path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5z"></path>
                      </svg>
                    ) : item.label === 'Tests' ? (
                      <svg viewBox="0 0 24 24">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <path d="M14 2v6h6"></path>
                        <path d="M8 13h8"></path>
                        <path d="M8 17h5"></path>
                      </svg>
                    ) : (
                      <svg viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="9"></circle>
                        <path d="M9.5 9.5h.01"></path>
                        <path d="M14.5 9.5h.01"></path>
                        <path d="M8.5 14.5c1 .8 2.1 1.2 3.5 1.2s2.5-.4 3.5-1.2"></path>
                      </svg>
                    )
                  }
                </span>
                <span>{item.label}</span>
              </a>
            ))}
          </nav>
        </div>

        <div class="admin-sidebar__bottom">
          <div class="admin-sidebar__email" title={userEmail ?? userName}>{userEmail ?? userName}</div>
          <form action="/api/auth/logout" method="POST">
            <button type="submit" class="admin-sidebar__logout">Logout</button>
          </form>
        </div>
      </aside>

      <div class="admin-main">
        <header class="admin-topbar">
          <h1 class="admin-topbar__title">{pageTitle}</h1>
          <div class="admin-topbar__actions">
            <slot name="actions" />
          </div>
        </header>

        <div class="admin-content">
          <slot />
        </div>
      </div>
    </div>
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    min-height: 100%;
    background: #f1f3f9;
  }

  .admin-app {
    font-family: 'Inter', sans-serif;
    color: #0a0f1e;
  }

  .admin-shell {
    display: flex;
    height: 100vh;
    overflow: hidden;
    background: #f1f3f9;
  }

  .admin-sidebar {
    width: 220px;
    flex-shrink: 0;
    background: #0a0f1e;
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
  }

  .admin-sidebar__top {
    padding: 20px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .admin-brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .admin-brand__logo {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    object-fit: cover;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .admin-brand__title {
    color: #fff;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .admin-brand__sub {
    margin-top: 3px;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .admin-sidebar__nav-wrap {
    flex: 1;
    padding: 12px 0;
    overflow-y: auto;
  }

  .admin-sidebar__label {
    padding: 8px 16px;
    color: rgba(255, 255, 255, 0.25);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .admin-sidebar__nav {
    display: grid;
  }

  .admin-sidebar__link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 14px;
    margin: 2px 8px;
    border-radius: 8px;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.84rem;
    font-weight: 500;
    transition: all 0.15s;
  }

  .admin-sidebar__link:hover {
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.9);
  }

  .admin-sidebar__link--active {
    background: rgba(245, 197, 24, 0.12);
    color: #f5c518;
  }

  .admin-sidebar__icon {
    width: 18px;
    height: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .admin-sidebar__icon svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .admin-sidebar__bottom {
    padding: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .admin-sidebar__email {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.75rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-bottom: 10px;
  }

  .admin-sidebar__logout {
    border: none;
    background: transparent;
    padding: 0;
    color: rgba(239, 68, 68, 0.7);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: color 0.15s;
  }

  .admin-sidebar__logout:hover {
    color: #ef4444;
  }

  .admin-main {
    flex: 1;
    min-width: 0;
    overflow-y: auto;
    background: #f1f3f9;
  }

  .admin-topbar {
    position: sticky;
    top: 0;
    z-index: 5;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 0 28px;
    background: #fff;
    border-bottom: 1px solid #e2e8f0;
  }

  .admin-topbar__title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: #0a0f1e;
  }

  .admin-topbar__actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .admin-content {
    padding: 24px 28px;
  }

  @media (max-width: 900px) {
    .admin-shell {
      flex-direction: column;
      height: auto;
      min-height: 100vh;
    }

    .admin-sidebar {
      width: 100%;
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .admin-sidebar__nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 0 8px;
    }

    .admin-main {
      overflow: visible;
    }
  }

  @media (max-width: 640px) {
    .admin-topbar {
      height: auto;
      padding: 14px 16px;
      align-items: flex-start;
      flex-direction: column;
    }

    .admin-content {
      padding: 20px 16px 28px;
    }

    .admin-sidebar__nav {
      grid-template-columns: 1fr;
    }
  }
</style>
