---
import '../styles/platform.css';

interface Props {
  title: string;
  pageTitle?: string;
  userName?: string;
  userEmail?: string;
  hideTopbar?: boolean;
}

const { title, pageTitle = title, userName = 'Admin', userEmail, hideTopbar = false } = Astro.props;

const pathname = Astro.url.pathname;
const navItems = [
  { label: 'Overview', href: '/admin' },
  { label: 'Students', href: '/admin/students' },
  { label: 'Subjects & Chapters', href: '/admin/subjects' },
  { label: 'Tests', href: '/admin/tests' },
  { label: 'Questions', href: '/admin/questions' },
];

const isActive = (label: string, href: string) => {
  if (label === 'Overview') {
    return pathname === '/admin';
  }

  if (label === 'Subjects & Chapters') {
    return pathname.startsWith('/admin/subjects') || pathname.startsWith('/admin/topics');
  }

  if (label === 'Tests') {
    return pathname === '/admin/tests';
  }

  if (label === 'Questions') {
    return pathname.startsWith('/admin/questions') || /^\/admin\/tests\/[^/]+$/.test(pathname);
  }

  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="admin-app">
    <div class="admin-shell">
      <aside class="admin-sidebar" id="admin-sidebar">
        <button type="button" class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
          <svg class="toggle-icon" viewBox="0 0 12 12" aria-hidden="true">
            <path d="M7.5 2.25 4 6l3.5 3.75" />
          </svg>
        </button>

        <div class="admin-sidebar__top">
          <a href="/admin" class="admin-brand" aria-label="Dream Neet Admin home">
            <img src="/images/logo.jpeg" alt="Dream Neet Academy logo" class="admin-brand__logo" />
            <div class="sidebar-logo-text">
              <div class="admin-brand__title">Dream Neet</div>
              <div class="admin-brand__title">Academy</div>
              <div class="admin-brand__sub">Admin Panel</div>
            </div>
          </a>
        </div>

        <div class="admin-sidebar__nav-wrap">
          <div class="admin-sidebar__label sidebar-section-label">Management</div>

          <nav class="admin-sidebar__nav" aria-label="Admin management">
            {navItems.map((item) => (
              <a
                href={item.href}
                title={item.label}
                class:list={[
                  'admin-sidebar__link nav-item',
                  { 'admin-sidebar__link--active': isActive(item.label, item.href) },
                ]}
              >
                <span class="admin-sidebar__icon" aria-hidden="true">
                  {
                    item.label === 'Overview' ? (
                      <svg viewBox="0 0 24 24">
                        <path d="M4 4h7v7H4z"></path>
                        <path d="M13 4h7v4h-7z"></path>
                        <path d="M13 10h7v10h-7z"></path>
                        <path d="M4 13h7v7H4z"></path>
                      </svg>
                    ) : item.label === 'Students' ? (
                      <svg viewBox="0 0 24 24">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9.5" cy="7" r="3"></circle>
                        <path d="M20 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 4.13a4 4 0 0 1 0 7.75"></path>
                      </svg>
                    ) : item.label === 'Subjects & Chapters' ? (
                      <svg viewBox="0 0 24 24">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                        <path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5z"></path>
                      </svg>
                    ) : item.label === 'Tests' ? (
                      <svg viewBox="0 0 24 24">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <path d="M14 2v6h6"></path>
                        <path d="M8 13h8"></path>
                        <path d="M8 17h5"></path>
                      </svg>
                    ) : (
                      <svg viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="9"></circle>
                        <path d="M9.5 9.5h.01"></path>
                        <path d="M14.5 9.5h.01"></path>
                        <path d="M8.5 14.5c1 .8 2.1 1.2 3.5 1.2s2.5-.4 3.5-1.2"></path>
                      </svg>
                    )
                  }
                </span>
                <span class="sidebar-label">{item.label}</span>
              </a>
            ))}
          </nav>
        </div>

        <div class="admin-sidebar__bottom">
          <div class="admin-sidebar__email sidebar-bottom-text" title={userEmail ?? userName}>{userEmail ?? userName}</div>
          <form action="/api/auth/logout" method="POST" class="sidebar-bottom-text">
            <button type="submit" class="admin-sidebar__logout">Logout</button>
          </form>
        </div>
      </aside>

      <div class="admin-main">
        {!hideTopbar && (
          <header class="admin-topbar">
            <h1 class="admin-topbar__title">{pageTitle}</h1>
            <div class="admin-topbar__actions">
              <slot name="actions" />
            </div>
          </header>
        )}

        <div class="admin-content">
          <slot />
        </div>
      </div>
    </div>

    <script is:inline>
      const sidebar = document.getElementById('admin-sidebar');
      const toggle = document.getElementById('sidebar-toggle');
      const STORAGE_KEY = 'admin_sidebar_collapsed';

      if (sidebar && localStorage.getItem(STORAGE_KEY) === 'true' && window.innerWidth > 900) {
        sidebar.classList.add('collapsed');
      }

      if (toggle && sidebar) {
        toggle.addEventListener('click', () => {
          if (window.innerWidth <= 900) {
            return;
          }

          const isCollapsed = sidebar.classList.toggle('collapsed');
          localStorage.setItem(STORAGE_KEY, String(isCollapsed));
        });

        sidebar.querySelectorAll('.nav-item').forEach((item) => {
          const label = item.querySelector('.sidebar-label')?.textContent?.trim();
          if (label) {
            item.setAttribute('title', label);
          }
        });
      }
    </script>
  </body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    min-height: 100%;
    background: #f1f3f9;
  }

  .admin-app {
    font-family: 'Inter', sans-serif;
    color: #0a0f1e;
  }

  .admin-shell {
    display: flex;
    min-height: 100vh;
    background: #f1f3f9;
  }

  .admin-sidebar {
    width: 220px;
    transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    flex-shrink: 0;
    align-self: flex-start;
    position: sticky;
    top: 0;
    min-height: 100vh;
    background: #0a0f1e;
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
  }

  .admin-sidebar.collapsed {
    width: 64px;
  }

  .admin-main {
    flex: 1;
    transition: margin-left 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    min-width: 0;
    min-height: 100vh;
    background: #f1f3f9;
  }

  .admin-sidebar__top {
    position: relative;
    padding: 20px 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .sidebar-toggle {
    position: absolute;
    right: -12px;
    top: 72px;
    width: 24px;
    height: 24px;
    border: 1.5px solid #e2e8f0;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(10, 15, 30, 0.1);
    transition: all 0.2s;
    color: #0a0f1e;
  }

  .sidebar-toggle:hover {
    background: #0a0f1e;
    border-color: #0a0f1e;
    color: #fff;
  }

  .toggle-icon {
    width: 12px;
    height: 12px;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .toggle-icon path {
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .admin-sidebar:not(.collapsed) .toggle-icon {
    transform: rotate(0deg);
  }

  .admin-sidebar.collapsed .toggle-icon {
    transform: rotate(180deg);
  }

  .admin-brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .admin-brand__logo {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid rgba(255, 255, 255, 0.08);
    flex-shrink: 0;
  }

  .sidebar-logo-text {
    transition: opacity 0.15s, width 0.25s;
    overflow: hidden;
  }

  .admin-brand__title {
    color: #fff;
    font-size: 0.82rem;
    font-weight: 800;
    line-height: 1.1;
  }

  .admin-brand__sub {
    margin-top: 3px;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .admin-sidebar__nav-wrap {
    flex: 1;
    padding: 12px 0;
    overflow-y: auto;
  }

  .admin-sidebar__label {
    padding: 8px 16px;
    color: rgba(255, 255, 255, 0.25);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .sidebar-section-label {
    transition: opacity 0.15s, height 0.25s, margin 0.25s, padding 0.25s;
  }

  .admin-sidebar__nav {
    display: grid;
  }

  .admin-sidebar__link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 14px;
    margin: 2px 8px;
    border-radius: 8px;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.84rem;
    font-weight: 500;
    transition: all 0.15s;
    text-decoration: none;
  }

  .admin-sidebar__link:hover {
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.9);
  }

  .admin-sidebar__link--active {
    background: rgba(245, 197, 24, 0.12);
    color: #f5c518;
  }

  .admin-sidebar__icon {
    width: 18px;
    height: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .admin-sidebar__icon svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .sidebar-label {
    transition: opacity 0.15s, width 0.25s;
    white-space: nowrap;
    overflow: hidden;
  }

  .admin-sidebar__bottom {
    padding: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .admin-sidebar__email {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.75rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-bottom: 10px;
  }

  .sidebar-bottom-text {
    transition: opacity 0.15s, width 0.25s;
    overflow: hidden;
  }

  .admin-sidebar__logout {
    border: none;
    background: transparent;
    padding: 0;
    color: rgba(239, 68, 68, 0.7);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: color 0.15s;
  }

  .admin-sidebar__logout:hover {
    color: #ef4444;
  }

  .admin-sidebar.collapsed .sidebar-label {
    opacity: 0;
    width: 0;
  }

  .admin-sidebar.collapsed .sidebar-section-label {
    opacity: 0;
    height: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
  }

  .admin-sidebar.collapsed .nav-item {
    justify-content: center;
    padding: 10px;
  }

  .admin-sidebar.collapsed .sidebar-logo-text {
    display: none;
  }

  .admin-sidebar.collapsed .sidebar-bottom-text {
    display: none;
  }

  .admin-topbar {
    position: sticky;
    top: 0;
    z-index: 5;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 0 28px;
    background: #fff;
    border-bottom: 1px solid #e2e8f0;
  }

  .admin-topbar__title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: #0a0f1e;
  }

  .admin-topbar__actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .admin-content {
    padding: 24px 28px;
  }

  @media (max-width: 900px) {
    .admin-shell {
      flex-direction: column;
      min-height: 100vh;
    }

    .admin-sidebar,
    .admin-sidebar.collapsed {
      width: 100%;
      min-height: auto;
      position: static;
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .sidebar-toggle {
      display: none;
    }

    .admin-sidebar__nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 0 8px;
    }

    .sidebar-label,
    .sidebar-logo-text,
    .sidebar-bottom-text,
    .sidebar-section-label {
      opacity: 1 !important;
      width: auto !important;
      height: auto !important;
      display: block !important;
      margin: initial;
      padding: initial;
    }
  }

  @media (max-width: 640px) {
    .admin-topbar {
      height: auto;
      padding: 14px 16px;
      align-items: flex-start;
      flex-direction: column;
    }

    .admin-content {
      padding: 20px 16px 28px;
    }

    .admin-sidebar__nav {
      grid-template-columns: 1fr;
    }
  }
</style>
