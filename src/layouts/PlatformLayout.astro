---
import PlatformFooter from '../components/platform/PlatformFooter.astro';
import PlatformNav from '../components/platform/PlatformNav.astro';
import '../styles/platform.css';

interface Props {
  title: string;
  showNav?: boolean;
}

const { title, showNav = true } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body style="background: var(--color-bg); font-family: 'Inter', sans-serif;">
    {showNav && <PlatformNav />}
    <main class:list={['platform-main', { 'platform-main--with-nav': showNav }]}>
      <slot />
    </main>
    <PlatformFooter />
  </body>
</html>

<style>
  .platform-main {
    min-height: calc(100vh - 89px);
  }

  .platform-main--with-nav {
    padding-top: 64px;
  }
</style>
