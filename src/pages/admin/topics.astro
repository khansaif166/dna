---
export const prerender = false;

import { asc } from 'drizzle-orm';

import AdminNav from '../../components/AdminNav.astro';
import Base from '../../layouts/Base.astro';
import { db, subjects, topics } from '../../db';
import { requireAuth } from '../../lib/auth';

const authResult = await requireAuth(Astro, 'admin');

if (authResult instanceof Response) {
  return authResult;
}

const allSubjects = await db.select().from(subjects).orderBy(asc(subjects.order));
const allTopics = await db.select().from(topics).orderBy(asc(topics.subjectId), asc(topics.order));
---

<Base title="Admin Topics | Dream Neet Academy">
  <main>
    <h1>Topics & Resources</h1>
    <AdminNav />

    <section>
      <h2>Add Topic</h2>
      <form action="/api/admin/topics" method="POST">
        <label>
          Subject
          <select name="subject_id" required>
            {allSubjects.map((subject) => (
              <option value={subject.id}>{subject.name}</option>
            ))}
          </select>
        </label>
        <label>
          Name
          <input type="text" name="name" required />
        </label>
        <label>
          Order
          <input type="number" name="order" required />
        </label>
        <button type="submit">Create Topic</button>
      </form>
    </section>

    <section>
      <h2>Topics by Subject</h2>
      {allSubjects.map((subject) => {
        const subjectTopics = allTopics.filter((topic) => topic.subjectId === subject.id);

        return (
          <section>
            <h3>{subject.name}</h3>
            {subjectTopics.length ? (
              <ul>
                {subjectTopics.map((topic) => (
                  <li>
                    <p>{topic.name} (Order: {topic.order})</p>
                    <form action="/api/admin/resources" method="POST">
                      <input type="hidden" name="topic_id" value={topic.id} />
                      <label>
                        Title
                        <input type="text" name="title" required />
                      </label>
                      <label>
                        YouTube URL
                        <input type="url" name="youtube_url" required />
                      </label>
                      <label>
                        Notes
                        <textarea name="notes"></textarea>
                      </label>
                      <label>
                        Order
                        <input type="number" name="order" required />
                      </label>
                      <button type="submit">Add Resource</button>
                    </form>
                  </li>
                ))}
              </ul>
            ) : (
              <p>No topics added yet.</p>
            )}
          </section>
        );
      })}
    </section>
  </main>
</Base>
