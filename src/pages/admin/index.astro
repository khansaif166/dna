---
export const prerender = false;

import { count, eq, gte } from 'drizzle-orm';

import AdminLayout from '../../layouts/AdminLayout.astro';
import { db, profiles, testAttempts, tests } from '../../db';
import { requireAuth } from '../../lib/auth';

const authResult = await requireAuth(Astro, 'admin');

if (authResult instanceof Response) {
  return authResult;
}

const admin = authResult;

const startOfToday = new Date();
startOfToday.setHours(0, 0, 0, 0);

const [studentCountRow, testCountRow, attemptsTodayRow, publishedTestsRow] = await Promise.all([
  db.select({ value: count() }).from(profiles).where(eq(profiles.role, 'student')),
  db.select({ value: count() }).from(tests),
  db.select({ value: count() }).from(testAttempts).where(gte(testAttempts.startedAt, startOfToday)),
  db.select({ value: count() }).from(tests).where(eq(tests.status, 'published')),
]);

const stats = [
  {
    label: 'Total Students',
    value: studentCountRow[0]?.value ?? 0,
    href: '/admin/students',
    icon: '👤',
    toneClass: 'stat-card__icon--blue',
  },
  {
    label: 'Total Tests',
    value: testCountRow[0]?.value ?? 0,
    href: '/admin/tests',
    icon: '📝',
    toneClass: 'stat-card__icon--yellow',
  },
  {
    label: 'Attempts Today',
    value: attemptsTodayRow[0]?.value ?? 0,
    href: '/admin/students',
    icon: '✅',
    toneClass: 'stat-card__icon--green',
  },
  {
    label: 'Published Tests',
    value: publishedTestsRow[0]?.value ?? 0,
    href: '/admin/tests',
    icon: '📚',
    toneClass: 'stat-card__icon--navy',
  },
];
---

<AdminLayout title="Admin Dashboard | Dream Neet Academy" userName={admin.fullName}>
  <section class="page-header">
    <h1 class="heading-lg">Admin Dashboard</h1>
  </section>

  <section class="stats-grid">
    {stats.map((stat) => (
      <a href={stat.href} class="card stat-card">
        <div>
          <p class="stat-card__label">{stat.label}</p>
          <strong>{stat.value}</strong>
        </div>
        <span class:list={['stat-card__icon', stat.toneClass]} aria-hidden="true">{stat.icon}</span>
      </a>
    ))}
  </section>
</AdminLayout>

<style>
  .page-header {
    margin-bottom: 24px;
  }

  .heading-lg {
    color: var(--color-navy);
    font-size: clamp(1.9rem, 3vw, 2.4rem);
    font-weight: 800;
    margin: 0;
  }

  .stats-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .stat-card {
    align-items: flex-start;
    color: inherit;
    display: flex;
    justify-content: space-between;
  }

  .stat-card__label {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0 0 0.4rem;
  }

  .stat-card strong {
    color: var(--color-navy);
    display: block;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
  }

  .stat-card__icon {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    font-size: 1.15rem;
    height: 44px;
    justify-content: center;
    width: 44px;
  }

  .stat-card__icon--blue {
    background: #dbeafe;
  }

  .stat-card__icon--yellow {
    background: var(--color-yellow-bg);
  }

  .stat-card__icon--green {
    background: #d1fae5;
  }

  .stat-card__icon--navy {
    background: var(--color-navy);
    color: var(--color-surface);
  }

  @media (max-width: 1080px) {
    .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
