---
export const prerender = false;

import { and, desc, eq, isNotNull, sql } from 'drizzle-orm';

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { attemptAnswers, db, questions, subjects, testAttempts, tests, topics } from '../../../db';
import { requireAuth } from '../../../lib/auth';
import { hasProfileIsActiveColumn } from '../../../lib/profileColumns';
import { getAdminSupabase } from '../../../lib/supabase';

function formatDate(dateValue: string | Date): string {
  const date = new Date(dateValue);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  const timeStr = date.toLocaleTimeString('en-IN', {
    hour: '2-digit',
    minute: '2-digit',
    hour12: true,
  });

  if (diffDays === 0) return `Today, ${timeStr}`;
  if (diffDays === 1) return `Yesterday, ${timeStr}`;
  if (diffDays < 7) {
    const day = date.toLocaleDateString('en-IN', { weekday: 'short' });
    return `${day}, ${timeStr}`;
  }

  const dateFormatted = date.toLocaleDateString('en-IN', {
    day: 'numeric',
    month: 'short',
  });

  return `${dateFormatted}, ${timeStr}`;
}

function toValidDate(value: Date | string | null | undefined) {
  if (!value) {
    return null;
  }

  const date = value instanceof Date ? value : new Date(value);
  return Number.isNaN(date.getTime()) ? null : date;
}

function formatDuration(seconds: number | null): string {
  if (!seconds) return '—';
  if (seconds < 60) return `${seconds}s`;

  const m = Math.floor(seconds / 60);
  const s = seconds % 60;

  if (seconds < 3600) return `${m}m ${s}s`;

  const h = Math.floor(seconds / 3600);
  const rem = Math.floor((seconds % 3600) / 60);
  return `${h}h ${rem}m`;
}

function relativeLastActive(value: Date | string | null) {
  const date = toValidDate(value);

  if (!date) {
    return 'Never';
  }

  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  if (diffDays === 0) return 'Today';
  if (diffDays === 1) return 'Yesterday';
  if (diffDays < 7) return `${diffDays} days ago`;

  return date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });
}

function initialsFor(fullName: string) {
  const parts = fullName.trim().split(/\s+/).filter(Boolean);
  const first = parts[0]?.[0] ?? 'S';
  const last = parts[1]?.[0] ?? parts[0]?.[1] ?? '';
  return `${first}${last}`.toUpperCase();
}

function accuracyPercent(score: number | null, totalQuestions: number | null) {
  const scoreValue = score ?? 0;
  const totalValue = totalQuestions ?? 0;
  return totalValue > 0 ? Math.round((scoreValue / totalValue) * 100) : 0;
}

function subjectTheme(subjectName: string | null) {
  const key = (subjectName ?? '').toLowerCase();

  if (key.includes('physics')) {
    return {
      pillBg: '#EFF6FF',
      pillText: '#1D4ED8',
      bar: '#3B82F6',
    };
  }

  if (key.includes('chemistry')) {
    return {
      pillBg: '#F0FDF4',
      pillText: '#166534',
      bar: '#10B981',
    };
  }

  if (key.includes('biology')) {
    return {
      pillBg: '#FFFBEB',
      pillText: '#92400E',
      bar: '#F59E0B',
    };
  }

  return {
    pillBg: '#F3F4F6',
    pillText: '#6B7280',
    bar: '#CBD5E1',
  };
}

const authResult = await requireAuth(Astro, 'admin');

if (authResult instanceof Response) {
  return authResult;
}

const admin = authResult;
const { studentId } = Astro.params;
const attemptFilter = Astro.url.searchParams.get('filter')?.trim() ?? 'all';
const hasIsActiveColumn = await hasProfileIsActiveColumn();

if (!studentId) {
  return new Response(null, { status: 404 });
}

const studentRows = await db.execute(sql`
  select
    id,
    full_name as "fullName",
    role,
    created_at as "createdAt",
    ${hasIsActiveColumn ? sql`is_active` : sql`true`} as "isActive"
  from profiles
  where id = ${studentId}
  limit 1
`);

if (!studentRows || studentRows.length === 0) {
  return new Response(null, { status: 404 });
}

const [student] = studentRows as Array<{
  id: string;
  fullName: string;
  role: 'student' | 'admin';
  createdAt: Date | null;
  isActive: boolean;
}>;

const [attempts, subjectAccuracyRows, adminSupabaseUser] = await Promise.all([
  db
    .select({
      id: testAttempts.id,
      score: testAttempts.score,
      totalQuestions: testAttempts.totalQuestions,
      submittedAt: testAttempts.submittedAt,
      timeTakenSeconds: testAttempts.timeTakenSeconds,
      testTitle: tests.title,
      subjectName: subjects.name,
      topicName: topics.name,
    })
    .from(testAttempts)
    .innerJoin(tests, eq(testAttempts.testId, tests.id))
    .leftJoin(topics, eq(tests.topicId, topics.id))
    .leftJoin(subjects, sql`${subjects.id} = coalesce(${topics.subjectId}, ${tests.subjectId})`)
    .where(and(eq(testAttempts.studentId, student.id), isNotNull(testAttempts.submittedAt)))
    .orderBy(desc(testAttempts.submittedAt)),
  db
    .select({
      subjectName: subjects.name,
      correct: sql<number>`sum(case when ${attemptAnswers.isCorrect} = true then 1 else 0 end)::int`,
      total: sql<number>`count(*)::int`,
    })
    .from(attemptAnswers)
    .innerJoin(testAttempts, eq(attemptAnswers.attemptId, testAttempts.id))
    .innerJoin(questions, eq(attemptAnswers.questionId, questions.id))
    .innerJoin(tests, eq(questions.testId, tests.id))
    .leftJoin(topics, eq(tests.topicId, topics.id))
    .innerJoin(subjects, sql`${subjects.id} = coalesce(${topics.subjectId}, ${tests.subjectId})`)
    .where(and(eq(testAttempts.studentId, student.id), isNotNull(testAttempts.submittedAt)))
    .groupBy(subjects.id, subjects.name),
  getAdminSupabase().auth.admin.getUserById(student.id),
]);

const email = adminSupabaseUser.data.user?.email ?? 'No email available';

const attemptsWithPercent = attempts.map((attempt) => ({
  ...attempt,
  percent: accuracyPercent(attempt.score, attempt.totalQuestions),
}));

const filteredAttempts = attemptsWithPercent.filter((attempt) => {
  if (attemptFilter === 'passed') {
    return attempt.percent >= 40;
  }

  if (attemptFilter === 'failed') {
    return attempt.percent < 40;
  }

  return true;
});

const totalAttempts = attemptsWithPercent.length;
const totalQuestionsAnswered = attemptsWithPercent.reduce((sum, attempt) => sum + (attempt.totalQuestions ?? 0), 0);
const totalCorrect = attemptsWithPercent.reduce((sum, attempt) => sum + (attempt.score ?? 0), 0);
const averageScore = totalAttempts
  ? Math.round(attemptsWithPercent.reduce((sum, attempt) => sum + attempt.percent, 0) / totalAttempts)
  : 0;
const bestScore = totalAttempts ? Math.max(...attemptsWithPercent.map((attempt) => attempt.percent)) : 0;
const lastActive = attemptsWithPercent[0]?.submittedAt ?? null;
const joinedDate = toValidDate(student.createdAt);
const joinedLabel = joinedDate
  ? new Intl.DateTimeFormat('en-IN', { month: 'short', year: 'numeric' }).format(joinedDate)
  : 'Unknown';

const recentScoreBars = attemptsWithPercent.slice(0, 5);
const recentScoreSlots = Array.from({ length: 5 }, (_, index) => recentScoreBars[index] ?? null);

const subjectAccuracyMap = new Map(
  subjectAccuracyRows.map((row) => [
    row.subjectName,
    row.total > 0 ? Math.round((row.correct / row.total) * 100) : 0,
  ])
);

const subjectRows = ['Physics', 'Chemistry', 'Biology'].map((name) => ({
  name,
  percent: subjectAccuracyMap.get(name) ?? 0,
  theme: subjectTheme(name),
}));

const filterHref = (filter: 'all' | 'passed' | 'failed') => {
  const params = new URLSearchParams(Astro.url.searchParams);

  if (filter === 'all') {
    params.delete('filter');
  } else {
    params.set('filter', filter);
  }

  const query = params.toString();
  return query ? `/admin/students/${student.id}?${query}` : `/admin/students/${student.id}`;
};
---

<AdminLayout
  title={`${student.fullName} | Admin | Dream Neet Academy`}
  pageTitle="Student Profile"
  userName={admin.fullName}
  userEmail={Astro.locals.user?.email ?? admin.fullName}
>
  <a slot="actions" href="/admin/students" class="top-action">← Back to Students</a>

  <section class="profile-hero">
    <div class="profile-hero__avatar">{initialsFor(student.fullName)}</div>

    <div class="profile-hero__content">
      <h2>{student.fullName}</h2>
      <div class="profile-hero__email">✉ {email}</div>
      <div class="profile-hero__tags">
        <span class="tag tag--role">Student</span>
        <span class:list={['tag', student.isActive ? 'tag--active' : 'tag--disabled']}>
          {student.isActive ? 'Active' : 'Disabled'}
        </span>
        <span class="tag tag--joined">Joined {joinedLabel}</span>
      </div>

      <div class="profile-hero__actions">
        <form action="/api/admin/students" method="POST">
          <input type="hidden" name="student_id" value={student.id} />
          <input type="hidden" name="action" value={student.isActive ? 'disable' : 'enable'} />
          <button type="submit" class="hero-button hero-button--ghost" disabled={!hasIsActiveColumn}>
            {student.isActive ? 'Disable Account' : 'Enable Account'}
          </button>
        </form>

      </div>
      {!hasIsActiveColumn && <p class="profile-hero__migration-note">Apply the latest database migration to use disable and enable controls.</p>}
    </div>

    <div class="profile-hero__stats">
      <div class="hero-stat-box">
        <strong>{totalAttempts}</strong>
        <span>Total Attempts</span>
      </div>
      <div class="hero-stat-box">
        <strong>{averageScore}%</strong>
        <span>Avg Score</span>
      </div>
      <div class="hero-stat-box">
        <strong>{bestScore}%</strong>
        <span>Best Score</span>
      </div>
      <div class="hero-stat-box">
        <strong>{relativeLastActive(lastActive)}</strong>
        <span>Last Active</span>
      </div>
    </div>
  </section>

  <section class="summary-strip">
    <article class="summary-card">
      <h3>Subject Accuracy</h3>
      <div class="subject-bars">
        {subjectRows.map((subject) => (
          <div class="subject-bar-row">
            <span class="subject-bar-row__name">{subject.name}</span>
            <div class="subject-bar-row__track">
              <span
                class="subject-bar-row__fill"
                style={`width:${subject.percent}%; background:${subject.theme.bar};`}
              ></span>
            </div>
            <span class="subject-bar-row__value" style={`color:${subject.theme.bar};`}>{subject.percent}%</span>
          </div>
        ))}
      </div>
    </article>

    <article class="summary-card">
      <h3>Recent Scores</h3>
      <div class="score-sparkline">
        {recentScoreSlots.map((attempt) => (
          <div class="score-sparkline__item">
            <div class="score-sparkline__track">
              {attempt ? (
                <span
                  class:list={[
                    'score-sparkline__bar',
                    attempt.percent >= 70
                      ? 'score-sparkline__bar--good'
                      : attempt.percent >= 40
                        ? 'score-sparkline__bar--mid'
                        : 'score-sparkline__bar--low',
                  ]}
                  style={`height:${Math.max(attempt.percent, 12)}%;`}
                ></span>
              ) : (
                <span class="score-sparkline__bar score-sparkline__bar--empty" style="height:16%;"></span>
              )}
            </div>
            <span class="score-sparkline__label">{attempt ? `${attempt.percent}%` : '—'}</span>
          </div>
        ))}
      </div>
      <p class="score-sparkline__note">Last 5 tests</p>
    </article>

    <article class="summary-card">
      <h3>Activity</h3>
      <div class="activity-list">
        <div class="activity-row">
          <span>Tests Attempted</span>
          <strong>{totalAttempts}</strong>
        </div>
        <div class="activity-row">
          <span>Questions Answered</span>
          <strong>{totalQuestionsAnswered}</strong>
        </div>
        <div class="activity-row">
          <span>Correct Answers</span>
          <strong>{totalCorrect}</strong>
        </div>
      </div>
    </article>
  </section>

  <section class="attempts-card">
    <div class="attempts-card__header">
      <div class="attempts-card__title-group">
        <h3>Test Attempts</h3>
        <span class="count-badge">{totalAttempts} total attempts</span>
      </div>

      <div class="filter-pills">
        <a href={filterHref('all')} class:list={['filter-pill', { 'filter-pill--active': attemptFilter === 'all' }]}>All</a>
        <a href={filterHref('passed')} class:list={['filter-pill', { 'filter-pill--active': attemptFilter === 'passed' }]}>
          Passed (≥40%)
        </a>
        <a href={filterHref('failed')} class:list={['filter-pill', { 'filter-pill--active': attemptFilter === 'failed' }]}>
          Failed (&lt;40%)
        </a>
      </div>
    </div>

    {filteredAttempts.length ? (
      <div class="attempts-table-wrap">
        <table class="attempts-table">
          <thead>
            <tr>
              <th scope="col">Test Name</th>
              <th scope="col">Subject</th>
              <th scope="col">Score</th>
              <th scope="col">Accuracy</th>
              <th scope="col">Time Taken</th>
              <th scope="col">Date</th>
              <th scope="col">Action</th>
            </tr>
          </thead>
          <tbody>
            {filteredAttempts.map((attempt) => {
              const score = attempt.score ?? 0;
              const total = attempt.totalQuestions ?? 0;
              const scoreTone =
                attempt.percent >= 70 ? '#065F46' : attempt.percent >= 40 ? '#92400E' : '#991B1B';
              const subjectColors = subjectTheme(attempt.subjectName);

              return (
                <tr>
                  <td>
                    <div class="attempt-name">{attempt.testTitle}</div>
                    <div class="attempt-topic">{attempt.topicName ?? 'No topic assigned'}</div>
                  </td>
                  <td>
                    <span
                      class="subject-pill"
                      style={`background:${subjectColors.pillBg}; color:${subjectColors.pillText};`}
                    >
                      {attempt.subjectName ?? 'General'}
                    </span>
                  </td>
                  <td>
                    <span class="score-value">
                      <strong style={`color:${scoreTone};`}>{score}</strong>
                      <span> / </span>
                      <em>{total}</em>
                    </span>
                  </td>
                  <td>
                    <span
                      class:list={[
                        'accuracy-pill',
                        attempt.percent >= 70
                          ? 'accuracy-pill--good'
                          : attempt.percent >= 40
                            ? 'accuracy-pill--mid'
                            : 'accuracy-pill--low',
                      ]}
                    >
                      {attempt.percent >= 70 ? '✓' : attempt.percent >= 40 ? '~' : '✗'} {attempt.percent}%
                    </span>
                  </td>
                  <td class="muted-cell">{formatDuration(attempt.timeTakenSeconds)}</td>
                  <td class="muted-cell">{attempt.submittedAt ? formatDate(attempt.submittedAt) : '—'}</td>
                  <td>
                    <a href={`/admin/students/${student.id}/attempts/${attempt.id}`} class="review-button">Review →</a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="empty-state">
        <div class="empty-state__icon">📋</div>
        <div class="empty-state__title">No attempts yet</div>
        <div class="empty-state__text">This student hasn't submitted any tests</div>
      </div>
    )}
  </section>
</AdminLayout>

