---
export const prerender = false;

import { asc, eq, sql } from 'drizzle-orm';

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, testAttempts } from '../../../db';
import { requireAuth } from '../../../lib/auth';
import { hasProfileIsActiveColumn } from '../../../lib/profileColumns';
import { getAdminSupabase } from '../../../lib/supabase';

const authResult = await requireAuth(Astro, 'admin');

if (authResult instanceof Response) {
  return authResult;
}

const admin = authResult;
const query = Astro.url.searchParams.get('q')?.trim() ?? '';
const hasIsActiveColumn = await hasProfileIsActiveColumn();

const studentsResult = await db.execute(sql`
  select
    p.id,
    p.full_name as "fullName",
    ${hasIsActiveColumn ? sql`p.is_active` : sql`true`} as "isActive",
    count(${testAttempts.id})::int as "totalAttempts",
    coalesce(
      round(
        avg(
          case
            when ${testAttempts.totalQuestions} > 0 and ${testAttempts.score} is not null
              then (${testAttempts.score}::numeric / ${testAttempts.totalQuestions}::numeric) * 100
          end
        )
      )::text,
      '0'
    ) as "averagePercent",
    max(${testAttempts.submittedAt}) as "lastActive"
  from profiles p
  left join test_attempts on ${testAttempts.studentId} = p.id
  where p.role = 'student'
  group by p.id, p.full_name${hasIsActiveColumn ? sql`, p.is_active` : sql``}
  order by p.full_name asc
`);

const students = studentsResult as Array<{
  id: string;
  fullName: string;
  isActive: boolean;
  totalAttempts: number;
  averagePercent: string;
  lastActive: Date | string | null;
}>;

const adminSupabase = getAdminSupabase();
const allUsers: Array<{ id: string; email?: string | null }> = [];
let page = 1;

while (true) {
  const { data: usersData } = await adminSupabase.auth.admin.listUsers({
    page,
    perPage: 1000,
  });

  const users = usersData?.users ?? [];
  allUsers.push(...users);

  if (users.length < 1000) {
    break;
  }

  page += 1;
}

const emailById = new Map(allUsers.map((user) => [user.id, user.email ?? '-']));

const filteredStudents = students.filter((student) => {
  if (!query) {
    return true;
  }

  const email = emailById.get(student.id) ?? '';
  return (
    student.fullName.toLowerCase().includes(query.toLowerCase()) ||
    email.toLowerCase().includes(query.toLowerCase())
  );
});

const gradients = [
  'linear-gradient(135deg, #3B82F6, #1D4ED8)',
  'linear-gradient(135deg, #8B5CF6, #6366F1)',
  'linear-gradient(135deg, #10B981, #059669)',
  'linear-gradient(135deg, #F59E0B, #D97706)',
];

const initialsFor = (fullName: string) => {
  const parts = fullName.trim().split(/\s+/).filter(Boolean);
  const first = parts[0]?.[0] ?? 'S';
  const last = parts[1]?.[0] ?? parts[0]?.[1] ?? '';
  return `${first}${last}`.toUpperCase();
};

const relativeDays = (value: Date | string | null) => {
  if (!value) {
    return 'Never';
  }

  const date = value instanceof Date ? value : new Date(value);

  if (Number.isNaN(date.getTime())) {
    return 'Never';
  }

  const diffDays = Math.max(0, Math.floor((Date.now() - date.getTime()) / (24 * 60 * 60 * 1000)));

  if (diffDays === 0) {
    return 'Today';
  }

  if (diffDays === 1) {
    return '1 day ago';
  }

  return `${diffDays} days ago`;
};
---

<AdminLayout
  title="Admin Students | Dream Neet Academy"
  pageTitle="Students"
  userName={admin.fullName}
  userEmail={Astro.locals.user?.email ?? admin.fullName}
>
  <section class="filters-card">
    <form action="/admin/students" method="GET" class="filters-form">
      <label class="search-field">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
        <input type="search" name="q" value={query} placeholder="Search students by name or email" />
      </label>
    </form>
  </section>

  <section class="create-card">
    <div class="section-heading">
      <div>
        <h2>Add Student</h2>
        <p>Create a student login directly from the admin panel.</p>
      </div>
    </div>

    <form action="/api/admin/students" method="POST" class="create-form">
      <input type="hidden" name="action" value="create" />
      <label>
        <span>Full name</span>
        <input type="text" name="full_name" placeholder="Student name" minlength="2" required />
      </label>
      <label>
        <span>Email</span>
        <input type="email" name="email" placeholder="student@example.com" required />
      </label>
      <label>
        <span>Password</span>
        <input type="password" name="password" placeholder="Minimum 8 characters" minlength="8" required />
      </label>
      <button type="submit" class="primary-button">Add Student</button>
    </form>
    {!hasIsActiveColumn && (
      <p class="migration-note">
        Student disable and enable actions will work after the latest database migration is applied.
      </p>
    )}
  </section>

  {filteredStudents.length ? (
    <section class="students-grid">
      {filteredStudents.map((student, index) => (
        <article class="student-card">
          <a
            href={`/admin/students/${student.id}`}
            class="student-card__overlay"
            aria-label={`Open profile for ${student.fullName}`}
          ></a>

          <div class="student-card__top">
            <div class="student-card__avatar" style={`background:${gradients[index % gradients.length]};`}>
              {initialsFor(student.fullName)}
            </div>
            <div class="student-card__identity">
              <h2>{student.fullName}</h2>
              <p>{emailById.get(student.id) ?? '-'}</p>
              <span class:list={['status-pill', student.isActive ? 'status-pill--active' : 'status-pill--disabled']}>
                {student.isActive ? 'Active' : 'Disabled'}
              </span>
            </div>
          </div>

          <div class="student-card__stats">
            <div>
              <strong>{student.totalAttempts}</strong>
              <span>Attempts</span>
            </div>
            <div>
              <strong>{student.averagePercent}%</strong>
              <span>Avg Score</span>
            </div>
            <div>
              <strong>{relativeDays(student.lastActive)}</strong>
              <span>Last Active</span>
            </div>
          </div>

          <div class="student-card__actions">
            <a href={`/admin/students/${student.id}`} class="student-card__link">View Profile →</a>

            <form action="/api/admin/students" method="POST">
              <input type="hidden" name="student_id" value={student.id} />
              <input type="hidden" name="action" value={student.isActive ? 'disable' : 'enable'} />
              <button type="submit" class="ghost-button" disabled={!hasIsActiveColumn}>
                {student.isActive ? 'Disable Account' : 'Enable Account'}
              </button>
            </form>

          </div>
        </article>
      ))}
    </section>
  ) : (
    <div class="empty-state">No students matched this search yet.</div>
  )}
</AdminLayout>

<style>
  .filters-card,
  .create-card,
  .student-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
  }

  .filters-card {
    padding: 12px 16px;
    margin-bottom: 16px;
  }

  .create-card {
    position: relative;
    overflow: hidden;
    padding: 20px;
    margin-bottom: 16px;
    border-color: #d9dfec;
    background:
      radial-gradient(circle at top right, rgba(245, 197, 24, 0.1), transparent 30%),
      linear-gradient(180deg, #ffffff 0%, #fffdfa 100%);
  }

  .create-card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: linear-gradient(180deg, #0a0f1e 0%, #f5c518 100%);
  }

  .section-heading h2 {
    margin: 0;
    color: #0a0f1e;
    font-size: 1rem;
    font-weight: 700;
  }

  .section-heading p {
    margin: 6px 0 0;
    color: #6b7280;
    font-size: 0.85rem;
  }

  .create-form {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .create-form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .create-form span {
    color: #475569;
    font-size: 0.78rem;
    font-weight: 600;
  }

  .migration-note {
    margin: 14px 0 0;
    color: #92400e;
    font-size: 0.82rem;
  }

  .create-form input {
    min-height: 42px;
    border: 1px solid #dbe3ef;
    border-radius: 10px;
    background: #fff;
    padding: 0 12px;
    font-size: 0.9rem;
    color: #0a0f1e;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .create-form input::placeholder {
    color: #9aa5b4;
  }

  .create-form input:focus {
    outline: none;
    border-color: #f5c518;
    box-shadow: 0 0 0 3px rgba(245, 197, 24, 0.16);
  }

  .filters-form {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .search-field {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .search-field svg {
    width: 18px;
    height: 18px;
    stroke: #9aa5b4;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex-shrink: 0;
  }

  .search-field input {
    width: 100%;
    border: none;
    outline: none;
    background: transparent;
    font-size: 0.9rem;
    color: #0a0f1e;
  }

  .students-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .student-card {
    position: relative;
    padding: 20px;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .student-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(10, 15, 30, 0.08);
    border-color: #d7deea;
  }

  .student-card:focus-within {
    border-color: #cbd5e1;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.14), 0 10px 24px rgba(10, 15, 30, 0.08);
  }

  .student-card__overlay {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: 1;
  }

  .student-card__overlay:focus-visible {
    outline: none;
  }

  .student-card__top {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .student-card__avatar {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 0.84rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .student-card__identity {
    min-width: 0;
  }

  .student-card__identity h2 {
    margin: 0;
    color: #0a0f1e;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .student-card__identity p {
    margin: 4px 0 0;
    color: #9aa5b4;
    font-size: 0.82rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    margin-top: 8px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .status-pill--active {
    background: #dcfce7;
    color: #166534;
  }

  .status-pill--disabled {
    background: #fee2e2;
    color: #991b1b;
  }

  .student-card__stats {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid #f1f3f9;
  }

  .student-card__stats strong {
    display: block;
    color: #0a0f1e;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .student-card__stats span {
    display: block;
    margin-top: 4px;
    color: #9aa5b4;
    font-size: 0.74rem;
    font-weight: 500;
  }

  .student-card__link {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    color: #0a0f1e;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .student-card__actions {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 16px;
  }

  .student-card__actions form {
    margin-left: auto;
  }

  .primary-button,
  .ghost-button {
    min-height: 40px;
    border-radius: 10px;
    padding: 0 14px;
    font-size: 0.82rem;
    font-weight: 700;
    transition: all 0.15s ease;
    cursor: pointer;
  }

  .primary-button {
    border: none;
    background: #0a0f1e;
    color: #f5c518;
    box-shadow: 0 10px 24px rgba(10, 15, 30, 0.16);
    justify-self: end;
    min-width: 168px;
  }

  .ghost-button {
    border: 1px solid rgba(10, 15, 30, 0.14);
    background: #fffdfa;
    color: #0a0f1e;
    box-shadow: 0 6px 18px rgba(10, 15, 30, 0.06);
  }

  .ghost-button:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .primary-button:hover,
  .ghost-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(10, 15, 30, 0.12);
  }

  .primary-button:hover {
    background: #161d33;
    color: #ffd84d;
    box-shadow: 0 12px 24px rgba(10, 15, 30, 0.2);
  }

  .ghost-button:hover {
    border-color: #0a0f1e;
    background: #0a0f1e;
    color: #f5c518;
    box-shadow: 0 12px 24px rgba(10, 15, 30, 0.18);
  }

  .ghost-button:disabled:hover {
    transform: none;
    box-shadow: none;
    border-color: rgba(10, 15, 30, 0.14);
    background: #fffdfa;
    color: #0a0f1e;
  }

  .empty-state {
    padding: 28px 20px;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    color: #9aa5b4;
    font-size: 0.875rem;
  }

  @media (max-width: 1080px) {
    .create-form {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .students-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .create-form {
      grid-template-columns: 1fr;
    }

    .students-grid {
      grid-template-columns: 1fr;
    }

    .student-card__actions {
      flex-wrap: wrap;
    }

    .student-card__actions form {
      margin-left: 0;
    }
  }
</style>
