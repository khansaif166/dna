---
export const prerender = false;

import { asc } from 'drizzle-orm';

import { db, subTopics, subjects, topics } from '../../db';
import { requireAuth } from '../../lib/auth';
import AdminLayout from '../../layouts/AdminLayout.astro';

const authResult = await requireAuth(Astro, 'admin');

if (authResult instanceof Response) {
  return authResult;
}

const admin = authResult;
const [allSubjects, allTopics, allSubTopics] = await Promise.all([
  db.select().from(subjects).orderBy(asc(subjects.order)),
  db.select().from(topics).orderBy(asc(topics.subjectId), asc(topics.order)),
  db.select().from(subTopics).orderBy(asc(subTopics.topicId), asc(subTopics.order)),
]);

const successParam = Astro.url.searchParams.get('success');
const errorParam = Astro.url.searchParams.get('error');
const selectedSubjectId = Astro.url.searchParams.get('subject');
const preselectedChapterId = Astro.url.searchParams.get('chapterId');

const subjectThemes = [
  {
    name: 'Blue',
    dot: '#3B82F6',
    tint: '#EFF6FF',
    ring: 'rgba(59, 130, 246, 0.22)',
    optionDot: '🔵',
  },
  {
    name: 'Green',
    dot: '#10B981',
    tint: '#ECFDF5',
    ring: 'rgba(16, 185, 129, 0.2)',
    optionDot: '🟢',
  },
  {
    name: 'Amber',
    dot: '#F59E0B',
    tint: '#FFFBEB',
    ring: 'rgba(245, 158, 11, 0.22)',
    optionDot: '🟠',
  },
] as const;

function getSubjectTheme(order: number) {
  return subjectThemes[Math.max(order - 1, 0) % subjectThemes.length];
}

function formatFlashMessage(value: string | null, fallback: string) {
  if (!value) {
    return null;
  }

  const normalized = value.replace(/[-_]+/g, ' ').trim();

  if (!normalized) {
    return fallback;
  }

  return normalized.charAt(0).toUpperCase() + normalized.slice(1);
}

const subjectTopicMap = new Map(
  allSubjects.map((subject) => [
    subject.id,
    allTopics.filter((topic) => topic.subjectId === subject.id).sort((a, b) => a.order - b.order),
  ])
);

const subTopicCountMap = new Map<string, number>();

for (const subTopic of allSubTopics) {
  subTopicCountMap.set(subTopic.topicId, (subTopicCountMap.get(subTopic.topicId) ?? 0) + 1);
}

const subjectRows = allSubjects.map((subject) => {
  const subjectTopics = subjectTopicMap.get(subject.id) ?? [];
  const chapters = subjectTopics.map((topic) => ({
    ...topic,
    subTopicCount: subTopicCountMap.get(topic.id) ?? 0,
  }));

  return {
    ...subject,
    theme: getSubjectTheme(subject.order),
    chapterCount: chapters.length,
    emptyTopicCount: chapters.filter((chapter) => chapter.subTopicCount === 0).length,
    chapters,
  };
});

const successMessage = formatFlashMessage(successParam, 'Action completed successfully.');
const errorMessage = formatFlashMessage(errorParam, 'Something went wrong. Please try again.');
---

<AdminLayout
  title="Admin Subjects | Dream Neet Academy"
  pageTitle="Subjects & Chapters"
  userName={admin.fullName}
  userEmail={Astro.locals.user?.email ?? admin.fullName}
>
  <section class="page-intro">
    <p class="breadcrumb">Admin / <span class="breadcrumb__active">Subjects & Chapters</span></p>
  </section>

  <section class="workspace">
    <aside class="workspace__forms">
      <div class="forms-sticky">
        {successMessage && (
          <p class="flash-message flash-message--success">{successMessage}</p>
        )}
        {errorMessage && (
          <p class="flash-message flash-message--error">{errorMessage}</p>
        )}

        <article class="editor-card">
          <div class="editor-card__header editor-card__header--subject">
            <span class="editor-card__accent editor-card__accent--subject"></span>
            <div class="editor-card__title-row">
              <span class="editor-card__icon editor-card__icon--subject" aria-hidden="true">+</span>
              <div>
                <h2>Add Subject</h2>
                <p>Add a new subject to the syllabus</p>
              </div>
            </div>
          </div>

          <form action="/api/admin/subjects" method="POST" class="editor-card__body">
            <label class="form-field">
              <span>Subject Name</span>
              <input class="form-input" type="text" name="name" placeholder="e.g. Physics" required />
            </label>

            <label class="form-field">
              <span>Display Order</span>
              <small>Lower number appears first (Physics=1, Chemistry=2, Biology=3)</small>
              <input class="form-input form-input--compact" type="number" name="order" min="1" required />
            </label>

            <div class="form-field">
              <span>Subject Color Theme</span>
              <div class="color-preview-row" aria-hidden="true">
                {subjectThemes.map((theme, index) => (
                  <div class="color-preview">
                    <span
                      class:list={['color-preview__swatch', { 'color-preview__swatch--selected': index === 0 }]}
                      style={`--swatch:${theme.dot}; --ring:${theme.ring};`}
                    ></span>
                    <small>{theme.name}</small>
                  </div>
                ))}
              </div>
            </div>

            <button type="submit" class="submit-button submit-button--dark">+ Create Subject</button>
          </form>
        </article>

        <article class="editor-card" id="add-chapter-form">
          <div class="editor-card__header editor-card__header--chapter">
            <span class="editor-card__accent editor-card__accent--chapter"></span>
            <div class="editor-card__title-row">
              <span class="editor-card__icon editor-card__icon--chapter" aria-hidden="true">C</span>
              <div>
                <h2>Add Chapter</h2>
                <p>Add a chapter under a subject</p>
              </div>
            </div>
          </div>

          <form action="/api/admin/topics" method="POST" class="editor-card__body">
            <label class="form-field">
              <span>Parent Subject</span>
              <select class="form-input form-select" name="subject_id" required>
                <option value="" disabled selected={!selectedSubjectId}>Select subject</option>
                {subjectRows.map((subject) => (
                  <option value={subject.id} selected={selectedSubjectId === subject.id}>
                    {subject.theme.optionDot} {subject.name}
                  </option>
                ))}
              </select>
            </label>

            <label class="form-field">
              <span>Chapter Name</span>
              <input class="form-input" type="text" name="name" placeholder="e.g. Mechanics" required />
            </label>

            <label class="form-field">
              <span>Order within Subject</span>
              <input class="form-input form-input--compact" type="number" name="order" min="1" required />
            </label>

            <button type="submit" class="submit-button submit-button--gold">+ Add Chapter</button>
          </form>
        </article>

        <article class="editor-card" id="add-topic-form">
          <div class="editor-card__header editor-card__header--resource">
            <span class="editor-card__accent editor-card__accent--resource"></span>
            <div class="editor-card__title-row">
              <span class="editor-card__icon editor-card__icon--resource" aria-hidden="true">▶</span>
              <div>
                <h2>Add Topic & Video</h2>
                <p>Add a topic inside a chapter with its video</p>
              </div>
            </div>
          </div>

          <form action="/api/admin/resources" method="POST" class="editor-card__body">
            <label class="form-field">
              <span>Parent Chapter</span>
              <select class="form-input form-select" name="topic_id" required>
                <option value="" disabled selected={!preselectedChapterId}>Select chapter</option>
                {subjectRows.map((subject) => (
                  <optgroup label={subject.name}>
                    {subject.chapters.map((chapter) => (
                      <option value={chapter.id} selected={preselectedChapterId === chapter.id}>
                        {chapter.name}
                      </option>
                    ))}
                  </optgroup>
                ))}
              </select>
            </label>

            <label class="form-field">
              <span>Topic Name</span>
              <input class="form-input" type="text" name="title" placeholder="e.g. Laws of Motion" required />
            </label>

            <label class="form-field">
              <span>YouTube URL</span>
              <input
                class="form-input"
                type="url"
                name="youtube_url"
                placeholder="https://youtube.com/watch?v=..."
                required
              />
            </label>

            <label class="form-field">
              <span>Notes</span>
              <textarea
                class="form-input form-textarea"
                name="notes"
                placeholder="Optional: add context or timestamps"
              ></textarea>
            </label>

            <label class="form-field">
              <span>Display Order</span>
              <input class="form-input form-input--compact" type="number" name="order" min="1" required />
            </label>

            <button type="submit" class="submit-button submit-button--green">+ Add Topic & Video</button>
          </form>
        </article>
      </div>
    </aside>

    <div class="workspace__data">
      <article class="data-card">
        <div class="data-card__header">
          <h2>Subjects</h2>
          <span class="count-badge">{subjectRows.length} subjects</span>
        </div>

        {subjectRows.length ? (
          <div>
            {subjectRows.map((subject) => (
              <div class="subject-row">
                <div class="subject-row__info">
                  <span class="subject-row__dot" style={`--subject-dot:${subject.theme.dot};`}></span>
                  <div>
                    <div class="subject-row__name">{subject.name}</div>
                    <div class="subject-row__meta">{subject.chapterCount} chapters</div>
                  </div>
                </div>

                <div class="subject-row__side">
                  <span class="order-badge">#{subject.order}</span>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="empty-panel">
            <p>No subjects yet — add one using the form on the left.</p>
          </div>
        )}
      </article>

      <section class="chapters-section">
        <div class="section-toolbar">
          <h2>Chapters</h2>
          <button type="button" class="accordion-toggle" data-accordion-toggle>Expand all</button>
        </div>

        <div class="accordion-list">
          {subjectRows.map((subject) => (
            <article class="accordion-card">
              <button
                type="button"
                class="accordion-header"
                style={`--subject-color:${subject.theme.dot};`}
                aria-expanded="false"
              >
                <span class="accordion-header__accent" aria-hidden="true"></span>
                <span class="subject-row__dot" style={`--subject-dot:${subject.theme.dot};`}></span>
                <span class="accordion-header__title">{subject.name}</span>
                <span class="count-badge">{subject.chapterCount} chapters</span>
                <span class="accordion-header__side">
                  {subject.emptyTopicCount > 0 && (
                    <span class="warning-badge">{subject.emptyTopicCount} need topics</span>
                  )}
                  <span class="chevron" aria-hidden="true">▾</span>
                </span>
              </button>

              <div class="accordion-body">
                {subject.chapters.length ? (
                  subject.chapters.map((chapter) => (
                    <div class="chapter-row">
                      <span class="chapter-row__order">{String(chapter.order).padStart(2, '0')}</span>
                      <span class="chapter-row__name">{chapter.name}</span>
                      <span
                        class:list={[
                          'topic-pill',
                          { 'topic-pill--empty': chapter.subTopicCount === 0 },
                        ]}
                      >
                        {chapter.subTopicCount === 0 ? '⚠ No topics' : `▶ ${chapter.subTopicCount} topics`}
                      </span>
                      <a
                        href={`/admin/subjects?subject=${subject.id}&chapterId=${chapter.id}#add-topic-form`}
                        class="chapter-action"
                        style={`--subject-color:${subject.theme.dot};`}
                      >
                        Add Topic
                      </a>
                    </div>
                  ))
                ) : (
                  <div class="empty-panel empty-panel--tight">
                    <p>No chapters yet — add one using the form</p>
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>

  <script>
    const accordionCards = Array.from(document.querySelectorAll('.accordion-card'));
    const accordionBodies = Array.from(document.querySelectorAll('.accordion-body'));
    const chevrons = Array.from(document.querySelectorAll('.chevron'));
    const toggleButton = document.querySelector('[data-accordion-toggle]');

    const setCardOpen = (card, open) => {
      const header = card.querySelector('.accordion-header');
      const body = card.querySelector('.accordion-body');
      const chevron = card.querySelector('.chevron');

      if (!header || !body || !chevron) {
        return;
      }

      body.style.display = open ? 'block' : 'none';
      chevron.style.transform = open ? 'rotate(180deg)' : 'rotate(0deg)';
      header.setAttribute('aria-expanded', open ? 'true' : 'false');
    };

    const updateToggleLabel = () => {
      if (!toggleButton) {
        return;
      }

      const allOpen = accordionCards.length > 0 && accordionCards.every((card) => {
        const header = card.querySelector('.accordion-header');
        return header?.getAttribute('aria-expanded') === 'true';
      });

      toggleButton.textContent = allOpen ? 'Collapse all' : 'Expand all';
    };

    document.querySelectorAll('.accordion-header').forEach((header) => {
      header.addEventListener('click', () => {
        const card = header.closest('.accordion-card');
        const body = card?.querySelector('.accordion-body');
        const isOpen = body instanceof HTMLElement && body.style.display === 'block';

        accordionCards.forEach((item) => setCardOpen(item, false));

        if (card && !isOpen) {
          setCardOpen(card, true);
        }

        updateToggleLabel();
      });
    });

    toggleButton?.addEventListener('click', () => {
      const allOpen = accordionCards.length > 0 && accordionCards.every((card) => {
        const header = card.querySelector('.accordion-header');
        return header?.getAttribute('aria-expanded') === 'true';
      });

      accordionCards.forEach((card) => setCardOpen(card, !allOpen));
      updateToggleLabel();
    });

    accordionBodies.forEach((body) => {
      body.style.display = 'none';
    });

    chevrons.forEach((chevron) => {
      chevron.style.transform = 'rotate(0deg)';
    });

    if (accordionCards[0]) {
      setCardOpen(accordionCards[0], true);
    }

    updateToggleLabel();
  </script>
</AdminLayout>

