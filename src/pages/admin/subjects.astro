---
export const prerender = false;

import { asc } from 'drizzle-orm';

import AdminLayout from '../../layouts/AdminLayout.astro';
import { db, subjects, topicResources, topics } from '../../db';
import { requireAuth } from '../../lib/auth';

const authResult = await requireAuth(Astro, 'admin');

if (authResult instanceof Response) {
  return authResult;
}

const admin = authResult;
const [allSubjects, allTopics, allResources] = await Promise.all([
  db.select().from(subjects).orderBy(asc(subjects.order)),
  db.select().from(topics).orderBy(asc(topics.subjectId), asc(topics.order)),
  db.select().from(topicResources).orderBy(asc(topicResources.topicId), asc(topicResources.order)),
]);

const successParam = Astro.url.searchParams.get('success');
const errorParam = Astro.url.searchParams.get('error');
const selectedSubjectId = Astro.url.searchParams.get('subject');
const selectedTopicId = Astro.url.searchParams.get('topic');

const subjectThemes = [
  {
    name: 'Blue',
    dot: '#3B82F6',
    tint: '#EFF6FF',
    ring: 'rgba(59, 130, 246, 0.22)',
    optionDot: '🔵',
  },
  {
    name: 'Green',
    dot: '#10B981',
    tint: '#ECFDF5',
    ring: 'rgba(16, 185, 129, 0.2)',
    optionDot: '🟢',
  },
  {
    name: 'Amber',
    dot: '#F59E0B',
    tint: '#FFFBEB',
    ring: 'rgba(245, 158, 11, 0.22)',
    optionDot: '🟠',
  },
] as const;

function getSubjectTheme(order: number) {
  return subjectThemes[Math.max(order - 1, 0) % subjectThemes.length];
}

function formatFlashMessage(value: string | null, fallback: string) {
  if (!value) {
    return null;
  }

  const normalized = value.replace(/[-_]+/g, ' ').trim();

  if (!normalized) {
    return fallback;
  }

  return normalized.charAt(0).toUpperCase() + normalized.slice(1);
}

const subjectTopicMap = new Map(
  allSubjects.map((subject) => [
    subject.id,
    allTopics.filter((topic) => topic.subjectId === subject.id).sort((a, b) => a.order - b.order),
  ])
);

const resourceCountMap = new Map<string, number>();

for (const resource of allResources) {
  resourceCountMap.set(resource.topicId, (resourceCountMap.get(resource.topicId) ?? 0) + 1);
}

const subjectRows = allSubjects.map((subject) => {
  const subjectTopics = subjectTopicMap.get(subject.id) ?? [];

  return {
    ...subject,
    theme: getSubjectTheme(subject.order),
    topicCount: subjectTopics.length,
    topics: subjectTopics.map((topic) => ({
      ...topic,
      resourceCount: resourceCountMap.get(topic.id) ?? 0,
    })),
  };
});

const successMessage = formatFlashMessage(successParam, 'Action completed successfully.');
const errorMessage = formatFlashMessage(errorParam, 'Something went wrong. Please try again.');
---

<AdminLayout
  title="Admin Subjects | Dream Neet Academy"
  pageTitle="Subjects & Topics"
  userName={admin.fullName}
  userEmail={Astro.locals.user?.email ?? admin.fullName}
>
  <section class="page-intro">
    <p class="breadcrumb">Admin / <span class="breadcrumb__active">Subjects & Topics</span></p>
  </section>

  <section class="workspace">
    <aside class="workspace__forms">
      <div class="forms-sticky">
        {successMessage && (
          <p class="flash-message flash-message--success">{successMessage}</p>
        )}
        {errorMessage && (
          <p class="flash-message flash-message--error">{errorMessage}</p>
        )}

        <article class="editor-card">
          <div class="editor-card__header editor-card__header--subject">
            <span class="editor-card__accent editor-card__accent--subject"></span>
            <div class="editor-card__title-row">
              <span class="editor-card__icon editor-card__icon--subject" aria-hidden="true">+</span>
              <div>
                <h2>Add Subject</h2>
                <p>Add a new subject to the syllabus</p>
              </div>
            </div>
          </div>

          <form action="/api/admin/subjects" method="POST" class="editor-card__body">
            <label class="form-field">
              <span>Subject Name</span>
              <input class="form-input" type="text" name="name" placeholder="e.g. Physics" required />
            </label>

            <label class="form-field">
              <span>Display Order</span>
              <small>Lower number appears first (Physics=1, Chemistry=2, Biology=3)</small>
              <input class="form-input form-input--compact" type="number" name="order" min="1" required />
            </label>

            <div class="form-field">
              <span>Subject Color Theme</span>
              <div class="color-preview-row" aria-hidden="true">
                {subjectThemes.map((theme, index) => (
                  <div class="color-preview">
                    <span
                      class:list={['color-preview__swatch', { 'color-preview__swatch--selected': index === 0 }]}
                      style={`--swatch:${theme.dot}; --ring:${theme.ring};`}
                    ></span>
                    <small>{theme.name}</small>
                  </div>
                ))}
              </div>
            </div>

            <button type="submit" class="submit-button submit-button--dark">+ Create Subject</button>
          </form>
        </article>

        <article class="editor-card">
          <div class="editor-card__header editor-card__header--topic">
            <span class="editor-card__accent editor-card__accent--topic"></span>
            <div class="editor-card__title-row">
              <span class="editor-card__icon editor-card__icon--topic" aria-hidden="true">T</span>
              <div>
                <h2>Add Topic</h2>
                <p>Add a topic under a subject</p>
              </div>
            </div>
          </div>

          <form action="/api/admin/topics" method="POST" class="editor-card__body">
            <label class="form-field">
              <span>Parent Subject</span>
              <select class="form-input form-select" name="subject_id" required>
                <option value="" disabled selected={!selectedSubjectId}>Select subject</option>
                {subjectRows.map((subject) => (
                  <option value={subject.id} selected={selectedSubjectId === subject.id}>
                    {subject.theme.optionDot} {subject.name}
                  </option>
                ))}
              </select>
            </label>

            <label class="form-field">
              <span>Topic Name</span>
              <input class="form-input" type="text" name="name" placeholder="e.g. Laws of Motion" required />
            </label>

            <label class="form-field">
              <span>Order within Subject</span>
              <input class="form-input form-input--compact" type="number" name="order" min="1" required />
            </label>

            <button type="submit" class="submit-button submit-button--gold">+ Add Topic</button>
          </form>
        </article>

        <article class="editor-card" id="video-resource-form">
          <div class="editor-card__header editor-card__header--resource">
            <span class="editor-card__accent editor-card__accent--resource"></span>
            <div class="editor-card__title-row">
              <span class="editor-card__icon editor-card__icon--resource" aria-hidden="true">▶</span>
              <div>
                <h2>Add Video Resource</h2>
                <p>Link a YouTube video to a topic</p>
              </div>
            </div>
          </div>

          <form action="/api/admin/resources" method="POST" class="editor-card__body">
            <label class="form-field">
              <span>Topic</span>
              <select class="form-input form-select" name="topic_id" required>
                <option value="" disabled selected={!selectedTopicId}>Select topic</option>
                {subjectRows.map((subject) => (
                  <optgroup label={subject.name}>
                    {subject.topics.map((topic) => (
                      <option value={topic.id} selected={selectedTopicId === topic.id}>
                        {topic.name}
                      </option>
                    ))}
                  </optgroup>
                ))}
              </select>
            </label>

            <label class="form-field">
              <span>Video Title</span>
              <input class="form-input" type="text" name="title" placeholder="e.g. Newton's Laws - Complete" required />
            </label>

            <label class="form-field">
              <span>YouTube URL</span>
              <input
                class="form-input"
                type="url"
                name="youtube_url"
                placeholder="https://youtube.com/watch?v=..."
                required
              />
              <small>Paste the full YouTube URL or short link</small>
            </label>

            <label class="form-field">
              <span>Notes (optional)</span>
              <textarea
                class="form-input form-textarea"
                name="notes"
                placeholder="Optional: add context or timestamps"
              ></textarea>
            </label>

            <label class="form-field">
              <span>Display Order</span>
              <input class="form-input form-input--compact" type="number" name="order" min="1" required />
            </label>

            <button type="submit" class="submit-button submit-button--green">+ Add Video</button>
          </form>
        </article>
      </div>
    </aside>

    <div class="workspace__data">
      <article class="data-card">
        <div class="data-card__header">
          <h2>Subjects</h2>
          <span class="count-badge">{subjectRows.length} subjects</span>
        </div>

        {subjectRows.length ? (
          <div>
            {subjectRows.map((subject) => (
              <div class="subject-row">
                <div class="subject-row__info">
                  <span class="subject-row__dot" style={`--subject-dot:${subject.theme.dot};`}></span>
                  <div>
                    <div class="subject-row__name">{subject.name}</div>
                    <div class="subject-row__meta">{subject.topicCount} topics</div>
                  </div>
                </div>

                <div class="subject-row__side">
                  <span class="order-badge">#{subject.order}</span>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="empty-panel">
            <p>No subjects yet — add one using the form on the left.</p>
          </div>
        )}
      </article>

      <section class="topics-groups">
        {subjectRows.map((subject) => (
          <article class="topic-group-card">
            <div class="topic-group-card__header" style={`--subject-color:${subject.theme.dot};`}>
              <span class="topic-group-card__accent"></span>
              <div class="topic-group-card__title">
                <span class="subject-row__dot" style={`--subject-dot:${subject.theme.dot};`}></span>
                <span>{subject.name}</span>
              </div>
              <span class="count-badge">{subject.topicCount} topics</span>
            </div>

            {subject.topics.length ? (
              <div>
                {subject.topics.map((topic) => (
                  <div class="topic-row">
                    <span class="topic-row__order">{String(topic.order).padStart(2, '0')}</span>
                    <span class="topic-row__name">{topic.name}</span>
                    <span
                      class:list={[
                        'video-pill',
                        { 'video-pill--empty': topic.resourceCount === 0 },
                      ]}
                    >
                      {topic.resourceCount === 0 ? '▶ No videos' : `▶ ${topic.resourceCount} videos`}
                    </span>
                    <a
                      href={`/admin/subjects?subject=${subject.id}&topic=${topic.id}#video-resource-form`}
                      class="ghost-button"
                    >
                      Add Video
                    </a>
                  </div>
                ))}
              </div>
            ) : (
              <div class="empty-panel empty-panel--tight">
                <p>No topics yet — add one using the form on the left</p>
              </div>
            )}
          </article>
        ))}
      </section>
    </div>
  </section>
</AdminLayout>

<style>
