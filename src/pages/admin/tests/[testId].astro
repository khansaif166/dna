---
export const prerender = false;

import { asc, eq } from 'drizzle-orm';

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, questions, subjects, tests, topics } from '../../../db';
import { requireAuth } from '../../../lib/auth';
import { getUuidParam } from '../../../lib/routeParams';
import { withRetry } from '../../../lib/withRetry';
import { withTimeout } from '../../../lib/withTimeout';

console.log('[admin-test-detail] request started', Astro.url.pathname);

let admin;
let test;
let testQuestions;
let nextOrder;
let questionCount;
let testTypeLabel;
let attemptModeLabel;
let metaSubject;
let metaChapter;

try {
  const authResult = await withTimeout(requireAuth(Astro, 'admin'), 'admin test detail auth check');

  if (authResult instanceof Response) {
    console.log('[admin-test-detail] auth returned redirect response');
    return authResult;
  }

  admin = authResult;

  const testId = getUuidParam(Astro.params.testId);

  if (testId instanceof Response) {
    console.warn('[admin-test-detail] invalid test id', Astro.params.testId);
    return testId;
  }

  console.log('[admin-test-detail] loading test', testId);

  const testRows = await withRetry(
    () =>
      withTimeout(
        db
          .select({
            id: tests.id,
            title: tests.title,
            status: tests.status,
            testType: tests.testType,
            attemptMode: tests.attemptMode,
            durationMinutes: tests.durationMinutes,
            publishedAt: tests.publishedAt,
            createdAt: tests.createdAt,
            subjectName: subjects.name,
            topicName: topics.name,
          })
          .from(tests)
          .leftJoin(subjects, eq(tests.subjectId, subjects.id))
          .leftJoin(topics, eq(tests.topicId, topics.id))
          .where(eq(tests.id, testId)),
        'admin test detail test query'
      ),
    'admin test detail test query'
  );

  if (!testRows || testRows.length === 0) {
    console.warn('[admin-test-detail] test not found', testId);
    return new Response(null, { status: 404 });
  }

  [test] = testRows;

  const rawTestQuestions = await withRetry(
    () =>
      withTimeout(
        db
          .select()
          .from(questions)
          .where(eq(questions.testId, test.id))
          .orderBy(asc(questions.order)),
        'admin test detail questions query'
      ),
    'admin test detail questions query'
  );

  testQuestions = rawTestQuestions.map((question) => ({
    ...question,
    prompt: question.prompt ?? '',
    optionA: question.optionA ?? '',
    optionB: question.optionB ?? '',
    optionC: question.optionC ?? '',
    optionD: question.optionD ?? '',
    explanation: question.explanation ?? '',
    questionImageUrl: question.questionImageUrl ?? '',
  }));

  nextOrder = (testQuestions.at(-1)?.order ?? 0) + 1;
  questionCount = testQuestions.length;
  testTypeLabel = test.testType === 'mock_exam' ? 'Mock Exam' : 'Practice';
  attemptModeLabel = test.attemptMode === 'multiple' ? 'Multiple attempts' : 'Single attempt';
  metaSubject = test.subjectName ?? 'General';
  metaChapter = test.topicName ?? 'No chapter assigned';

  console.log('[admin-test-detail] loaded test page data', {
    testId: test.id,
    questionCount,
  });
} catch (error) {
  const errorDetails =
    error && typeof error === 'object'
      ? Object.fromEntries(
          Object.entries(error).map(([key, value]) => [
            key,
            value instanceof Error
              ? {
                  name: value.name,
                  message: value.message,
                  stack: value.stack ?? null,
                }
              : value,
          ])
        )
      : null;

  console.error('[admin-test-detail] failed to render', {
    path: Astro.url.pathname,
    testId: Astro.params.testId ?? null,
    name: error instanceof Error ? error.name : null,
    message: error instanceof Error ? error.message : String(error),
    stack: error instanceof Error ? error.stack ?? null : null,
    cause:
      error instanceof Error && error.cause instanceof Error
        ? {
            name: error.cause.name,
            message: error.cause.message,
            stack: error.cause.stack ?? null,
          }
        : error instanceof Error
          ? error.cause ?? null
          : null,
    details: errorDetails,
  });

  return new Response('Internal Server Error', { status: 500 });
}
---

<AdminLayout
  title={`${test.title} | Admin | Dream Neet Academy`}
  pageTitle="Questions"
  userName={admin.fullName}
  userEmail={Astro.locals.user?.email ?? admin.fullName}
  hideTopbar={true}
>
  <div class="questions-editor" data-current-test-id={test.id}>
    <section class="meta-bar">
      <div class="meta-bar__identity">
        <p class="meta-bar__breadcrumb">Tests / {test.title}</p>
        <h1 class="meta-bar__title">{test.title}</h1>
        <span class="meta-bar__subject-pill">{metaSubject} · {metaChapter}</span>
      </div>

      <div class="meta-bar__stats">
        <span class="meta-pill" data-question-count>📝 {questionCount} Questions</span>
        <span class="meta-pill">⏱ {test.durationMinutes} Min</span>
        <span class:list={['meta-pill', 'meta-pill--status', { 'meta-pill--published': test.status === 'published' }]}>
          {test.status === 'published' ? '✓ Published' : '◯ Draft'}
        </span>
        <span class="meta-pill meta-pill--type">{testTypeLabel}</span>
        <span class="meta-pill meta-pill--mode">{attemptModeLabel}</span>
      </div>

      <div class="meta-bar__actions">
        <a href="/admin/tests" class="back-link">← Back to Tests</a>

        <form action={`/api/admin/tests/${test.id}/publish`} method="POST">
          <input type="hidden" name="test_id" value={test.id} />
          <button type="submit" class:list={['publish-btn', { 'publish-btn--published': test.status === 'published' }]}>
            {test.status === 'published' ? '✓ Published · Unpublish' : 'Publish Test →'}
          </button>
        </form>

        <button type="button" class="panel-toggle-btn" id="panel-toggle" title="Toggle side panel" aria-label="Toggle side panel">
          ☰
        </button>

        <button type="button" class="delete-test-link" data-delete-test-button>Delete Test</button>
      </div>
    </section>

    <div class="mobile-editor-tabs" data-mobile-editor-tabs>
      <button type="button" class="mobile-editor-tab is-active" data-mobile-editor-tab="questions">
        Questions ({questionCount})
      </button>
      <button type="button" class="mobile-editor-tab" data-mobile-editor-tab="add-question">
        Add Question
      </button>
      <button type="button" class="mobile-editor-tab" data-mobile-editor-tab="import-pdf">
        Import PDF
      </button>
    </div>

    <section class="editor-shell">
      <div class="questions-zone" data-mobile-editor-panel="questions">
        <div class="search-filter-bar">
          <span class="search-filter-bar__icon" aria-hidden="true">🔍</span>
          <input
            type="search"
            class="search-filter-bar__input"
            placeholder="Search questions..."
            data-question-search
          />
          <span class="search-filter-bar__separator"></span>
          <div class="filter-pills" data-filter-pills>
            <button type="button" class="filter-pill is-active" data-filter-option="all">All</button>
            <button type="button" class="filter-pill" data-filter-option="a">Correct A</button>
            <button type="button" class="filter-pill" data-filter-option="b">Correct B</button>
            <button type="button" class="filter-pill" data-filter-option="c">Correct C</button>
            <button type="button" class="filter-pill" data-filter-option="d">Correct D</button>
          </div>
        </div>

        {questionCount ? (
          <div class="question-list" data-question-list>
            {testQuestions.map((question) => {
              const options = [
                { key: 'a', label: 'A', text: question.optionA },
                { key: 'b', label: 'B', text: question.optionB },
                { key: 'c', label: 'C', text: question.optionC },
                { key: 'd', label: 'D', text: question.optionD },
              ] as const;

              return (
                <article
                  class="question-card"
                  data-question-card
                  data-correct-option={question.correctOption ?? ''}
                  data-question-id={question.id}
                  data-question-order={question.order}
                  data-question-prompt={question.prompt}
                  data-question-option-a={question.optionA}
                  data-question-option-b={question.optionB}
                  data-question-option-c={question.optionC}
                  data-question-option-d={question.optionD}
                  data-question-correct-option={question.correctOption ?? ''}
                  data-question-image-url={question.questionImageUrl ?? ''}
                  data-question-explanation={question.explanation ?? ''}
                >
                  <div class="question-accent" aria-hidden="true"></div>

                  <div class="view-mode">
                    <div class="question-card__header">
                      <span class="question-badge">Q{question.order}</span>

                      <div class="question-card__prompt-wrap">
                        <p class="question-prompt" data-prompt-text>{question.prompt}</p>
                        <button
                          type="button"
                          class="expand-prompt-btn"
                          data-expand-prompt
                          hidden={question.prompt.length < 160}
                        >
                          Expand
                        </button>
                      </div>

                      <div class="question-card__actions">
                        <button type="button" class="icon-btn edit-question-btn" data-edit-question aria-label={`Edit question ${question.order}`}>
                          ✎
                        </button>
                        <button type="button" class="icon-btn icon-btn--danger" data-delete-question aria-label={`Delete question ${question.order}`}>
                          ✕
                        </button>
                      </div>
                    </div>

                    {question.questionImageUrl && (
                      <div class="question-card__media">
                        <img src={question.questionImageUrl} alt={`Question ${question.order} illustration`} loading="lazy" />
                      </div>
                    )}

                    <div class="question-options">
                      {options.map((option) => (
                        <div class:list={['option-chip', `option-chip--${option.key}`, { 'option-chip--correct': question.correctOption === option.key }]}>
                          <span class:list={['option-bubble', { 'option-bubble--correct': question.correctOption === option.key }]}>{option.label}</span>
                          <span class="option-text">{option.text}</span>
                          {question.correctOption === option.key && <span class="option-status">Correct</span>}
                        </div>
                      ))}
                    </div>

                    {!question.correctOption && <p class="pending-answer-chip">Answer key pending</p>}

                    {question.explanation && (
                      <div class="question-explanation">
                        <strong>Explanation</strong>
                        <p>{question.explanation}</p>
                      </div>
                    )}
                  </div>

                  <form class="edit-mode" data-inline-editor hidden>
                    <div class="edit-mode__head">
                      <span class="editing-pill">Editing Q{question.order}</span>
                      <button type="button" class="cancel-edit-text cancel-edit-btn" data-inline-cancel>Cancel</button>
                    </div>

                    <p class="form-status" data-inline-status hidden></p>

                    <label class="field">
                      <span>Question Prompt</span>
                      <textarea class="input-field textarea-field" name="prompt" required>{question.prompt}</textarea>
                    </label>

                    <label class="field">
                      <span>Question Image</span>
                      <input type="hidden" name="question_image_url" value={question.questionImageUrl ?? ''} />
                    </label>

                    <div class="image-upload-panel" data-image-upload-panel>
                      <label class="field">
                        <span>Upload Question Image</span>
                        <input class="input-field" type="file" name="question_image_file" accept="image/png,image/jpeg,image/webp,image/gif" />
                      </label>
                      <input type="hidden" value={test.id} data-question-image-test-id />
                      <p class="upload-status" data-upload-status hidden></p>
                    </div>

                    <div class="image-preview" data-image-preview hidden>
                      <img src={question.questionImageUrl ?? ''} alt="Question preview" data-image-preview-img />
                    </div>

                    <div class="options-grid">
                      {options.map((option) => (
                        <label class="field option-field">
                          <span>{option.label}</span>
                          <input
                            class="input-field"
                            type="text"
                            name={`option_${option.key}`}
                            required
                            value={option.text}
                          />
                        </label>
                      ))}
                    </div>

                    <div class="field">
                      <span>Correct Answer</span>
                      <div class="answer-group answer-group--editor">
                        <input type="hidden" name="correct_option" value={question.correctOption ?? ''} />
                        {options.map((option) => (
                          <button
                            type="button"
                            class:list={['answer-pill', 'answer-pill--editor', `answer-pill--${option.key}`, { selected: question.correctOption === option.key }]}
                            data-option={option.key}
                          >
                            {option.label}
                          </button>
                        ))}
                      </div>
                    </div>

                    <label class="field">
                      <span>Explanation (optional)</span>
                      <textarea class="input-field explanation-field" name="explanation">{question.explanation ?? ''}</textarea>
                    </label>

                    <label class="field order-field">
                      <span>Question Order</span>
                      <input class="input-field" type="number" name="order" required value={question.order} />
                    </label>

                    <div class="edit-mode__actions">
                      <button type="button" class="text-btn cancel-edit-btn" data-inline-cancel>Cancel</button>
                      <button type="submit" class="submit-btn" data-inline-save>Save Changes</button>
                    </div>
                  </form>
                </article>
              );
            })}
          </div>
        ) : (
          <div class="empty-state" data-empty-state>
            <div class="empty-state__icon">📝</div>
            <h2>No questions yet</h2>
            <p>Add your first question using the panel on the right</p>
            <div class="empty-state__arrow">→</div>
          </div>
        )}

        <div class="empty-state empty-state--filtered" data-filter-empty hidden>
          <div class="empty-state__icon">📝</div>
          <h2>No matching questions</h2>
          <p>Try a different search term or answer filter.</p>
        </div>
      </div>

      <aside class="right-panel" id="right-panel">
        <div class="panel-card add-question-card" data-mobile-editor-panel="add-question">
          <div class="panel-card__header panel-card__header--blue">
            <span class="panel-card__accent panel-card__accent--dark"></span>
            <div>
              <p class="panel-card__eyebrow">Create New</p>
              <h2>Add Question</h2>
            </div>
          </div>

          <form action="/api/admin/questions" method="POST" class="question-form" data-question-form>
            <input type="hidden" name="test_id" value={test.id} />
            <div class="form-flash" data-question-form-flash hidden></div>
            <p class="form-status" data-question-form-status hidden></p>

            <section class="form-section form-section--prompt">
              <div class="section-label-row">
                <span class="section-label">Question Prompt</span>
                <span class="section-counter" id="char-count">0 chars</span>
              </div>
              <textarea
                class="input-field textarea-field prompt-textarea"
                id="question-prompt"
                name="prompt"
                required
              ></textarea>
            </section>

            <div class="form-divider"></div>

            <section class="form-section">
              <div class="section-label-row section-label-row--single">
                <span class="section-label">Question Image <span class="section-optional">(optional)</span></span>
              </div>
              <input type="hidden" name="question_image_url" value="" />
              <div class="image-upload-panel image-upload-panel--create" data-image-upload-panel>
                <label class="upload-zone" id="upload-zone">
                  <span class="upload-zone__default" id="upload-default">
                    <span class="upload-zone__emoji">🖼</span>
                    <span class="upload-zone__title">Click to upload image</span>
                    <span class="upload-zone__hint">PNG, JPG up to 5MB</span>
                  </span>
                  <span class="upload-zone__selected" id="upload-selected" hidden>
                    <span class="upload-zone__filename" id="upload-filename">✓ image.png</span>
                    <button type="button" class="upload-zone__remove" id="remove-file" aria-label="Remove selected file">×</button>
                  </span>
                  <input
                    type="file"
                    id="question-image-input"
                    name="question_image_file"
                    accept="image/png,image/jpeg,image/webp,image/gif"
                    class="upload-zone__input"
                  />
                </label>
                <input type="hidden" value={test.id} data-question-image-test-id />
                <p class="upload-status" data-upload-status hidden></p>
              </div>

              <div class="image-preview image-preview--create" data-image-preview hidden>
                <img src="" alt="Question preview" data-image-preview-img />
              </div>
            </section>

            <div class="form-divider"></div>

            <section class="form-section">
              <div class="section-label-row section-label-row--single">
                <span class="section-label">Answer Options</span>
              </div>
              <div class="options-stack">
                <label class="option-row option-row--a">
                  <span class="option-row__badge">A</span>
                  <input class="input-field option-row__input" id="option-a" type="text" name="option_a" placeholder="Option A" required />
                </label>
                <label class="option-row option-row--b">
                  <span class="option-row__badge">B</span>
                  <input class="input-field option-row__input" id="option-b" type="text" name="option_b" placeholder="Option B" required />
                </label>
                <label class="option-row option-row--c">
                  <span class="option-row__badge">C</span>
                  <input class="input-field option-row__input" id="option-c" type="text" name="option_c" placeholder="Option C" required />
                </label>
                <label class="option-row option-row--d">
                  <span class="option-row__badge">D</span>
                  <input class="input-field option-row__input" id="option-d" type="text" name="option_d" placeholder="Option D" required />
                </label>
              </div>
            </section>

            <div class="form-divider"></div>

            <section class="form-section">
              <div class="section-label-row section-label-row--single">
                <span class="section-label">Correct Answer</span>
              </div>
              <div class="answer-group answer-group--create">
                <input type="hidden" name="correct_option" id="correct-option-input" value="" />
                <button type="button" class="answer-pill answer-pill--create answer-pill--a" data-option="a">
                  <span class="answer-pill__letter">A</span>
                  <span class="answer-pill__preview" id="pill-preview-a"></span>
                </button>
                <button type="button" class="answer-pill answer-pill--create answer-pill--b" data-option="b">
                  <span class="answer-pill__letter">B</span>
                  <span class="answer-pill__preview" id="pill-preview-b"></span>
                </button>
                <button type="button" class="answer-pill answer-pill--create answer-pill--c" data-option="c">
                  <span class="answer-pill__letter">C</span>
                  <span class="answer-pill__preview" id="pill-preview-c"></span>
                </button>
                <button type="button" class="answer-pill answer-pill--create answer-pill--d" data-option="d">
                  <span class="answer-pill__letter">D</span>
                  <span class="answer-pill__preview" id="pill-preview-d"></span>
                </button>
              </div>
            </section>

            <div class="form-divider"></div>

            <section class="form-section">
              <div class="section-label-row section-label-row--single">
                <span class="section-label">Explanation <span class="section-optional">(optional)</span></span>
              </div>
              <textarea
                class="input-field explanation-field explanation-field--create"
                name="explanation"
                placeholder="Why is this the correct answer? (shown after submission)"
              ></textarea>
            </section>

            <div class="form-divider"></div>

            <section class="order-row">
              <span class="section-label">Order</span>
              <input class="input-field order-row__input" type="number" name="order" required value={nextOrder} />
              <span class="order-row__hint">Lower = appears first</span>
            </section>

            <div class="form-submit-wrap">
              <button type="submit" class="submit-btn submit-btn--create" data-question-form-submit>+ Add Question</button>
              <p class="form-inline-error" data-form-inline-error hidden>
                Please fill in the question, all options, and select the correct answer
              </p>
            </div>
          </form>
        </div>

        <div class="panel-card import-panel-card" data-mobile-editor-panel="import-pdf">
          <div class="panel-card__header panel-card__header--amber">
            <span class="panel-card__accent panel-card__accent--amber"></span>
            <div>
              <p class="panel-card__eyebrow panel-card__eyebrow--amber">Bulk Import</p>
              <h2>Upload PDF</h2>
            </div>
          </div>

          <form
            action="/api/admin/questions/import-pdf"
            method="POST"
            enctype="multipart/form-data"
            class="question-form"
            data-pdf-import-form
          >
            <input type="hidden" name="test_id" value={test.id} />

            <label class="pdf-dropzone" data-pdf-dropzone>
              <input class="pdf-dropzone__input" type="file" name="pdf" accept="application/pdf,.pdf" required />
              <span class="pdf-dropzone__icon">📄</span>
              <span class="pdf-dropzone__text" data-pdf-dropzone-label>Drop PDF here or click to browse</span>
            </label>

            <div class="format-box">
              <p class="format-box__label">Expected Format</p>
              <pre>1. Question text
A. Option one
B. Option two
C. Option three
D. Option four
Answer: B
Explanation: optional</pre>
            </div>

            <p class="import-status" data-pdf-import-status hidden></p>
            <a class="secondary-btn report-link" data-pdf-report-link hidden download>⬇ Download Skipped Report</a>
            <button type="submit" class="submit-btn" data-pdf-import-button>Import Questions →</button>
          </form>
        </div>
      </aside>
    </section>
  </div>

  <div class="delete-modal" data-delete-modal hidden>
    <div class="delete-modal__backdrop" data-delete-modal-close></div>
    <div
      class="delete-modal__dialog"
      role="dialog"
      aria-modal="true"
      aria-labelledby="delete-modal-title"
      aria-describedby="delete-modal-description"
    >
      <div class="delete-modal__icon">!</div>
      <p class="panel-card__eyebrow">Delete Question</p>
      <h2 id="delete-modal-title">Are you sure?</h2>
      <p class="delete-modal__text" id="delete-modal-description">
        This will permanently delete <strong data-delete-modal-question-label>this question</strong>.
      </p>
      <p class="delete-modal__subtext">
        Any saved student answers linked to this question will also be removed. This action cannot be undone.
      </p>
      <div class="delete-modal__actions">
        <button type="button" class="secondary-btn" data-delete-modal-cancel>Cancel</button>
        <button type="button" class="submit-btn delete-modal__confirm" data-delete-modal-confirm>Delete Question</button>
      </div>
    </div>
  </div>

  <div class="delete-modal" data-delete-test-modal hidden>
    <div class="delete-modal__backdrop" data-delete-test-modal-close></div>
    <div
      class="delete-modal__dialog delete-modal__dialog--danger"
      role="dialog"
      aria-modal="true"
      aria-labelledby="delete-test-modal-title"
      aria-describedby="delete-test-modal-description"
    >
      <div class="delete-modal__icon delete-modal__icon--danger">!</div>
      <p class="panel-card__eyebrow">Delete Test</p>
      <h2 id="delete-test-modal-title">Delete this entire test?</h2>
      <p class="delete-modal__text" id="delete-test-modal-description">
        You are about to permanently delete <strong>{test.title}</strong>.
      </p>
      <p class="delete-modal__subtext">
        This will remove all questions in this test, every imported answer key, and all student attempt history linked to it. This action cannot be undone.
      </p>
      <div class="delete-modal__actions">
        <button type="button" class="secondary-btn" data-delete-test-modal-cancel>Keep Test</button>
        <button type="button" class="submit-btn delete-modal__confirm" data-delete-test-modal-confirm>Delete Test</button>
      </div>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  const editorGrid = document.querySelector('[data-current-test-id]');
  const currentTestId = editorGrid instanceof HTMLElement ? editorGrid.dataset.currentTestId ?? '' : '';
  const questionForm = document.querySelector('[data-question-form]');
  const pdfImportForm = document.querySelector('[data-pdf-import-form]');
  const deleteTestButton = document.querySelector('[data-delete-test-button]');
  const deleteModal = document.querySelector('[data-delete-modal]');
  const deleteTestModal = document.querySelector('[data-delete-test-modal]');
  const deleteModalQuestionLabel = document.querySelector('[data-delete-modal-question-label]');
  const deleteModalCancel = document.querySelector('[data-delete-modal-cancel]');
  const deleteModalConfirm = document.querySelector('[data-delete-modal-confirm]');
  const deleteModalCloseTargets = Array.from(document.querySelectorAll('[data-delete-modal-close]'));
  const deleteTestModalCancel = document.querySelector('[data-delete-test-modal-cancel]');
  const deleteTestModalConfirm = document.querySelector('[data-delete-test-modal-confirm]');
  const deleteTestModalCloseTargets = Array.from(document.querySelectorAll('[data-delete-test-modal-close]'));
  const questionCountChip = document.querySelector('[data-question-count]');
  const questionsZone = document.querySelector('.questions-zone');
  const searchInput = document.querySelector('[data-question-search]');
  const filterPills = Array.from(document.querySelectorAll('.filter-pill'));
  const filterEmptyState = document.querySelector('[data-filter-empty]');
  const panelToggle = document.getElementById('panel-toggle');
  const rightPanel = document.getElementById('right-panel');
  const mobileEditorTabs = Array.from(document.querySelectorAll('[data-mobile-editor-tab]'));
  const mobileEditorPanels = Array.from(document.querySelectorAll('[data-mobile-editor-panel]'));
  const PANEL_KEY = 'questions_panel_open';
  const RIGHT_PANEL_WIDTH = '360px';
  let questionList = document.querySelector('[data-question-list]');
  let pendingDelete = null;
  let deleteTestPending = false;
  let activeInlineCard = null;
  let activeFilter = 'all';
  let activeMobilePanel = 'questions';

  const syncMobileEditorPanels = () => {
    mobileEditorTabs.forEach((tab) => {
      if (!(tab instanceof HTMLButtonElement)) {
        return;
      }

      const isActive = tab.dataset.mobileEditorTab === activeMobilePanel;
      tab.classList.toggle('is-active', isActive);
    });

    mobileEditorPanels.forEach((panel) => {
      if (!(panel instanceof HTMLElement)) {
        return;
      }

      panel.hidden = window.innerWidth <= 768 && panel.dataset.mobileEditorPanel !== activeMobilePanel;
    });
  };

  const escapeHtml = (value) =>
    String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

  const closeDeleteModal = () => {
    if (deleteModal instanceof HTMLElement) {
      deleteModal.hidden = true;
    }

    pendingDelete = null;

    if (deleteModalConfirm instanceof HTMLButtonElement) {
      deleteModalConfirm.disabled = false;
      deleteModalConfirm.textContent = 'Delete Question';
    }
  };

  const closeDeleteTestModal = () => {
    if (deleteTestPending) {
      return;
    }

    if (deleteTestModal instanceof HTMLElement) {
      deleteTestModal.hidden = true;
    }

    if (deleteTestModalConfirm instanceof HTMLButtonElement) {
      deleteTestModalConfirm.disabled = false;
      deleteTestModalConfirm.textContent = 'Delete Test';
    }

    if (deleteTestButton instanceof HTMLButtonElement) {
      deleteTestButton.disabled = false;
      deleteTestButton.textContent = 'Delete Test';
    }
  };

  mobileEditorTabs.forEach((tab) => {
    if (!(tab instanceof HTMLButtonElement)) {
      return;
    }

    tab.addEventListener('click', () => {
      activeMobilePanel = tab.dataset.mobileEditorTab ?? 'questions';
      syncMobileEditorPanels();
    });
  });

  window.addEventListener('resize', syncMobileEditorPanels);
  syncMobileEditorPanels();

  const attachQuestionImageUpload = (form) => {
    if (!(form instanceof HTMLFormElement)) {
      return { uploadSelectedImage: async () => {}, reset: () => {} };
    }

    const imageUrlInput = form.elements.namedItem('question_image_url');
    const imageFileInput = form.elements.namedItem('question_image_file');
    const testIdInput = form.querySelector('[data-question-image-test-id]');
    const uploadStatus = form.querySelector('[data-upload-status]');
    const imagePreview = form.querySelector('[data-image-preview]');
    const imagePreviewImg = form.querySelector('[data-image-preview-img]');
    let localPreviewUrl = null;

    const syncPreview = () => {
      if (!(imageUrlInput instanceof HTMLInputElement) || !(imagePreview instanceof HTMLElement) || !(imagePreviewImg instanceof HTMLImageElement)) {
        return;
      }

      const value = imageUrlInput.value.trim();
      imagePreview.hidden = !value;
      imagePreviewImg.src = value;
    };

    const syncLocalPreview = () => {
      if (!(imageFileInput instanceof HTMLInputElement) || !(imagePreview instanceof HTMLElement) || !(imagePreviewImg instanceof HTMLImageElement)) {
        return;
      }

      const file = imageFileInput.files?.[0];

      if (localPreviewUrl) {
        URL.revokeObjectURL(localPreviewUrl);
        localPreviewUrl = null;
      }

      if (!file) {
        syncPreview();
        return;
      }

      localPreviewUrl = URL.createObjectURL(file);
      imagePreview.hidden = false;
      imagePreviewImg.src = localPreviewUrl;
    };

    const setUploadStatus = (message, type = 'pending') => {
      if (!(uploadStatus instanceof HTMLElement)) {
        return;
      }

      uploadStatus.hidden = false;
      uploadStatus.textContent = message;
      uploadStatus.className = `upload-status upload-status--${type}`;
    };

    const clearUploadStatus = () => {
      if (!(uploadStatus instanceof HTMLElement)) {
        return;
      }

      uploadStatus.hidden = true;
      uploadStatus.textContent = '';
      uploadStatus.className = 'upload-status';
    };

    if (imageUrlInput instanceof HTMLInputElement) {
      syncPreview();
    }

    if (imageFileInput instanceof HTMLInputElement) {
      imageFileInput.addEventListener('change', syncLocalPreview);
    }

    const uploadSelectedImage = async () => {
      if (!(imageFileInput instanceof HTMLInputElement)) {
        return;
      }

      const file = imageFileInput.files?.[0];

      if (!file) {
        return;
      }

      const testId = testIdInput instanceof HTMLInputElement ? testIdInput.value : '';

      if (!testId) {
        setUploadStatus('Missing test information for upload.', 'error');
        throw new Error('Missing test information for upload.');
      }

      setUploadStatus('Uploading image...', 'pending');

      try {
        const body = new FormData();
        body.set('test_id', testId);
        body.set('image', file);

        const response = await fetch('/api/admin/question-images', {
          method: 'POST',
          body,
        });

        const payload = await response.json().catch(() => ({ message: 'Unexpected response from the server.' }));

        if (!response.ok) {
          throw new Error(payload.message || 'Failed to upload image.');
        }

        if (imageUrlInput instanceof HTMLInputElement) {
          imageUrlInput.value = payload.imageUrl || '';
          syncPreview();
        }

        imageFileInput.value = '';

        if (localPreviewUrl) {
          URL.revokeObjectURL(localPreviewUrl);
          localPreviewUrl = null;
        }

        setUploadStatus(payload.message || 'Image uploaded successfully.', 'success');
      } catch (error) {
        setUploadStatus(error instanceof Error ? error.message : 'Failed to upload image.', 'error');
        throw error;
      }
    };

    const reset = () => {
      if (localPreviewUrl) {
        URL.revokeObjectURL(localPreviewUrl);
        localPreviewUrl = null;
      }

      clearUploadStatus();
      syncPreview();
    };

    return { uploadSelectedImage, reset };
  };

  const createOptionMarkup = (option, correctOption) => `
    <div class="option-chip option-chip--${option.key} ${correctOption === option.key ? 'option-chip--correct' : ''}">
      <span class="option-bubble ${correctOption === option.key ? 'option-bubble--correct' : ''}">${option.label}</span>
      <span class="option-text">${escapeHtml(option.text)}</span>
      ${correctOption === option.key ? '<span class="option-status">Correct</span>' : ''}
    </div>
  `;

  const createAnswerPillMarkup = (option, correctOption, editor = false) => `
    <button
      type="button"
      class="answer-pill ${editor ? 'answer-pill--editor' : ''} answer-pill--${option} ${correctOption === option ? 'selected' : ''}"
      data-option="${option}"
    >
      ${option.toUpperCase()}
    </button>
  `;

  const createQuestionCardElement = (question) => {
    const article = document.createElement('article');
    article.className = 'question-card';
    article.dataset.questionCard = '';
    article.dataset.correctOption = question.correctOption ?? '';
    article.dataset.questionId = question.id;
    article.dataset.questionOrder = String(question.order);
    article.dataset.questionPrompt = question.prompt;
    article.dataset.questionOptionA = question.optionA;
    article.dataset.questionOptionB = question.optionB;
    article.dataset.questionOptionC = question.optionC;
    article.dataset.questionOptionD = question.optionD;
    article.dataset.questionCorrectOption = question.correctOption ?? '';
    article.dataset.questionImageUrl = question.questionImageUrl ?? '';
    article.dataset.questionExplanation = question.explanation ?? '';

    const options = [
      { key: 'a', label: 'A', text: question.optionA },
      { key: 'b', label: 'B', text: question.optionB },
      { key: 'c', label: 'C', text: question.optionC },
      { key: 'd', label: 'D', text: question.optionD },
    ];

    article.innerHTML = `
      <div class="question-accent" aria-hidden="true"></div>
      <div class="view-mode">
        <div class="question-card__header">
          <span class="question-badge">Q${escapeHtml(question.order)}</span>
          <div class="question-card__prompt-wrap">
            <p class="question-prompt" data-prompt-text>${escapeHtml(question.prompt)}</p>
            <button type="button" class="expand-prompt-btn" data-expand-prompt ${String(question.prompt).length < 160 ? 'hidden' : ''}>Expand</button>
          </div>
          <div class="question-card__actions">
            <button type="button" class="icon-btn edit-question-btn" data-edit-question aria-label="Edit question">✎</button>
            <button type="button" class="icon-btn icon-btn--danger" data-delete-question aria-label="Delete question">✕</button>
          </div>
        </div>
        ${
          question.questionImageUrl
            ? `<div class="question-card__media"><img src="${escapeHtml(question.questionImageUrl)}" alt="Question ${escapeHtml(question.order)} illustration" loading="lazy" /></div>`
            : ''
        }
        <div class="question-options">
          ${options.map((option) => createOptionMarkup(option, question.correctOption)).join('')}
        </div>
        ${question.correctOption ? '' : '<p class="pending-answer-chip">Answer key pending</p>'}
        ${
          question.explanation
            ? `<div class="question-explanation"><strong>Explanation</strong><p>${escapeHtml(question.explanation)}</p></div>`
            : ''
        }
      </div>
      <form class="edit-mode" data-inline-editor hidden>
        <div class="edit-mode__head">
          <span class="editing-pill">Editing Q${escapeHtml(question.order)}</span>
          <button type="button" class="cancel-edit-text cancel-edit-btn" data-inline-cancel>Cancel</button>
        </div>
        <p class="form-status" data-inline-status hidden></p>
        <label class="field">
          <span>Question Prompt</span>
          <textarea class="input-field textarea-field" name="prompt" required>${escapeHtml(question.prompt)}</textarea>
        </label>
        <label class="field">
          <span>Question Image</span>
          <input type="hidden" name="question_image_url" value="${escapeHtml(question.questionImageUrl ?? '')}" />
        </label>
        <div class="image-upload-panel" data-image-upload-panel>
          <label class="field">
            <span>Upload Question Image</span>
            <input class="input-field" type="file" name="question_image_file" accept="image/png,image/jpeg,image/webp,image/gif" />
          </label>
          <input type="hidden" value="${escapeHtml(currentTestId)}" data-question-image-test-id />
          <p class="upload-status" data-upload-status hidden></p>
        </div>
        <div class="image-preview" data-image-preview ${question.questionImageUrl ? '' : 'hidden'}>
          <img src="${escapeHtml(question.questionImageUrl ?? '')}" alt="Question preview" data-image-preview-img />
        </div>
        <div class="options-grid">
          <label class="field option-field"><span>A</span><input class="input-field" type="text" name="option_a" required value="${escapeHtml(question.optionA)}" /></label>
          <label class="field option-field"><span>B</span><input class="input-field" type="text" name="option_b" required value="${escapeHtml(question.optionB)}" /></label>
          <label class="field option-field"><span>C</span><input class="input-field" type="text" name="option_c" required value="${escapeHtml(question.optionC)}" /></label>
          <label class="field option-field"><span>D</span><input class="input-field" type="text" name="option_d" required value="${escapeHtml(question.optionD)}" /></label>
        </div>
        <div class="field">
          <span>Correct Answer</span>
          <div class="answer-group answer-group--editor">
            <input type="hidden" name="correct_option" value="${escapeHtml(question.correctOption ?? '')}" />
            ${['a', 'b', 'c', 'd'].map((option) => createAnswerPillMarkup(option, question.correctOption, true)).join('')}
          </div>
        </div>
        <label class="field">
          <span>Explanation (optional)</span>
          <textarea class="input-field explanation-field" name="explanation">${escapeHtml(question.explanation ?? '')}</textarea>
        </label>
        <label class="field order-field">
          <span>Question Order</span>
          <input class="input-field" type="number" name="order" required value="${escapeHtml(question.order)}" />
        </label>
        <div class="edit-mode__actions">
          <button type="button" class="text-btn cancel-edit-btn" data-inline-cancel>Cancel</button>
          <button type="submit" class="submit-btn" data-inline-save>Save Changes</button>
        </div>
      </form>
    `;

    return article;
  };

  const syncQuestionNumbers = () => {
    const cards = Array.from(document.querySelectorAll('[data-question-card]'));

    cards.forEach((node, index) => {
      if (!(node instanceof HTMLElement)) {
        return;
      }

      const nextOrder = index + 1;
      node.dataset.questionOrder = String(nextOrder);

      const badge = node.querySelector('.question-badge');
      const editingPill = node.querySelector('.editing-pill');
      const inlineOrderInput = node.querySelector('[name="order"]');

      if (badge instanceof HTMLElement) {
        badge.textContent = `Q${nextOrder}`;
      }

      if (editingPill instanceof HTMLElement) {
        editingPill.textContent = `Editing Q${nextOrder}`;
      }

      if (inlineOrderInput instanceof HTMLInputElement) {
        inlineOrderInput.value = String(nextOrder);
      }
    });

    if (questionCountChip instanceof HTMLElement) {
      questionCountChip.textContent = `📝 ${cards.length} Questions`;
    }

    if (questionForm instanceof HTMLFormElement) {
      const createOrderInput = questionForm.elements.namedItem('order');

      if (createOrderInput instanceof HTMLInputElement) {
        createOrderInput.value = String(cards.length + 1);
      }
    }

    toggleEmptyStates();
  };

  const closeInlineEditor = (card) => {
    if (!(card instanceof HTMLElement)) {
      return;
    }

    const editor = card.querySelector('[data-inline-editor]');
    const viewMode = card.querySelector('.view-mode');

    if (editor instanceof HTMLFormElement) {
      editor.hidden = true;
    }

    if (viewMode instanceof HTMLElement) {
      viewMode.style.display = '';
    }

    card.classList.remove('question-card--editing');
    activeInlineCard = activeInlineCard === card ? null : activeInlineCard;
  };

  const openInlineEditor = (card) => {
    if (!(card instanceof HTMLElement)) {
      return;
    }

    if (activeInlineCard && activeInlineCard !== card) {
      closeInlineEditor(activeInlineCard);
    }

    const editor = card.querySelector('[data-inline-editor]');
    const viewMode = card.querySelector('.view-mode');

    if (editor instanceof HTMLFormElement) {
      editor.hidden = false;
      if (viewMode instanceof HTMLElement) {
        viewMode.style.display = 'none';
      }
      card.classList.add('question-card--editing');
      activeInlineCard = card;
      editor.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  };

  const attachUniqueValidation = (form) => {
    const fields = ['option_a', 'option_b', 'option_c', 'option_d']
      .map((name) => form.elements.namedItem(name))
      .filter((field) => field instanceof HTMLInputElement);

    const validate = () => {
      fields.forEach((field) => field.setCustomValidity(''));
      const seen = new Map();

      fields.forEach((field) => {
        const value = field.value.trim().toLowerCase();

        if (!value) {
          return;
        }

        const duplicateField = seen.get(value);

        if (duplicateField) {
          const message = 'Each option must be unique.';
          field.setCustomValidity(message);
          duplicateField.setCustomValidity(message);
        } else {
          seen.set(value, field);
        }
      });
    };

    fields.forEach((field) => {
      field.addEventListener('input', validate);
      field.addEventListener('blur', validate);
    });

    return validate;
  };

  const wireAnswerGroups = (scope = document) => {
    scope.querySelectorAll('.answer-group').forEach((group) => {
      if (!(group instanceof HTMLElement) || group.dataset.answerBound === 'true') {
        return;
      }

      group.dataset.answerBound = 'true';

      group.querySelectorAll('.answer-pill').forEach((pill) => {
        pill.addEventListener('click', () => {
          group.querySelectorAll('.answer-pill').forEach((node) => node.classList.remove('selected'));
          pill.classList.add('selected');

          const input = group.querySelector('input[name="correct_option"]');
          if (input instanceof HTMLInputElement && pill instanceof HTMLElement) {
            input.value = pill.dataset.option ?? '';
          }
        });
      });
    });
  };

  const wirePromptExpander = (card) => {
    if (!(card instanceof HTMLElement)) {
      return;
    }

    const button = card.querySelector('[data-expand-prompt]');
    const prompt = card.querySelector('[data-prompt-text]');

    if (!(button instanceof HTMLButtonElement) || !(prompt instanceof HTMLElement)) {
      return;
    }

    button.addEventListener('click', () => {
      const expanded = prompt.classList.toggle('is-expanded');
      button.textContent = expanded ? 'Collapse' : 'Expand';
    });
  };

  const openDeleteModal = ({ card, onError }) => {
    if (!(deleteModal instanceof HTMLElement) || !(card instanceof HTMLElement)) {
      return;
    }

    const questionOrder = card.dataset.questionOrder;

    if (deleteModalQuestionLabel instanceof HTMLElement) {
      deleteModalQuestionLabel.textContent = questionOrder ? `Q${questionOrder}` : 'this question';
    }

    pendingDelete = { card, onError };
    deleteModal.hidden = false;
  };

  const applyQuestionFilter = () => {
    const term = searchInput instanceof HTMLInputElement ? searchInput.value.trim().toLowerCase() : '';
    const cards = Array.from(document.querySelectorAll('[data-question-card]'));
    let visibleCount = 0;

    cards.forEach((card) => {
      if (!(card instanceof HTMLElement)) {
        return;
      }

      const haystack = [
        card.dataset.questionPrompt,
        card.dataset.questionOptionA,
        card.dataset.questionOptionB,
        card.dataset.questionOptionC,
        card.dataset.questionOptionD,
        card.dataset.questionExplanation,
      ]
        .join(' ')
        .toLowerCase();

      const matchesSearch = !term || haystack.includes(term);
      const correctOption = (card.dataset.questionCorrectOption ?? '').toLowerCase();
      const matchesFilter = activeFilter === 'all' || correctOption === activeFilter;
      const shouldShow = matchesSearch && matchesFilter;

      card.style.display = shouldShow ? '' : 'none';
      if (shouldShow) {
        visibleCount += 1;
      }
    });

    if (filterEmptyState instanceof HTMLElement) {
      filterEmptyState.hidden = visibleCount > 0 || cards.length === 0;
    }
  };

  const toggleEmptyStates = () => {
    const cards = Array.from(document.querySelectorAll('[data-question-card]'));
    const emptyState = document.querySelector('[data-empty-state]');

    if (emptyState instanceof HTMLElement) {
      emptyState.hidden = cards.length > 0;
    }

    if (cards.length === 0 && filterEmptyState instanceof HTMLElement) {
      filterEmptyState.hidden = true;
    }

    applyQuestionFilter();
  };

  const initializeQuestionCard = (card) => {
    if (!(card instanceof HTMLElement)) {
      return;
    }

    const editButton = card.querySelector('[data-edit-question]');
    const deleteButton = card.querySelector('[data-delete-question]');
    const inlineEditor = card.querySelector('[data-inline-editor]');
    const inlineCancelButtons = Array.from(card.querySelectorAll('[data-inline-cancel]'));
    const inlineStatus = card.querySelector('[data-inline-status]');
    const inlineSave = card.querySelector('[data-inline-save]');

    wireAnswerGroups(card);
    wirePromptExpander(card);

    const setInlineStatus = (message, type = 'pending') => {
      if (!(inlineStatus instanceof HTMLElement)) {
        return;
      }

      inlineStatus.hidden = false;
      inlineStatus.textContent = message;
      inlineStatus.className = `form-status form-status--${type}`;
    };

    const clearInlineStatus = () => {
      if (!(inlineStatus instanceof HTMLElement)) {
        return;
      }

      inlineStatus.hidden = true;
      inlineStatus.textContent = '';
      inlineStatus.className = 'form-status';
    };

    if (editButton instanceof HTMLButtonElement) {
      editButton.addEventListener('click', () => {
        openInlineEditor(card);
        clearInlineStatus();
      });
    }

    inlineCancelButtons.forEach((button) => {
      if (button instanceof HTMLButtonElement) {
        button.addEventListener('click', () => {
          closeInlineEditor(card);
          clearInlineStatus();
        });
      }
    });

    if (deleteButton instanceof HTMLButtonElement) {
      deleteButton.addEventListener('click', () => {
        const questionId = card.dataset.questionId;

        if (!questionId) {
          return;
        }

        openDeleteModal({
          card,
          onError: (message) => {
            setInlineStatus(message, 'error');
            openInlineEditor(card);
          },
        });
      });
    }

    if (inlineEditor instanceof HTMLFormElement) {
      const validateInlineOptions = attachUniqueValidation(inlineEditor);
      const inlineImageUpload = attachQuestionImageUpload(inlineEditor);

      inlineEditor.addEventListener('submit', async (event) => {
        event.preventDefault();
        validateInlineOptions();

        if (!inlineEditor.reportValidity()) {
          return;
        }

        const questionId = card.dataset.questionId;

        if (!questionId) {
          return;
        }

        if (inlineSave instanceof HTMLButtonElement) {
          inlineSave.disabled = true;
        }

        setInlineStatus('Saving question changes...', 'pending');

        try {
          await inlineImageUpload.uploadSelectedImage();

          const response = await fetch(`/api/admin/questions/${questionId}`, {
            method: 'PATCH',
            body: new FormData(inlineEditor),
          });
          const payload = await response.json().catch(() => ({ message: 'Unexpected response from the server.' }));

          if (!response.ok) {
            throw new Error(payload.message || 'Failed to save question.');
          }

          setInlineStatus(payload.message || 'Question updated successfully.', 'success');
          window.setTimeout(() => window.location.reload(), 500);
        } catch (error) {
          setInlineStatus(error instanceof Error ? error.message : 'Failed to save question.', 'error');
        } finally {
          if (inlineSave instanceof HTMLButtonElement) {
            inlineSave.disabled = false;
          }
        }
      });
    }
  };

  if (localStorage.getItem(PANEL_KEY) === 'false' && rightPanel instanceof HTMLElement) {
    rightPanel.style.width = '0';
    rightPanel.style.padding = '0';
    rightPanel.style.overflow = 'hidden';
  }

  if (panelToggle instanceof HTMLButtonElement && rightPanel instanceof HTMLElement) {
    panelToggle.addEventListener('click', () => {
      const isHidden = rightPanel.style.width === '0px' || rightPanel.style.width === '0';

      if (isHidden) {
        rightPanel.style.width = RIGHT_PANEL_WIDTH;
        rightPanel.style.padding = '0 24px 0 0';
        rightPanel.style.overflow = 'visible';
        localStorage.setItem(PANEL_KEY, 'true');
      } else {
        rightPanel.style.width = '0';
        rightPanel.style.padding = '0';
        rightPanel.style.overflow = 'hidden';
        localStorage.setItem(PANEL_KEY, 'false');
      }
    });
  }

  deleteModalCloseTargets.forEach((node) => {
    node.addEventListener('click', closeDeleteModal);
  });

  deleteTestModalCloseTargets.forEach((node) => {
    node.addEventListener('click', closeDeleteTestModal);
  });

  if (deleteModalCancel instanceof HTMLButtonElement) {
    deleteModalCancel.addEventListener('click', closeDeleteModal);
  }

  if (deleteTestModalCancel instanceof HTMLButtonElement) {
    deleteTestModalCancel.addEventListener('click', closeDeleteTestModal);
  }

  if (deleteModalConfirm instanceof HTMLButtonElement) {
    deleteModalConfirm.addEventListener('click', async () => {
      if (!pendingDelete?.card) {
        closeDeleteModal();
        return;
      }

      const { card, onError } = pendingDelete;
      const questionId = card.dataset.questionId;

      if (!questionId) {
        closeDeleteModal();
        return;
      }

      deleteModalConfirm.disabled = true;
      deleteModalConfirm.textContent = 'Deleting...';

      try {
        const response = await fetch(`/api/admin/questions/${questionId}`, {
          method: 'DELETE',
        });
        const payload = await response.json().catch(() => ({ message: 'Unexpected response from the server.' }));

        if (!response.ok) {
          throw new Error(payload.message || 'Failed to delete question.');
        }

        card.remove();
        closeDeleteModal();
        syncQuestionNumbers();
      } catch (error) {
        closeDeleteModal();

        if (typeof onError === 'function') {
          onError(error instanceof Error ? error.message : 'Failed to delete question.');
        }
      }
    });
  }

  if (deleteTestModalConfirm instanceof HTMLButtonElement) {
    deleteTestModalConfirm.addEventListener('click', async () => {
      if (!currentTestId) {
        closeDeleteTestModal();
        return;
      }

      deleteTestPending = true;
      deleteTestModalConfirm.disabled = true;
      deleteTestModalConfirm.textContent = 'Deleting...';

      if (deleteTestButton instanceof HTMLButtonElement) {
        deleteTestButton.disabled = true;
        deleteTestButton.textContent = 'Deleting...';
      }

      try {
        const response = await fetch(`/api/admin/tests/${currentTestId}`, {
          method: 'DELETE',
        });
        const payload = await response.json().catch(() => ({ message: 'Unexpected response from the server.' }));

        if (!response.ok) {
          throw new Error(payload.message || 'Failed to delete test.');
        }

        window.location.href = '/admin/tests';
      } catch (error) {
        deleteTestPending = false;
        window.alert(error instanceof Error ? error.message : 'Failed to delete test.');
        closeDeleteTestModal();
      }
    });
  }

  if (questionForm instanceof HTMLFormElement) {
    const formStatus = questionForm.querySelector('[data-question-form-status]');
    const formFlash = questionForm.querySelector('[data-question-form-flash]');
    const inlineError = questionForm.querySelector('[data-form-inline-error]');
    const submitButton = questionForm.querySelector('[data-question-form-submit]');
    const orderField = questionForm.elements.namedItem('order');
    const questionImageUpload = attachQuestionImageUpload(questionForm);
    const promptTA = document.getElementById('question-prompt');
    const charCount = document.getElementById('char-count');
    const fileInput = document.getElementById('question-image-input');
    const uploadZone = document.getElementById('upload-zone');
    const uploadDefault = document.getElementById('upload-default');
    const uploadSelected = document.getElementById('upload-selected');
    const uploadFilename = document.getElementById('upload-filename');
    const removeFile = document.getElementById('remove-file');
    const correctInput = document.getElementById('correct-option-input');

    const optionFields = ['option_a', 'option_b', 'option_c', 'option_d']
      .map((name) => questionForm.elements.namedItem(name))
      .filter((field) => field instanceof HTMLInputElement);

    const optionInputMap = {
      a: document.getElementById('option-a'),
      b: document.getElementById('option-b'),
      c: document.getElementById('option-c'),
      d: document.getElementById('option-d'),
    };

    let flashTimeout = null;

    const setFormStatus = (message, type = 'pending') => {
      if (!(formStatus instanceof HTMLElement)) {
        return;
      }

      formStatus.hidden = false;
      formStatus.textContent = message;
      formStatus.className = `form-status form-status--${type}`;
    };

    const clearFormStatus = () => {
      if (!(formStatus instanceof HTMLElement)) {
        return;
      }

      formStatus.hidden = true;
      formStatus.textContent = '';
      formStatus.className = 'form-status';
    };

    const showFormFlash = (message) => {
      if (!(formFlash instanceof HTMLElement)) {
        return;
      }

      if (flashTimeout) {
        window.clearTimeout(flashTimeout);
      }

      formFlash.hidden = false;
      formFlash.textContent = `✓ ${message}`;
      flashTimeout = window.setTimeout(() => {
        formFlash.hidden = true;
        formFlash.textContent = '';
      }, 3000);
    };

    const setInlineError = (visible) => {
      if (!(inlineError instanceof HTMLElement)) {
        return;
      }

      inlineError.hidden = !visible;
    };

    const updateCharCount = () => {
      if (promptTA instanceof HTMLTextAreaElement && charCount instanceof HTMLElement) {
        charCount.textContent = `${promptTA.value.length} chars`;
      }
    };

    const syncUploadZone = () => {
      if (
        !(fileInput instanceof HTMLInputElement) ||
        !(uploadZone instanceof HTMLElement) ||
        !(uploadDefault instanceof HTMLElement) ||
        !(uploadSelected instanceof HTMLElement) ||
        !(uploadFilename instanceof HTMLElement)
      ) {
        return;
      }

      const file = fileInput.files?.[0];

      if (file) {
        uploadDefault.style.display = 'none';
        uploadSelected.hidden = false;
        uploadSelected.style.display = 'block';
        uploadFilename.textContent = `✓ ${file.name}`;
        uploadZone.style.borderColor = '#A7F3D0';
        uploadZone.style.background = '#F0FDF4';
      } else {
        uploadDefault.style.display = 'block';
        uploadSelected.hidden = true;
        uploadSelected.style.display = 'none';
        uploadFilename.textContent = '';
        uploadZone.style.borderColor = '#E2E8F0';
        uploadZone.style.background = '#FAFBFF';
      }
    };

    const clearCreateValidationState = () => {
      questionForm.querySelectorAll('.is-invalid').forEach((node) => node.classList.remove('is-invalid'));
      setInlineError(false);
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.classList.remove('shake');
      }
    };

    const updatePillPreviews = () => {
      Object.entries(optionInputMap).forEach(([letter, input]) => {
        if (!(input instanceof HTMLInputElement)) {
          return;
        }

        const preview = document.getElementById(`pill-preview-${letter}`);
        if (!(preview instanceof HTMLElement)) {
          return;
        }

        preview.textContent = input.value.slice(0, 12) || '';
        preview.hidden = input.value.trim().length === 0;
      });
    };

    const validateUniqueOptions = () => {
      optionFields.forEach((field) => field.setCustomValidity(''));

      const seen = new Map();

      optionFields.forEach((field) => {
        const value = field.value.trim().toLowerCase();

        if (!value) {
          return;
        }

        const duplicateField = seen.get(value);

        if (duplicateField) {
          const message = 'Each option must be unique.';
          field.setCustomValidity(message);
          duplicateField.setCustomValidity(message);
        } else {
          seen.set(value, field);
        }
      });
    };

    const resetQuestionForm = () => {
      questionForm.reset();

      if (orderField instanceof HTMLInputElement) {
        orderField.value = String(document.querySelectorAll('[data-question-card]').length + 1);
      }

      questionForm.querySelectorAll('.answer-pill').forEach((pill) => pill.classList.remove('selected'));
      if (correctInput instanceof HTMLInputElement) {
        correctInput.value = '';
      }
      questionImageUpload.reset();
      clearFormStatus();
      clearCreateValidationState();
      updateCharCount();
      updatePillPreviews();
      syncUploadZone();
      validateUniqueOptions();
    };

    optionFields.forEach((field) => {
      field.addEventListener('input', validateUniqueOptions);
      field.addEventListener('input', () => {
        field.classList.remove('is-invalid');
        clearCreateValidationState();
        updatePillPreviews();
      });
      field.addEventListener('blur', validateUniqueOptions);
    });

    if (promptTA instanceof HTMLTextAreaElement) {
      promptTA.addEventListener('input', () => {
        promptTA.classList.remove('is-invalid');
        clearCreateValidationState();
        updateCharCount();
      });
      updateCharCount();
    }

    Object.values(optionInputMap).forEach((input) => {
      if (input instanceof HTMLInputElement) {
        input.addEventListener('input', updatePillPreviews);
      }
    });

    updatePillPreviews();
    syncUploadZone();

    if (fileInput instanceof HTMLInputElement) {
      fileInput.addEventListener('change', syncUploadZone);
    }

    if (removeFile instanceof HTMLButtonElement && fileInput instanceof HTMLInputElement) {
      removeFile.addEventListener('click', (event) => {
        event.preventDefault();
        event.stopPropagation();
        fileInput.value = '';
        syncUploadZone();
        questionImageUpload.reset();
      });
    }

    questionForm.querySelectorAll('.answer-group--create .answer-pill').forEach((pill) => {
      if (pill instanceof HTMLButtonElement) {
        pill.addEventListener('click', () => {
          if (correctInput instanceof HTMLInputElement) {
            correctInput.value = pill.dataset.option ?? '';
          }
          clearCreateValidationState();
        });
      }
    });

    questionForm.addEventListener('submit', async (event) => {
      validateUniqueOptions();

      if (!questionForm.reportValidity()) {
        event.preventDefault();
        clearCreateValidationState();
        if (promptTA instanceof HTMLTextAreaElement && !promptTA.value.trim()) {
          promptTA.classList.add('is-invalid');
        }
        optionFields.forEach((field) => {
          if (!field.value.trim()) {
            field.classList.add('is-invalid');
          }
        });
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.classList.remove('shake');
          void submitButton.offsetWidth;
          submitButton.classList.add('shake');
        }
        setInlineError(true);
        return;
      }

      if (!(correctInput instanceof HTMLInputElement) || !correctInput.value) {
        event.preventDefault();
        clearCreateValidationState();
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.classList.remove('shake');
          void submitButton.offsetWidth;
          submitButton.classList.add('shake');
        }
        setInlineError(true);
        return;
      }

      event.preventDefault();
      clearCreateValidationState();

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.classList.add('loading');
        submitButton.textContent = 'Adding...';
      }

      setFormStatus('Adding question...', 'pending');

      try {
        await questionImageUpload.uploadSelectedImage();

        const response = await fetch(questionForm.action, {
          method: 'POST',
          headers: {
            'x-requested-with': 'XMLHttpRequest',
          },
          body: new FormData(questionForm),
        });
        const isJson = response.headers.get('content-type')?.includes('application/json');
        const payload = isJson
          ? await response.json().catch(() => ({ message: 'Unexpected response from the server.' }))
          : { message: response.ok ? '' : await response.text() };

        if (!response.ok) {
          throw new Error(payload.message || 'Failed to save question.');
        }

        const createdQuestion = payload.question;

        if (!createdQuestion) {
          throw new Error('Question was created but the server did not return the new item.');
        }

        let targetList = questionList;

        if (!(targetList instanceof HTMLElement)) {
          const newList = document.createElement('div');
          newList.className = 'question-list';
          newList.setAttribute('data-question-list', '');
          questionsZone?.appendChild(newList);
          targetList = newList;
          questionList = newList;
        }

        const newCard = createQuestionCardElement(createdQuestion);
        targetList.appendChild(newCard);
        initializeQuestionCard(newCard);
        syncQuestionNumbers();
        resetQuestionForm();
        clearFormStatus();
        showFormFlash('Question added successfully');
        newCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } catch (error) {
        setFormStatus(error instanceof Error ? error.message : 'Failed to save question.', 'error');
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.classList.remove('loading');
          submitButton.textContent = '+ Add Question';
        }
      }
    });
  }

  Array.from(document.querySelectorAll('[data-question-card]')).forEach((card) => {
    initializeQuestionCard(card);
  });

  if (pdfImportForm instanceof HTMLFormElement) {
    const status = pdfImportForm.querySelector('[data-pdf-import-status]');
    const submitButton = pdfImportForm.querySelector('[data-pdf-import-button]');
    const reportLink = pdfImportForm.querySelector('[data-pdf-report-link]');
    const pdfDropzone = pdfImportForm.querySelector('[data-pdf-dropzone]');
    const pdfInput = pdfImportForm.querySelector('input[name="pdf"]');
    const pdfLabel = pdfImportForm.querySelector('[data-pdf-dropzone-label]');
    let reportUrl = null;

    const syncPdfLabel = () => {
      if (!(pdfLabel instanceof HTMLElement) || !(pdfInput instanceof HTMLInputElement)) {
        return;
      }

      const file = pdfInput.files?.[0];
      pdfLabel.textContent = file ? `✓ ${file.name}` : 'Drop PDF here or click to browse';

      if (pdfDropzone instanceof HTMLElement) {
        pdfDropzone.classList.toggle('has-file', Boolean(file));
      }
    };

    const revokeReportUrl = () => {
      if (reportUrl) {
        URL.revokeObjectURL(reportUrl);
        reportUrl = null;
      }
    };

    const buildSkippedReportCsv = (skipped) => {
      const rows = [
        ['question_number', 'reason', 'prompt_preview'],
        ...skipped.map((item) => [
          String(item.questionNumber ?? ''),
          String(item.reason ?? ''),
          String(item.prompt ?? ''),
        ]),
      ];

      return rows
        .map((row) => row.map((value) => `"${value.replaceAll('"', '""')}"`).join(','))
        .join('\n');
    };

    if (pdfInput instanceof HTMLInputElement) {
      pdfInput.addEventListener('change', syncPdfLabel);
    }

    pdfImportForm.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!pdfImportForm.reportValidity()) {
        return;
      }

      revokeReportUrl();

      if (reportLink instanceof HTMLAnchorElement) {
        reportLink.hidden = true;
        reportLink.removeAttribute('href');
        reportLink.removeAttribute('download');
      }

      if (status instanceof HTMLElement) {
        status.hidden = false;
        status.textContent = 'Importing questions from PDF...';
        status.className = 'import-status import-status--pending';
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
      }

      try {
        const response = await fetch(pdfImportForm.action, {
          method: 'POST',
          body: new FormData(pdfImportForm),
        });

        const payload = await response.json().catch(() => ({ message: 'Unexpected response from the server.' }));

        if (!response.ok) {
          throw new Error(payload.message || 'Failed to import the PDF.');
        }

        const skipped = Array.isArray(payload.skipped) ? payload.skipped : [];

        if (status instanceof HTMLElement) {
          status.textContent = payload.message || 'Questions imported successfully.';
          status.className = 'import-status import-status--success';
        }

        if (skipped.length && reportLink instanceof HTMLAnchorElement) {
          const csv = buildSkippedReportCsv(skipped);
          const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
          reportUrl = URL.createObjectURL(blob);
          const sourceName = payload.sourceFileName || 'question-import';

          reportLink.href = reportUrl;
          reportLink.download = `${sourceName.replace(/\.pdf$/i, '')}-skipped-questions.csv`;
          reportLink.hidden = false;
        }

        window.setTimeout(() => window.location.reload(), 800);
      } catch (error) {
        if (status instanceof HTMLElement) {
          status.textContent = error instanceof Error ? error.message : 'Failed to import the PDF.';
          status.className = 'import-status import-status--error';
        }
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
        }
      }
    });
  }

  if (deleteTestButton instanceof HTMLButtonElement) {
    deleteTestButton.addEventListener('click', () => {
      if (!(deleteTestModal instanceof HTMLElement)) {
        return;
      }

      deleteTestPending = false;
      deleteTestModal.hidden = false;
      deleteTestButton.textContent = 'Delete Test';
    });
  }

  if (searchInput instanceof HTMLInputElement) {
    searchInput.addEventListener('input', applyQuestionFilter);
  }

  filterPills.forEach((pill) => {
    if (!(pill instanceof HTMLButtonElement)) {
      return;
    }

    pill.addEventListener('click', () => {
      activeFilter = pill.dataset.filterOption ?? 'all';
      filterPills.forEach((node) => node.classList.remove('is-active'));
      pill.classList.add('is-active');
      applyQuestionFilter();
    });
  });

  wireAnswerGroups();
  toggleEmptyStates();
</script>

