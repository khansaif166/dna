---
export const prerender = false;

import { asc, eq } from 'drizzle-orm';

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, questions, subjects, tests, topics } from '../../../db';
import { requireAuth } from '../../../lib/auth';

const authResult = await requireAuth(Astro, 'admin');

if (authResult instanceof Response) {
  return authResult;
}

const admin = authResult;
const { testId } = Astro.params;

if (!testId) {
  return new Response(null, { status: 404 });
}

const testRows = await db
  .select({
    id: tests.id,
    title: tests.title,
    status: tests.status,
    testType: tests.testType,
    attemptMode: tests.attemptMode,
    durationMinutes: tests.durationMinutes,
    publishedAt: tests.publishedAt,
    createdAt: tests.createdAt,
    subjectName: subjects.name,
    topicName: topics.name,
  })
  .from(tests)
  .leftJoin(subjects, eq(tests.subjectId, subjects.id))
  .leftJoin(topics, eq(tests.topicId, topics.id))
  .where(eq(tests.id, testId));

if (!testRows || testRows.length === 0) {
  return new Response(null, { status: 404 });
}

const [test] = testRows;
const testQuestions = await db.select().from(questions).where(eq(questions.testId, test.id)).orderBy(asc(questions.order));
const nextOrder = (testQuestions.at(-1)?.order ?? 0) + 1;
---

<AdminLayout
  title={`${test.title} | Admin | Dream Neet Academy`}
  pageTitle="Questions"
  userName={admin.fullName}
  userEmail={Astro.locals.user?.email ?? admin.fullName}
>
  <form slot="actions" action={`/api/admin/tests/${test.id}/publish`} method="POST">
    <input type="hidden" name="test_id" value={test.id} />
    <button type="submit" class:list={['publish-btn', { 'publish-btn--published': test.status === 'published' }]}>
      {test.status === 'published' ? 'Published · Unpublish' : 'Publish Test'}
    </button>
  </form>

  <section class="test-meta">
    <div>
      <p class="eyebrow">Question Editor</p>
      <h2>{test.title}</h2>
      <p class="test-meta__sub">{test.subjectName ?? 'General'} · {test.topicName ?? 'No topic assigned'}</p>
    </div>

    <div class="meta-chips">
      <span class="meta-chip">{testQuestions.length} questions</span>
      <span class="meta-chip">{test.durationMinutes} min</span>
      <span class="meta-chip meta-chip--status">{test.status}</span>
      <span class="meta-chip">{test.testType.replace('_', ' ')}</span>
      <span class="meta-chip">{test.attemptMode.replace('_', ' ')}</span>
    </div>
  </section>

  <section class="editor-grid">
    <div class="questions-pane">
      {testQuestions.length ? (
        <div class="question-list">
          {testQuestions.map((question) => (
            <article class="question-card">
              <div class="question-card__head">
                <div class="question-card__summary">
                  <span class="question-card__badge">Q{question.order}</span>
                  <strong>{question.prompt}</strong>
                </div>

                <div class="question-card__actions">
                  <button type="button" class="ghost-btn" disabled>Edit</button>
                  <button type="button" class="ghost-btn ghost-btn--danger" disabled>Delete</button>
                </div>
              </div>

              <div class="option-grid">
                <span class:list={['option-chip', { 'option-chip--correct': question.correctOption === 'a' }]}>
                  A. {question.optionA}
                </span>
                <span class:list={['option-chip', { 'option-chip--correct': question.correctOption === 'b' }]}>
                  B. {question.optionB}
                </span>
                <span class:list={['option-chip', { 'option-chip--correct': question.correctOption === 'c' }]}>
                  C. {question.optionC}
                </span>
                <span class:list={['option-chip', { 'option-chip--correct': question.correctOption === 'd' }]}>
                  D. {question.optionD}
                </span>
              </div>

              {question.explanation && <p class="question-card__explanation">{question.explanation}</p>}
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">No questions added yet. Use the form to create the first question in this test.</div>
      )}
    </div>

    <aside class="form-pane">
      <div class="form-card">
        <div class="form-card__head">
          <span class="form-card__accent"></span>
          <div>
            <p class="eyebrow">Create New</p>
            <h2>Add Question</h2>
          </div>
        </div>

        <form action="/api/admin/questions" method="POST" class="question-form" data-question-form>
          <input type="hidden" name="test_id" value={test.id} />

          <label class="field">
            <span>Prompt</span>
            <textarea class="input-field textarea-field" name="prompt" required></textarea>
          </label>

          <div class="options-fields">
            <label class="field">
              <span>Option A</span>
              <input class="input-field" type="text" name="option_a" required />
            </label>
            <label class="field">
              <span>Option B</span>
              <input class="input-field" type="text" name="option_b" required />
            </label>
            <label class="field">
              <span>Option C</span>
              <input class="input-field" type="text" name="option_c" required />
            </label>
            <label class="field">
              <span>Option D</span>
              <input class="input-field" type="text" name="option_d" required />
            </label>
          </div>

          <fieldset class="correct-selector">
            <legend>Correct Answer</legend>
            <div class="correct-selector__grid">
              {(['a', 'b', 'c', 'd'] as const).map((option) => (
                <label class="correct-option">
                  <input type="radio" name="correct_option" value={option} required checked={option === 'a'} />
                  <span>{option.toUpperCase()}</span>
                </label>
              ))}
            </div>
          </fieldset>

          <label class="field">
            <span>Explanation</span>
            <textarea class="input-field explanation-field" name="explanation"></textarea>
          </label>

          <label class="field">
            <span>Question Order</span>
            <input class="input-field" type="number" name="order" required value={nextOrder} />
          </label>

          <button type="submit" class="submit-btn">Add Question →</button>
        </form>
      </div>
    </aside>
  </section>
</AdminLayout>

<script is:inline>
  const questionForm = document.querySelector('[data-question-form]');

  if (questionForm instanceof HTMLFormElement) {
    const optionFields = ['option_a', 'option_b', 'option_c', 'option_d']
      .map((name) => questionForm.elements.namedItem(name))
      .filter((field) => field instanceof HTMLInputElement);

    const validateUniqueOptions = () => {
      optionFields.forEach((field) => field.setCustomValidity(''));

      const seen = new Map();

      optionFields.forEach((field) => {
        const value = field.value.trim().toLowerCase();

        if (!value) {
          return;
        }

        const duplicateField = seen.get(value);

        if (duplicateField) {
          const message = 'Each option must be unique.';
          field.setCustomValidity(message);
          duplicateField.setCustomValidity(message);
        } else {
          seen.set(value, field);
        }
      });
    };

    optionFields.forEach((field) => {
      field.addEventListener('input', validateUniqueOptions);
      field.addEventListener('blur', validateUniqueOptions);
    });

    questionForm.addEventListener('submit', (event) => {
      validateUniqueOptions();

      if (!questionForm.reportValidity()) {
        event.preventDefault();
      }
    });
  }
</script>

<style>
  .publish-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 10px;
    padding: 9px 14px;
    background: #f5c518;
    color: #0a0f1e;
    font-size: 0.82rem;
    font-weight: 700;
    cursor: pointer;
  }

  .publish-btn--published {
    background: #d1fae5;
    color: #065f46;
  }

  .test-meta {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 18px;
  }

  .eyebrow {
    margin: 0 0 4px;
    color: #9aa5b4;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .test-meta h2,
  .form-card h2 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: #0a0f1e;
  }

  .test-meta__sub {
    margin: 6px 0 0;
    color: #64748b;
    font-size: 0.85rem;
  }

  .meta-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .meta-chip {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 999px;
    padding: 6px 10px;
    color: #64748b;
    font-size: 0.76rem;
    font-weight: 600;
    text-transform: capitalize;
  }

  .meta-chip--status {
    background: #fffbeb;
    color: #92400e;
    border-color: #fde68a;
  }

  .editor-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(340px, 1fr);
    gap: 18px;
    align-items: start;
  }

  .question-list {
    display: grid;
    gap: 8px;
  }

  .question-card,
  .form-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
  }

  .question-card {
    padding: 16px 20px;
  }

  .question-card__head {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: flex-start;
  }

  .question-card__summary {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .question-card__summary strong {
    color: #0a0f1e;
    font-size: 0.92rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .question-card__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px 10px;
    border-radius: 8px;
    background: #0a0f1e;
    color: #fff;
    font-size: 0.76rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .question-card__actions {
    display: flex;
    gap: 8px;
    opacity: 0;
    transform: translateX(8px);
    transition: all 0.15s ease;
  }

  .question-card:hover .question-card__actions {
    opacity: 1;
    transform: translateX(0);
  }

  .ghost-btn {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 6px 10px;
    background: #fff;
    color: #94a3b8;
    font-size: 0.78rem;
    font-weight: 600;
  }

  .ghost-btn--danger {
    color: #f87171;
  }

  .option-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 8px;
    margin-top: 14px;
  }

  .option-chip {
    background: #f3f4f6;
    color: #64748b;
    border-radius: 999px;
    padding: 7px 10px;
    font-size: 0.77rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .option-chip--correct {
    background: #f5c518;
    color: #0a0f1e;
    font-weight: 700;
  }

  .question-card__explanation {
    margin: 12px 0 0;
    color: #64748b;
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .form-pane {
    position: sticky;
    top: 80px;
  }

  .form-card {
    padding: 18px 20px 20px;
  }

  .form-card__head {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 16px;
  }

  .form-card__accent {
    width: 4px;
    min-height: 36px;
    border-radius: 999px;
    background: #f5c518;
    flex-shrink: 0;
  }

  .question-form,
  .field {
    display: grid;
    gap: 6px;
  }

  .question-form {
    gap: 14px;
  }

  .field span,
  .correct-selector legend {
    color: #4a5568;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .input-field {
    width: 100%;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 10px 12px;
    background: #fff;
    color: #0a0f1e;
    font-size: 0.9rem;
  }

  .textarea-field {
    min-height: 80px;
    resize: vertical;
  }

  .explanation-field {
    min-height: 64px;
    resize: vertical;
  }

  .options-fields {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .correct-selector {
    border: none;
    padding: 0;
    margin: 0;
  }

  .correct-selector__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    margin-top: 8px;
  }

  .correct-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .correct-option span {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: #f3f4f6;
    color: #64748b;
    padding: 12px 0;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
  }

  .correct-option input:checked + span {
    background: #0a0f1e;
    color: #f5c518;
  }

  .submit-btn {
    width: 100%;
    border: none;
    border-radius: 10px;
    padding: 12px;
    background: #f5c518;
    color: #0a0f1e;
    font-size: 0.88rem;
    font-weight: 800;
    cursor: pointer;
  }

  .empty-state {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 24px 20px;
    color: #9aa5b4;
    font-size: 0.875rem;
  }

  @media (max-width: 1080px) {
    .editor-grid {
      grid-template-columns: 1fr;
    }

    .form-pane {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .test-meta {
      flex-direction: column;
    }

    .meta-chips {
      justify-content: flex-start;
    }

    .option-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .options-fields {
      grid-template-columns: 1fr;
    }
  }
</style>
