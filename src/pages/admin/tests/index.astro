---
export const prerender = false;

import { asc, count, desc, eq } from 'drizzle-orm';

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, questions, subTopics, subjects, tests, topics } from '../../../db';
import { requireAuth } from '../../../lib/auth';

const authResult = await requireAuth(Astro, 'admin');

if (authResult instanceof Response) {
  return authResult;
}

const admin = authResult;
const query = Astro.url.searchParams.get('q')?.trim() ?? '';
const statusFilter = Astro.url.searchParams.get('status')?.trim() ?? 'all';

const [allSubjects, allTopics, allSubTopics, allTests] = await Promise.all([
  db.select().from(subjects).orderBy(asc(subjects.order)),
  db.select().from(topics).orderBy(asc(topics.order)),
  db.select().from(subTopics).orderBy(asc(subTopics.topicId), asc(subTopics.order)),
  db
    .select({
      id: tests.id,
      title: tests.title,
      testType: tests.testType,
      durationMinutes: tests.durationMinutes,
      status: tests.status,
      createdAt: tests.createdAt,
      subjectName: subjects.name,
      topicName: topics.name,
      subTopicName: subTopics.name,
      questionCount: count(questions.id),
    })
    .from(tests)
    .leftJoin(subjects, eq(tests.subjectId, subjects.id))
    .leftJoin(topics, eq(tests.topicId, topics.id))
    .leftJoin(subTopics, eq(tests.subTopicId, subTopics.id))
    .leftJoin(questions, eq(questions.testId, tests.id))
    .groupBy(tests.id, subjects.name, topics.name, subTopics.name)
    .orderBy(desc(tests.createdAt)),
]);

const filteredTests = allTests.filter((test) => {
  const matchesQuery =
    !query ||
    test.title.toLowerCase().includes(query.toLowerCase()) ||
    (test.subjectName ?? '').toLowerCase().includes(query.toLowerCase()) ||
    (test.topicName ?? '').toLowerCase().includes(query.toLowerCase()) ||
    (test.subTopicName ?? '').toLowerCase().includes(query.toLowerCase());
  const matchesStatus = statusFilter === 'all' || test.status === statusFilter;
  return matchesQuery && matchesStatus;
});

const filterHref = (status: string) => {
  const params = new URLSearchParams();

  if (query) {
    params.set('q', query);
  }

  if (status !== 'all') {
    params.set('status', status);
  }

  const search = params.toString();
  return search ? `/admin/tests?${search}` : '/admin/tests';
};
---

<AdminLayout
  title="Admin Tests | Dream Neet Academy"
  pageTitle="Tests"
  userName={admin.fullName}
  userEmail={Astro.locals.user?.email ?? admin.fullName}
>
  <a slot="actions" href="#create-test" class="top-action">+ Add Test</a>

  <section class="filters-card">
    <form action="/admin/tests" method="GET" class="filters-form">
      <label class="search-field">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
        <input type="search" name="q" value={query} placeholder="Search tests, subjects, or topics" />
      </label>

      <div class="filter-pills" aria-label="Status filters">
        <a href={filterHref('all')} class:list={['filter-pill', { 'filter-pill--active': statusFilter === 'all' }]}>All</a>
        <a
          href={filterHref('published')}
          class:list={['filter-pill', { 'filter-pill--active': statusFilter === 'published' }]}
        >
          Published
        </a>
        <a href={filterHref('draft')} class:list={['filter-pill', { 'filter-pill--active': statusFilter === 'draft' }]}>
          Draft
        </a>
      </div>
    </form>
  </section>

  <section class="tests-card">
    <div class="tests-card__header">
      <div class="tests-card__header-row tests-card__header-row--labels">
        <span>Test</span>
        <span>Details</span>
        <span>Status</span>
      </div>
    </div>

    {filteredTests.length ? (
      <div class="tests-list">
        {filteredTests.map((test) => (
          <article class="test-row">
            <div class="test-row__title-block">
              <div class="test-row__title-line">
                <span class:list={['test-row__dot', { 'test-row__dot--published': test.status === 'published' }]}></span>
                <a href={`/admin/tests/${test.id}`} class="test-row__title">{test.title}</a>
              </div>
              <div class="test-row__meta">
                <span>{test.subjectName ?? 'General'}</span>
                <span>·</span>
                <span>{test.topicName ?? 'No chapter'}</span>
                {test.subTopicName && (
                  <>
                    <span>·</span>
                    <span>{test.subTopicName}</span>
                  </>
                )}
              </div>
            </div>

            <div class="test-row__chips">
              <span class="meta-chip">{test.questionCount} questions</span>
              <span class="meta-chip">{test.durationMinutes} min</span>
            </div>

            <div class="test-row__actions">
              <span class:list={['status-badge', test.status === 'published' ? 'status-badge--published' : 'status-badge--draft']}>
                {test.status}
              </span>
              <a href={`/admin/tests/${test.id}`} class="edit-link">Edit</a>
              <form action={`/api/admin/tests/${test.id}/publish`} method="POST">
                <input type="hidden" name="test_id" value={test.id} />
                <button
                  type="submit"
                  class="toggle-btn"
                  aria-label={test.status === 'published' ? 'Unpublish test' : 'Publish test'}
                >
                  {test.status === 'published' ? '↺' : '↑'}
                </button>
              </form>
              <button type="button" class="delete-row-btn" data-delete-test-row data-test-id={test.id} data-test-title={test.title}>
                Delete
              </button>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-state">No tests matched this filter. Try another search or create a new test.</div>
    )}
  </section>

  <section id="create-test" class="create-card">
    <div class="create-card__head">
      <div>
        <p class="eyebrow">Create New</p>
        <h2>Add Test</h2>
      </div>
    </div>

    <form action="/api/admin/tests" method="POST" class="create-form">
      <label class="field field--wide">
        <span>Title</span>
        <input class="input-field" type="text" name="title" required />
      </label>
      <label class="field">
        <span>Subject</span>
        <select class="input-field input-select" name="subject_id" data-test-subject-select>
          <option value="">None</option>
          {allSubjects.map((subject) => (
            <option value={subject.id}>{subject.name}</option>
          ))}
        </select>
      </label>
      <label class="field">
        <span>Chapter</span>
        <select class="input-field input-select" name="topic_id" data-test-topic-select>
          <option value="">None</option>
          {allTopics.map((topic) => (
            <option value={topic.id} data-subject-id={topic.subjectId}>
              {topic.name}
            </option>
          ))}
        </select>
      </label>
      <label class="field field--wide">
        <span>Sub-topic (optional)</span>
        <select class="input-field input-select" name="sub_topic_id" data-test-subtopic-select>
          <option value="">Entire chapter</option>
          {allTopics.map((topic) => {
            const topicSubTopics = allSubTopics.filter((subTopic) => subTopic.topicId === topic.id);

            if (!topicSubTopics.length) {
              return null;
            }

            return (
              <optgroup label={topic.name}>
                {topicSubTopics.map((subTopic) => (
                  <option value={subTopic.id} data-topic-id={topic.id}>
                    {subTopic.name}
                  </option>
                ))}
              </optgroup>
            );
          })}
        </select>
      </label>
      <label class="field">
        <span>Duration Minutes</span>
        <input class="input-field" type="number" name="duration_minutes" min="1" required />
      </label>
      <label class="field">
        <span>Test Type</span>
        <select class="input-field input-select" name="test_type" required>
          <option value="topic_practice">Topic Practice</option>
          <option value="mock_exam">Mock Exam</option>
        </select>
      </label>
      <label class="field">
        <span>Attempt Mode</span>
        <select class="input-field input-select" name="attempt_mode" required>
          <option value="multiple">Multiple Attempts</option>
          <option value="single">Single Attempt</option>
        </select>
      </label>
      <button type="submit" class="submit-btn">Create Test →</button>
    </form>
  </section>

  <div class="delete-modal" data-delete-test-list-modal hidden>
    <div class="delete-modal__backdrop" data-delete-test-list-modal-close></div>
    <div
      class="delete-modal__dialog delete-modal__dialog--danger"
      role="dialog"
      aria-modal="true"
      aria-labelledby="delete-test-list-modal-title"
      aria-describedby="delete-test-list-modal-description"
    >
      <div class="delete-modal__icon delete-modal__icon--danger">!</div>
      <p class="eyebrow">Delete Test</p>
      <h2 id="delete-test-list-modal-title">Delete this entire test?</h2>
      <p class="delete-modal__text" id="delete-test-list-modal-description">
        You are about to permanently delete <strong data-delete-test-list-modal-title-label>this test</strong>.
      </p>
      <p class="delete-modal__subtext">
        This will remove all questions in the test, imported answer keys, and all student attempt history linked to it. This action cannot be undone.
      </p>
      <div class="delete-modal__actions">
        <button type="button" class="cancel-btn" data-delete-test-list-modal-cancel>Keep Test</button>
        <button type="button" class="submit-btn delete-modal__confirm" data-delete-test-list-modal-confirm>Delete Test</button>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const subjectSelect = document.querySelector('[data-test-subject-select]');
  const topicSelect = document.querySelector('[data-test-topic-select]');
  const subTopicSelect = document.querySelector('[data-test-subtopic-select]');
  const deleteTestListModal = document.querySelector('[data-delete-test-list-modal]');
  const deleteTestListModalTitleLabel = document.querySelector('[data-delete-test-list-modal-title-label]');
  const deleteTestListModalCancel = document.querySelector('[data-delete-test-list-modal-cancel]');
  const deleteTestListModalConfirm = document.querySelector('[data-delete-test-list-modal-confirm]');
  const deleteTestListModalCloseTargets = Array.from(document.querySelectorAll('[data-delete-test-list-modal-close]'));
  let pendingDeleteButton = null;
  let pendingDeleteTestId = '';

  const syncTopicOptions = () => {
    if (!(subjectSelect instanceof HTMLSelectElement) || !(topicSelect instanceof HTMLSelectElement)) {
      return;
    }

    const selectedSubjectId = subjectSelect.value;

    Array.from(topicSelect.options).forEach((option, index) => {
      if (index === 0) {
        option.hidden = false;
        option.disabled = false;
        return;
      }

      const belongsToSubject = !selectedSubjectId || option.dataset.subjectId === selectedSubjectId;
      option.hidden = !belongsToSubject;
      option.disabled = !belongsToSubject;

      if (!belongsToSubject && option.selected) {
        topicSelect.value = '';
      }
    });
  };

  const syncSubTopicOptions = () => {
    if (!(topicSelect instanceof HTMLSelectElement) || !(subTopicSelect instanceof HTMLSelectElement)) {
      return;
    }

    const selectedTopicId = topicSelect.value;

    Array.from(subTopicSelect.children).forEach((child, index) => {
      if (!(child instanceof HTMLOptGroupElement)) {
        if (child instanceof HTMLOptionElement && index === 0) {
          child.hidden = false;
          child.disabled = false;
        }
        return;
      }

      let visibleCount = 0;

      Array.from(child.children).forEach((option) => {
        if (!(option instanceof HTMLOptionElement)) {
          return;
        }

        const belongsToTopic = !selectedTopicId || option.dataset.topicId === selectedTopicId;
        option.hidden = !belongsToTopic;
        option.disabled = !belongsToTopic;

        if (belongsToTopic) {
          visibleCount += 1;
        } else if (option.selected) {
          subTopicSelect.value = '';
        }
      });

      child.disabled = visibleCount === 0;
      child.hidden = visibleCount === 0;
    });
  };

  subjectSelect?.addEventListener('change', () => {
    syncTopicOptions();
    syncSubTopicOptions();
  });

  topicSelect?.addEventListener('change', syncSubTopicOptions);

  syncTopicOptions();
  syncSubTopicOptions();

  const closeDeleteTestListModal = () => {
    if (deleteTestListModal instanceof HTMLElement) {
      deleteTestListModal.hidden = true;
    }

    if (deleteTestListModalConfirm instanceof HTMLButtonElement) {
      deleteTestListModalConfirm.disabled = false;
      deleteTestListModalConfirm.textContent = 'Delete Test';
    }

    if (pendingDeleteButton instanceof HTMLButtonElement) {
      pendingDeleteButton.disabled = false;
      pendingDeleteButton.textContent = 'Delete';
    }

    pendingDeleteButton = null;
    pendingDeleteTestId = '';
  };

  deleteTestListModalCloseTargets.forEach((node) => {
    node.addEventListener('click', closeDeleteTestListModal);
  });

  if (deleteTestListModalCancel instanceof HTMLButtonElement) {
    deleteTestListModalCancel.addEventListener('click', closeDeleteTestListModal);
  }

  if (deleteTestListModalConfirm instanceof HTMLButtonElement) {
    deleteTestListModalConfirm.addEventListener('click', async () => {
      if (!pendingDeleteTestId) {
        closeDeleteTestListModal();
        return;
      }

      deleteTestListModalConfirm.disabled = true;
      deleteTestListModalConfirm.textContent = 'Deleting...';

      if (pendingDeleteButton instanceof HTMLButtonElement) {
        pendingDeleteButton.disabled = true;
        pendingDeleteButton.textContent = 'Deleting...';
      }

      try {
        const response = await fetch(`/api/admin/tests/${pendingDeleteTestId}`, {
          method: 'DELETE',
        });
        const payload = await response.json().catch(() => ({ message: 'Unexpected response from the server.' }));

        if (!response.ok) {
          throw new Error(payload.message || 'Failed to delete test.');
        }

        window.location.reload();
      } catch (error) {
        window.alert(error instanceof Error ? error.message : 'Failed to delete test.');
        closeDeleteTestListModal();
      }
    });
  }

  const deleteButtons = Array.from(document.querySelectorAll('[data-delete-test-row]'));

  deleteButtons.forEach((button) => {
    if (!(button instanceof HTMLButtonElement)) {
      return;
    }

    button.addEventListener('click', () => {
      const testId = button.dataset.testId;
      const testTitle = button.dataset.testTitle ?? 'this test';

      if (!testId || !(deleteTestListModal instanceof HTMLElement)) {
        return;
      }

      pendingDeleteButton = button;
      pendingDeleteTestId = testId;

      if (deleteTestListModalTitleLabel instanceof HTMLElement) {
        deleteTestListModalTitleLabel.textContent = testTitle;
      }

      button.disabled = true;
      deleteTestListModal.hidden = false;
    });
  });
</script>

<style>
  .top-action,
  .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: #0a0f1e;
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 9px 14px;
  }

  .filters-card,
  .tests-card,
  .create-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
  }

  .filters-card {
    padding: 12px 16px;
    margin-bottom: 16px;
  }

  .filters-form {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .search-field {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .search-field svg {
    width: 18px;
    height: 18px;
    stroke: #9aa5b4;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex-shrink: 0;
  }

  .search-field input {
    width: 100%;
    border: none;
    outline: none;
    background: transparent;
    font-size: 0.9rem;
    color: #0a0f1e;
  }

  .filter-pills {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .filter-pill {
    padding: 4px 14px;
    border-radius: 999px;
    background: #f3f4f6;
    color: #6b7280;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .filter-pill--active {
    background: #0a0f1e;
    color: #fff;
  }

  .tests-card {
    overflow: hidden;
  }

  .tests-card__header {
    background: #f8f9ff;
    border-bottom: 1px solid #f1f3f9;
  }

  .tests-card__header-row {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(220px, 0.8fr) auto;
    gap: 16px;
    align-items: center;
    padding: 12px 20px;
  }

  .tests-card__header-row--labels {
    color: #9aa5b4;
    font-size: 0.7rem;
