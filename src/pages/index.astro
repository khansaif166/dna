---
import EnrollModal from '../components/EnrollModal.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import WhatsApp from '../components/WhatsApp.astro';
import Base from '../layouts/Base.astro';
import Advantage from '../components/sections/Advantage.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import Hero from '../components/sections/Hero.astro';
import ProgramHighlights from '../components/sections/ProgramHighlights.astro';
import SubjectPills from '../components/sections/SubjectPills.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import UrgencyBanner from '../components/sections/UrgencyBanner.astro';
---

<Base
  title="Dream Neet Academy | 20-Day Re-NEET Guided Self-Study Program"
  description="Dream Neet Academy's 20-day offline guided self-study program helps Re-NEET aspirants execute 12 focused study hours every day under expert monitoring."
>
  <UrgencyBanner />
  <Navbar />
  <main>
    <Hero />
    <SubjectPills />
    <ProgramHighlights />
    <Advantage />
    <Testimonials />
    <CTABanner />
  </main>
  <Footer />
  <EnrollModal />
  <WhatsApp />
</Base>
