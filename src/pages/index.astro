---
export const prerender = true;

import Base from '../layouts/Base.astro';
import EnrollModal from '../components/EnrollModal.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import WhatsApp from '../components/WhatsApp.astro';
import Advantage from '../components/sections/Advantage.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import Hero from '../components/sections/Hero.astro';
import ProgramHighlights from '../components/sections/ProgramHighlights.astro';
import SubjectPills from '../components/sections/SubjectPills.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import UrgencyBanner from '../components/sections/UrgencyBanner.astro';
---

<Base
  title="Dream Neet Academy"
  description="20-day Re-NEET guided self-study program from Dream Neet Academy."
>
  <UrgencyBanner />
  <Navbar />
  <Hero />
  <SubjectPills />
  <ProgramHighlights />
  <Advantage />
  <Testimonials />
  <CTABanner />
  <Footer />
  <EnrollModal />
  <WhatsApp />
</Base>
