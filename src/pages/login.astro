---
export const prerender = false;

import PlatformLayout from '../layouts/PlatformLayout.astro';

if (Astro.locals.profile) {
  return Astro.redirect(Astro.locals.profile.role === 'admin' ? '/admin' : '/student');
}

const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
const errorMessages: Record<string, string> = {
  invalid_input: 'Please enter a valid email and password.',
  invalid_credentials: 'Invalid email or password.',
  verification_failed: 'Email verification failed. Please try the link again.',
};
const successMessages: Record<string, string> = {
  account_created: 'Your account is ready. Please log in to continue.',
};
const subjects = ['Physics', 'Chemistry', 'Biology'];
---

<PlatformLayout title="Login | Dream Neet Academy" showNav={false}>
  <section class="auth-shell">
    <aside class="auth-panel auth-panel--brand">
      <div class="auth-panel__content">
        <div class="auth-brand">
          <img src="/images/logo.jpeg" alt="Dream Neet Academy logo" class="auth-brand__logo" />
          <span class="auth-brand__text">Dream Neet Academy</span>
        </div>

        <div class="auth-panel__copy">
          <p>India's most focused NEET preparation platform.</p>
        </div>

        <div class="auth-panel__footer">
          <span class="auth-panel__line"></span>
          <div class="auth-panel__subjects">
            {subjects.map((subject) => (
              <span class="auth-subject-pill">{subject}</span>
            ))}
          </div>
        </div>
      </div>
    </aside>

    <div class="auth-panel auth-panel--form">
      <div class="auth-card">
        <span class="auth-card__eyebrow">Student Login</span>
        <h1 class="auth-card__title">Welcome back</h1>
        <p class="auth-card__subtitle">Sign in to continue your preparation</p>

        {error && (
          <p class="auth-message auth-message--error">
            {errorMessages[error] ?? 'Unable to log in right now.'}
          </p>
        )}
        {success && (
          <p class="auth-message auth-message--success">
            {successMessages[success] ?? 'Success.'}
          </p>
        )}

        <form action="/api/auth/login" method="POST" class="auth-form">
          <div class="auth-form__field">
            <label for="email">Email</label>
            <input
              class="input-field"
              id="email"
              name="email"
              type="email"
              placeholder="you@example.com"
              required
            />
          </div>

          <div class="auth-form__field">
            <label for="password">Password</label>
            <input
              class="input-field"
              id="password"
              name="password"
              type="password"
              placeholder="Enter your password"
              required
            />
          </div>

          <button class="btn-yellow auth-form__submit" type="submit">Sign In →</button>
        </form>

        <p class="auth-card__footer">
          Don't have an account?
          <a href="/signup">Sign up</a>
        </p>
      </div>
    </div>
  </section>
</PlatformLayout>

<style>
  .auth-shell {
    min-height: 100vh;
    display: flex;
    background: var(--color-bg);
  }

  .auth-panel {
    min-height: 100vh;
  }

  .auth-panel--brand {
    display: none;
    width: 45%;
    background: var(--color-navy);
    padding: 48px;
  }

  .auth-panel__content {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: space-between;
  }

  .auth-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
  }

  .auth-brand__logo {
    width: 48px;
    height: 48px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    object-fit: cover;
  }

  .auth-brand__text {
    color: var(--color-surface);
    font-size: 1.1rem;
    font-weight: 700;
  }

  .auth-panel__copy {
    max-width: 27rem;
  }

  .auth-panel__copy p {
    margin: 0;
    color: var(--color-surface);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.4;
  }

  .auth-panel__footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .auth-panel__line {
    width: 60px;
    height: 4px;
    border-radius: 2px;
    background: var(--color-yellow);
  }

  .auth-panel__subjects {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .auth-subject-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px 14px;
    border: 1px solid rgba(245, 197, 24, 0.3);
    border-radius: 999px;
    background: rgba(245, 197, 24, 0.15);
    color: var(--color-yellow);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .auth-panel--form {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 32px;
    background: var(--color-bg);
  }

  .auth-card {
    width: 100%;
    max-width: 400px;
    border-radius: 20px;
    background: var(--color-surface);
    padding: 40px;
    box-shadow: 0 4px 24px rgba(10, 15, 30, 0.08);
  }

  .auth-card__eyebrow {
    display: inline-block;
    margin-bottom: 16px;
    border-radius: 999px;
    background: var(--color-yellow-bg);
    padding: 4px 12px;
    color: var(--color-yellow);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .auth-card__title {
    margin: 0 0 4px;
    color: var(--color-navy);
    font-size: 1.75rem;
    font-weight: 700;
  }

  .auth-card__subtitle {
    margin: 0 0 28px;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .auth-message {
    margin: 0 0 16px;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 0.875rem;
  }

  .auth-message--error {
    background: #fee2e2;
    border: 1px solid #fecaca;
    color: #991b1b;
  }

  .auth-message--success {
    background: #d1fae5;
    border: 1px solid #a7f3d0;
    color: #065f46;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .auth-form__field label {
    display: block;
    margin-bottom: 6px;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .auth-form__submit {
    width: 100%;
    margin-top: 8px;
    padding: 12px;
    font-size: 1rem;
  }

  .auth-card__footer {
    margin: 20px 0 0;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .auth-card__footer a {
    color: var(--color-navy);
    font-weight: 600;
  }

  @media (min-width: 960px) {
    .auth-panel--brand {
      display: block;
    }

    .auth-panel--form {
      width: 55%;
    }
  }

  @media (max-width: 640px) {
    .auth-panel--form {
      padding: 24px 16px;
    }

    .auth-card {
      padding: 28px 22px;
    }
  }
</style>
