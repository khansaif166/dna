---
export const prerender = false;

import { and, asc, eq, inArray, isNotNull } from 'drizzle-orm';

import Base from '../../../layouts/Base.astro';
import { db, testAttempts, tests, topicResources, topics } from '../../../db';
import { requireAuth } from '../../../lib/auth';

const authResult = await requireAuth(Astro, 'student');

if (authResult instanceof Response) {
  return authResult;
}

const profile = authResult;
const { topicId } = Astro.params;

if (!topicId) {
  return new Response(null, { status: 404 });
}

const topicRows = await db.select().from(topics).where(eq(topics.id, topicId));

if (!topicRows || topicRows.length === 0) {
  return new Response(null, { status: 404 });
}

const [topic] = topicRows;

const [resources, publishedTests] = await Promise.all([
  db
    .select()
    .from(topicResources)
    .where(eq(topicResources.topicId, topic.id))
    .orderBy(asc(topicResources.order)),
  db
    .select()
    .from(tests)
    .where(and(eq(tests.topicId, topic.id), eq(tests.status, 'published')))
    .orderBy(asc(tests.createdAt)),
]);

const testIds = publishedTests.map((test) => test.id);

const submittedAttempts = testIds.length
  ? await db
      .select({
        testId: testAttempts.testId,
      })
      .from(testAttempts)
      .where(
        and(
          eq(testAttempts.studentId, profile.id),
          inArray(testAttempts.testId, testIds),
          isNotNull(testAttempts.submittedAt)
        )
      )
  : [];

const attemptedTestIds = new Set(submittedAttempts.map((attempt) => attempt.testId));

function toEmbedUrl(youtubeUrl: string) {
  if (youtubeUrl.includes('watch?v=')) {
    return youtubeUrl.replace('watch?v=', 'embed/');
  }

  if (youtubeUrl.includes('youtu.be/')) {
    return youtubeUrl.replace('youtu.be/', 'www.youtube.com/embed/');
  }

  return youtubeUrl;
}
---

<Base title={`${topic.name} | Dream Neet Academy`}>
  <main class="min-h-screen bg-gray-950 text-white">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <div class="mb-8">
        <a href={`/student/subjects/${topic.subjectId}`} class="text-sm text-gray-400 transition-colors hover:text-white">
          ← Back to subject
        </a>
        <h1 class="mt-3 text-3xl font-bold text-white">{topic.name}</h1>
      </div>

      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold text-white">Video Resources</h2>
        {resources.length ? (
          <div class="space-y-5">
            {resources.map((resource) => (
              <article class="rounded-2xl border border-gray-800 bg-gray-900 p-4">
                <h3 class="mb-3 text-lg font-semibold text-white">{resource.title}</h3>
                <div class="aspect-video w-full rounded-xl overflow-hidden bg-gray-800 mb-3">
                  <iframe
                    class="h-full w-full"
                    src={toEmbedUrl(resource.youtubeUrl)}
                    title={resource.title}
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  />
                </div>
                {resource.notes && <p class="text-sm text-gray-400">{resource.notes}</p>}
              </article>
            ))}
          </div>
        ) : (
          <p class="rounded-xl border border-gray-800 bg-gray-900 p-5 text-gray-400">
            No video resources are available for this topic yet.
          </p>
        )}
      </section>

      <section>
        <h2 class="mb-4 text-xl font-semibold text-white">Tests</h2>
        {publishedTests.length ? (
          <div class="space-y-3">
            {publishedTests.map((test) => (
              <a
                href={`/student/tests/${test.id}`}
                class="bg-gray-900 rounded-xl p-4 border border-gray-800 flex justify-between items-center gap-4 transition-colors hover:border-blue-500"
              >
                <div>
                  <h3 class="font-semibold text-white">{test.title}</h3>
                  <p class="text-sm text-gray-400">{test.durationMinutes} minutes</p>
                </div>
                <span
                  class:list={[
                    'text-xs px-2 py-1 rounded-full',
                    attemptedTestIds.has(test.id)
                      ? 'bg-green-900/40 text-green-400'
                      : 'bg-gray-800 text-gray-400',
                  ]}
                >
                  {attemptedTestIds.has(test.id) ? 'Attempted' : 'Not attempted'}
                </span>
              </a>
            ))}
          </div>
        ) : (
          <p class="rounded-xl border border-gray-800 bg-gray-900 p-5 text-gray-400">
            No published tests are available for this topic yet.
          </p>
        )}
      </section>
    </div>
  </main>
</Base>
