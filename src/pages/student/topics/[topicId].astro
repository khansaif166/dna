---
export const prerender = false;

import { and, asc, count, desc, eq, inArray, isNotNull, sql } from 'drizzle-orm';

import PlatformLayout from '../../../layouts/PlatformLayout.astro';
import { db, questions, subTopics, subjects, testAttempts, tests, topicResources, topics } from '../../../db';
import { requireAuth } from '../../../lib/auth';

const authResult = await requireAuth(Astro, 'student');

if (authResult instanceof Response) {
  return authResult;
}

const profile = authResult;
const { topicId } = Astro.params;

if (!topicId) {
  return new Response(null, { status: 404 });
}

const topicRows = await db
  .select({
    id: topics.id,
    name: topics.name,
    subjectId: topics.subjectId,
    subjectName: subjects.name,
  })
  .from(topics)
  .innerJoin(subjects, eq(topics.subjectId, subjects.id))
  .where(eq(topics.id, topicId));

if (!topicRows || topicRows.length === 0) {
  return new Response(null, { status: 404 });
}

const [topic] = topicRows;

const [topicSubTopics, resources, testRows] = await Promise.all([
  db
    .select()
    .from(subTopics)
    .where(eq(subTopics.topicId, topic.id))
    .orderBy(asc(subTopics.order)),
  db
    .select()
    .from(topicResources)
    .where(eq(topicResources.topicId, topic.id))
    .orderBy(asc(topicResources.order)),
  db
    .select({
      id: tests.id,
      title: tests.title,
      durationMinutes: tests.durationMinutes,
      questionCount: count(questions.id),
    })
    .from(tests)
    .leftJoin(questions, eq(questions.testId, tests.id))
    .where(and(eq(tests.topicId, topic.id), eq(tests.status, 'published')))
    .groupBy(tests.id, tests.title, tests.durationMinutes, tests.createdAt)
    .orderBy(asc(tests.createdAt)),
]);

const testIds = testRows.map((test) => test.id);

const attemptRows = testIds.length
  ? await db
      .select({
        testId: testAttempts.testId,
        score: testAttempts.score,
        totalQuestions: testAttempts.totalQuestions,
        submittedAt: testAttempts.submittedAt,
      })
      .from(testAttempts)
      .where(
        and(
          eq(testAttempts.studentId, profile.id),
          inArray(testAttempts.testId, testIds),
          isNotNull(testAttempts.submittedAt)
        )
      )
      .orderBy(desc(testAttempts.submittedAt))
  : [];

const attemptsByTestId = new Map<string, typeof attemptRows>();

for (const attempt of attemptRows) {
  const existing = attemptsByTestId.get(attempt.testId) ?? [];
  existing.push(attempt);
  attemptsByTestId.set(attempt.testId, existing);
}

const attemptedTestIds = new Set(attemptRows.map((attempt) => attempt.testId));

function normalizeLabel(value: string) {
  return value.toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
}

const matchedResourceIds = new Set<string>();
const subTopicSections = topicSubTopics.map((subTopic) => {
  const normalizedName = normalizeLabel(subTopic.name);
  const matchedResources = resources.filter((resource) => {
    if (matchedResourceIds.has(resource.id)) {
      return false;
    }

    const sameOrder = resource.order === subTopic.order;
    const sameTitle = normalizeLabel(resource.title) === normalizedName;

    if (sameOrder || sameTitle) {
      matchedResourceIds.add(resource.id);
      return true;
    }

    return false;
  });

  return {
    ...subTopic,
    resources: matchedResources,
  };
});

const unmatchedResources = resources.filter((resource) => !matchedResourceIds.has(resource.id));

const subjectType = topic.subjectName.toLowerCase().includes('physics')
  ? 'physics'
  : topic.subjectName.toLowerCase().includes('chemistry')
    ? 'chemistry'
    : 'biology';

const theme = {
  physics: {
    color: '#3B82F6',
    colorDark: '#1D4ED8',
    bgLight: '#EFF6FF',
    textColor: '#1D4ED8',
    border: '#BFDBFE',
    shadowRgb: '59,130,246',
    gradientFrom: '#1D4ED8',
    gradientTo: '#3B82F6',
  },
  chemistry: {
    color: '#10B981',
    colorDark: '#059669',
    bgLight: '#F0FDF4',
    textColor: '#166534',
    border: '#BBF7D0',
    shadowRgb: '16,185,129',
    gradientFrom: '#059669',
    gradientTo: '#10B981',
  },
  biology: {
    color: '#F59E0B',
    colorDark: '#D97706',
    bgLight: '#FFFBEB',
    textColor: '#92400E',
    border: '#FDE68A',
    shadowRgb: '245,158,11',
    gradientFrom: '#D97706',
    gradientTo: '#F59E0B',
  },
}[subjectType];

const practiced = attemptedTestIds.size > 0;

const enrichedTests = testRows.map((test) => {
  const attempts = attemptsByTestId.get(test.id) ?? [];
  const bestAttempt = attempts.reduce<
    | {
        score: number;
        totalQuestions: number;
        percent: number;
      }
    | null
  >((best, attempt) => {
    const score = attempt.score ?? 0;
    const totalQuestions = attempt.totalQuestions ?? test.questionCount;
    const percent = totalQuestions > 0 ? Math.round((score / totalQuestions) * 100) : 0;

    if (!best || percent > best.percent) {
      return { score, totalQuestions, percent };
    }

    return best;
  }, null);

  return {
    ...test,
    attempted: attempts.length > 0,
    attemptCount: attempts.length,
    bestAttempt,
  };
});

function toEmbedUrl(youtubeUrl: string) {
  if (youtubeUrl.includes('watch?v=')) {
    return youtubeUrl.replace('watch?v=', 'embed/');
  }

  if (youtubeUrl.includes('youtu.be/')) {
    return youtubeUrl.replace('youtu.be/', 'www.youtube.com/embed/');
  }

  return youtubeUrl;
}

function pluralize(count: number, singular: string, plural = `${singular}s`) {
  return `${count} ${count === 1 ? singular : plural}`;
}

function scoreTone(percent: number) {
  if (percent >= 70) {
    return {
      dot: '#10B981',
      text: '#10B981',
    };
  }

  if (percent >= 40) {
    return {
      dot: '#F59E0B',
      text: '#F59E0B',
    };
  }

  return {
    dot: '#EF4444',
    text: '#EF4444',
  };
}
---

<PlatformLayout title={`${topic.name} | Dream Neet Academy`}>
  <section class="topic-page">
    <header class="topic-header">
      <div class="topic-header__left">
        <div class="topic-breadcrumbs">
          <a href="/student">Dashboard</a>
          <span>›</span>
          <a href={`/student/subjects/${topic.subjectId}`}>{topic.subjectName}</a>
          <span>›</span>
          <span class="topic-breadcrumbs__current">{topic.name}</span>
        </div>

        <div class="topic-title-row">
          <span class="topic-title-row__dot" style={`background:${theme.color};`}></span>
          <h1>{topic.name}</h1>
        </div>

        <div class="topic-stats">
          <span>◎ {pluralize(topicSubTopics.length, 'sub-topic')}</span>
          <span>▶ {pluralize(resources.length, 'video')}</span>
          <span>📝 {pluralize(testRows.length, 'test')}</span>
        </div>
      </div>

      <div class="topic-header__right">
        <div class:list={['completion-pill', { 'completion-pill--done': practiced }]}>
          <span>{practiced ? '✓' : '○'}</span>
          <span>{practiced ? 'Practiced' : 'Not started'}</span>
        </div>
        <a href={`/student/subjects/${topic.subjectId}`} class="topic-header__back">← Back to {topic.subjectName}</a>
      </div>
    </header>

    <div class="topic-layout">
      <div class="topic-layout__main">
        <div class="section-head">
          <h2>Sub-topics</h2>
          <span class="section-count" style={`background:${theme.bgLight}; color:${theme.textColor};`}>
            {topicSubTopics.length} items
          </span>
        </div>

        {topicSubTopics.length ? (
          <div class="subtopic-accordion-list">
            {subTopicSections.map((subTopic, index) => (
              <details class="subtopic-accordion" open={index === 0}>
                <summary class="subtopic-accordion__summary">
                  <span class="subtopic-accordion__order">{String(subTopic.order).padStart(2, '0')}</span>
                  <span class="subtopic-accordion__name">{subTopic.name}</span>
                  <span
                    class="subtopic-accordion__count"
                    style={`background:${theme.bgLight}; color:${theme.textColor}; border-color:${theme.border};`}
                  >
                    ▶ {pluralize(subTopic.resources.length, 'video')}
                  </span>
                  <span class="subtopic-accordion__chevron" aria-hidden="true">▾</span>
                </summary>

                <div class="subtopic-accordion__body">
                  {subTopic.resources.length ? (
                    <div>
                      {subTopic.resources.map((resource, resourceIndex) => (
                        <article class="video-card video-card--nested">
                          <div
                            class="video-card__accent"
                            style={`background:linear-gradient(90deg, ${theme.gradientFrom}, ${theme.gradientTo});`}
                          ></div>

                          <div class="video-card__media">
                            <iframe
                              class="video-card__frame"
                              src={toEmbedUrl(resource.youtubeUrl)}
                              title={resource.title}
                              loading="lazy"
                              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                              allowfullscreen
                            />
                            <div class="video-card__overlay">VIDEO {resourceIndex + 1}</div>
                          </div>

                          <div class="video-card__body">
                            <div class="video-card__title-row">
                              <h3 class="video-card__title">{resource.title}</h3>
                            </div>

                            {resource.notes && (
                              <div class="video-card__notes">
                                <div class="video-card__notes-label">📌 Note</div>
                                <div class="video-card__notes-text">{resource.notes}</div>
                              </div>
                            )}
                          </div>
                        </article>
                      ))}
                    </div>
                  ) : (
                    <div class="subtopic-empty">
                      <h3>No videos yet</h3>
                      <p>Videos for this sub-topic will appear here soon.</p>
                    </div>
                  )}

                  <div class="subtopic-tests">
                    <div class="subtopic-tests__head">
                      <h3>Practice Tests</h3>
                      <span
                        class="subtopic-tests__count"
                        style={`background:${theme.bgLight}; color:${theme.textColor}; border-color:${theme.border};`}
                      >
                        📝 {pluralize(enrichedTests.length, 'test')}
                      </span>
                    </div>

                    {enrichedTests.length ? (
                      <div class="subtopic-tests__list">
                        {enrichedTests.map((test) => (
                          <a
                            href={`/student/tests/${test.id}`}
                            class:list={[
                              'subtopic-test-link',
                              { 'subtopic-test-link--attempted': test.attempted },
                            ]}
                            style={`--subject-color:${theme.color}; --subject-text:${theme.textColor}; --subject-border:${theme.border};`}
                          >
                            <span class="subtopic-test-link__title">{test.title}</span>
                            <span class="subtopic-test-link__meta">
                              {test.attempted ? 'Retake test' : 'Start test'}
                            </span>
                          </a>
                        ))}
                      </div>
                    ) : (
                      <div class="subtopic-tests__empty">
                        <p>No tests yet for this chapter.</p>
                      </div>
                    )}
                  </div>
                </div>
              </details>
            ))}
          </div>
        ) : (
          <div class="empty-card empty-card--subtopics">
            <div class="empty-card__emoji">◎</div>
            <h3>No sub-topics yet</h3>
            <p>Sub-topics for this topic will appear here soon</p>
          </div>
        )}

        {unmatchedResources.length > 0 && (
          <>
            <div class="section-head">
              <h2>Additional Videos</h2>
              <span class="section-count" style={`background:${theme.bgLight}; color:${theme.textColor};`}>
                {unmatchedResources.length} videos
              </span>
            </div>

            <div>
              {unmatchedResources.map((resource, index) => (
                <article class="video-card">
                  <div
                    class="video-card__accent"
                    style={`background:linear-gradient(90deg, ${theme.gradientFrom}, ${theme.gradientTo});`}
                  ></div>

                  <div class="video-card__media">
                    <iframe
                      class="video-card__frame"
                      src={toEmbedUrl(resource.youtubeUrl)}
                      title={resource.title}
                      loading="lazy"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    />
                    <div class="video-card__overlay">VIDEO {index + 1}</div>
                  </div>

                  <div class="video-card__body">
                    <div class="video-card__title-row">
                      <h3 class="video-card__title">{resource.title}</h3>
                    </div>

                    {resource.notes && (
                      <div class="video-card__notes">
                        <div class="video-card__notes-label">📌 Note</div>
                        <div class="video-card__notes-text">{resource.notes}</div>
                      </div>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </>
        )}
      </div>

      <aside class="topic-layout__side">
        <div class="tests-panel">
          <div class="section-head section-head--tests">
            <h2>Practice Tests</h2>
            <span class="section-count section-count--tests">{testRows.length} tests</span>
          </div>

          {enrichedTests.length ? (
            <div>
              {enrichedTests.map((test) => {
                const tone = test.bestAttempt ? scoreTone(test.bestAttempt.percent) : null;

                return (
                  <article
                    class="test-card"
                    style={`--subject-color:${theme.color}; --subject-shadow-rgb:${theme.shadowRgb};`}
                  >
                    <div class="test-card__top">
                      <h3 class="test-card__title">{test.title}</h3>

                      <div class="test-card__meta">
                        <span>⏱ {test.durationMinutes} min</span>
                        <span>·</span>
                        <span>{test.questionCount} questions</span>
                      </div>

                      {test.bestAttempt && tone && (
                        <div class="test-card__score" style={`color:${tone.text};`}>
                          <span class="test-card__score-dot" style={`background:${tone.dot};`}></span>
                          <span>
                            Your best: {test.bestAttempt.score}/{test.bestAttempt.totalQuestions} ({test.bestAttempt.percent}%)
                          </span>
                          <span class="test-card__score-attempts">
                            ({pluralize(test.attemptCount, 'attempt')})
                          </span>
                        </div>
                      )}
                    </div>

                    <div class="test-card__divider"></div>

                    <div class="test-card__bottom">
                      {test.attempted ? (
                        <div class="test-card__status">
                          <span class="test-card__status-dot">✓</span>
                          <span>Practiced</span>
                        </div>
                      ) : (
                        <span
                          class="test-card__new"
                          style={`background:${theme.bgLight}; color:${theme.textColor};`}
                        >
                          New
                        </span>
                      )}

                      <a
                        href={`/student/tests/${test.id}`}
                        class:list={['test-card__button', { 'test-card__button--retake': test.attempted }]}
                        style={!test.attempted ? `background:${theme.color};` : undefined}
                      >
                        {test.attempted ? 'Retake' : 'Start Test →'}
                      </a>
                    </div>
                  </article>
                );
              })}
            </div>
          ) : (
            <div class="empty-card empty-card--tests">
              <div class="empty-card__emoji">📝</div>
              <h3>No tests yet</h3>
              <p>Tests for this topic will be added soon</p>
            </div>
          )}
        </div>
      </aside>
    </div>
  </section>
</PlatformLayout>

<style>
  .topic-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 24px;
  }

  .topic-header {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #e2e8f0;
    padding: 20px 24px;
    margin-bottom: 20px;
    box-shadow: 0 1px 4px rgba(10, 15, 30, 0.05);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .topic-breadcrumbs {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    margin-bottom: 8px;
  }

  .topic-breadcrumbs a {
    color: #9aa5b4;
    transition: color 0.15s ease;
  }

  .topic-breadcrumbs a:hover {
    color: #0a0f1e;
  }

  .topic-breadcrumbs span {
    color: #e2e8f0;
  }

  .topic-breadcrumbs__current {
    color: #0a0f1e !important;
    font-weight: 600;
  }

  .topic-title-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .topic-title-row__dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    flex-shrink: 0;
  }

  .topic-title-row h1 {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 800;
    color: #0a0f1e;
  }

  .topic-stats {
    margin-top: 6px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    font-size: 0.78rem;
    color: #9aa5b4;
  }

  .topic-header__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }

  .completion-pill {
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 999px;
    padding: 6px 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    color: #9aa5b4;
    font-size: 0.82rem;
    font-weight: 500;
  }

  .completion-pill--done {
    background: #d1fae5;
    border-color: #a7f3d0;
    color: #065f46;
    font-weight: 600;
  }

  .completion-pill span:first-child {
    font-size: 0.85rem;
    font-weight: 800;
  }

  .topic-header__back {
    font-size: 0.75rem;
    color: #9aa5b4;
    transition: color 0.15s ease;
  }

  .topic-header__back:hover {
    color: #0a0f1e;
  }

  .topic-layout {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .topic-layout__main {
    flex: 1;
    min-width: 0;
  }

  .topic-layout__side {
    width: 320px;
    flex-shrink: 0;
  }

  .tests-panel {
    position: sticky;
    top: 80px;
  }

  .section-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }

  .section-head--tests {
    justify-content: space-between;
  }

  .section-head h2 {
    margin: 0;
    font-weight: 700;
    font-size: 0.95rem;
    color: #0a0f1e;
