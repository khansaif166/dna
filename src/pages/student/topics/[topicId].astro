---
export const prerender = false;

import { and, asc, count, eq, inArray, isNotNull } from 'drizzle-orm';

import PlatformLayout from '../../../layouts/PlatformLayout.astro';
import { db, questions, subjects, testAttempts, tests, topicResources, topics } from '../../../db';
import { requireAuth } from '../../../lib/auth';

const authResult = await requireAuth(Astro, 'student');

if (authResult instanceof Response) {
  return authResult;
}

const profile = authResult;
const { topicId } = Astro.params;

if (!topicId) {
  return new Response(null, { status: 404 });
}

const topicRows = await db
  .select({
    id: topics.id,
    name: topics.name,
    subjectId: topics.subjectId,
    subjectName: subjects.name,
  })
  .from(topics)
  .innerJoin(subjects, eq(topics.subjectId, subjects.id))
  .where(eq(topics.id, topicId));

if (!topicRows || topicRows.length === 0) {
  return new Response(null, { status: 404 });
}

const [topic] = topicRows;

const [resources, testRows] = await Promise.all([
  db
    .select()
    .from(topicResources)
    .where(eq(topicResources.topicId, topic.id))
    .orderBy(asc(topicResources.order)),
  db
    .select({
      id: tests.id,
      title: tests.title,
      durationMinutes: tests.durationMinutes,
      questionCount: count(questions.id),
    })
    .from(tests)
    .leftJoin(questions, eq(questions.testId, tests.id))
    .where(and(eq(tests.topicId, topic.id), eq(tests.status, 'published')))
    .groupBy(tests.id, tests.title, tests.durationMinutes, tests.createdAt)
    .orderBy(asc(tests.createdAt)),
]);

const testIds = testRows.map((test) => test.id);

const submittedAttempts = testIds.length
  ? await db
      .select({
        testId: testAttempts.testId,
      })
      .from(testAttempts)
      .where(
        and(
          eq(testAttempts.studentId, profile.id),
          inArray(testAttempts.testId, testIds),
          isNotNull(testAttempts.submittedAt)
        )
      )
  : [];

const attemptedTestIds = new Set(submittedAttempts.map((attempt) => attempt.testId));

function toEmbedUrl(youtubeUrl: string) {
  if (youtubeUrl.includes('watch?v=')) {
    return youtubeUrl.replace('watch?v=', 'embed/');
  }

  if (youtubeUrl.includes('youtu.be/')) {
    return youtubeUrl.replace('youtu.be/', 'www.youtube.com/embed/');
  }

  return youtubeUrl;
}
---

<PlatformLayout title={`${topic.name} | Dream Neet Academy`}>
  <section class="topic-hero">
    <div class="topic-hero__inner">
      <p class="breadcrumb">
        <a href="/student">Dashboard</a>
        <span>/</span>
        <a href={`/student/subjects/${topic.subjectId}`}>{topic.subjectName}</a>
        <span>/</span>
        <span class="breadcrumb__active">{topic.name}</span>
      </p>
      <h1 class="heading-xl">{topic.name}</h1>
      <a href={`/student/subjects/${topic.subjectId}`} class="topic-hero__back">← Back to {topic.subjectName}</a>
    </div>
  </section>

  <section class="topic-page">
    <div class="topic-layout">
      <div class="topic-layout__main">
        <h2 class="heading-md">Video Resources</h2>

        {resources.length ? (
          <div>
            {resources.map((resource, index) => (
              <article class="card video-card">
                <div class="video-card__badge">{index + 1}</div>
                <iframe
                  class="video-card__frame"
                  src={toEmbedUrl(resource.youtubeUrl)}
                  title={resource.title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                />
                <h3 class="video-card__title">{resource.title}</h3>
                {resource.notes && <p class="video-card__notes">{resource.notes}</p>}
              </article>
            ))}
          </div>
        ) : (
          <div class="card empty-card">
            <h3 class="heading-md">No video resources yet</h3>
            <p class="text-muted">Video lessons for this topic will appear here.</p>
          </div>
        )}
      </div>

      <aside class="topic-layout__side">
        <div class="tests-panel">
          <h2 class="heading-md">Practice Tests</h2>

          {testRows.length ? (
            <div>
              {testRows.map((test) => {
                const attempted = attemptedTestIds.has(test.id);

                return (
                  <article class="card test-card">
                    <h3 class="test-card__title">{test.title}</h3>
                    <p class="test-card__meta">⏱ {test.durationMinutes} minutes</p>
                    <p class="test-card__meta">{test.questionCount} questions</p>
                    <div class="test-card__divider"></div>
                    <div class="test-card__footer">
                      <span class:list={[attempted ? 'badge-success' : 'badge-pending']}>
                        {attempted ? 'Attempted' : 'Not attempted'}
                      </span>
                      <a
                        href={`/student/tests/${test.id}`}
                        class:list={[attempted ? 'btn-outline test-card__button' : 'btn-yellow test-card__button']}
                      >
                        {attempted ? 'Retake' : 'Start Test'}
                      </a>
                    </div>
                  </article>
                );
              })}
            </div>
          ) : (
            <div class="card empty-card">
              <h3 class="heading-md">No practice tests yet</h3>
              <p class="text-muted">Published tests for this topic will show up here.</p>
            </div>
          )}
        </div>
      </aside>
    </div>
  </section>
</PlatformLayout>

<style>
  .topic-hero {
    background: var(--color-navy);
    padding: 40px 16px;
  }

  .topic-hero__inner,
  .topic-page {
    margin: 0 auto;
    max-width: 64rem;
  }

  .breadcrumb {
    align-items: center;
    color: rgba(255, 255, 255, 0.5);
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    font-size: 0.875rem;
    margin: 0;
  }

  .breadcrumb__active,
  .topic-hero__back {
    color: var(--color-surface);
  }

  .heading-xl,
  .heading-md {
    margin: 0;
  }

  .heading-xl {
    color: var(--color-surface);
    font-size: clamp(2rem, 3vw, 2.75rem);
    font-weight: 800;
    margin-top: 8px;
  }

  .heading-md {
    color: var(--color-navy);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .topic-hero__back {
    display: inline-flex;
    font-size: 0.875rem;
    margin-top: 0.75rem;
  }

  .topic-page {
    padding: 2rem 1rem 3.5rem;
  }

  .topic-layout {
    display: grid;
    gap: 1.5rem;
  }

  .topic-layout__main {
    min-width: 0;
  }

  .video-card,
  .test-card {
    margin-bottom: 16px;
  }

  .video-card {
    position: relative;
  }

  .video-card__badge {
    align-items: center;
    background: var(--color-yellow);
    border-radius: 999px;
    color: var(--color-navy);
    display: inline-flex;
    font-size: 0.75rem;
    font-weight: 700;
    height: 28px;
    justify-content: center;
    left: 16px;
    position: absolute;
    top: 16px;
    width: 28px;
  }

  .video-card__frame {
    aspect-ratio: 16 / 9;
    background: #000;
    border: none;
    border-radius: 10px;
    margin-bottom: 12px;
    width: 100%;
  }

  .video-card__title,
  .test-card__title {
    color: var(--color-text);
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
  }

  .video-card__notes {
    background: var(--color-bg);
    border-left: 3px solid var(--color-yellow);
    border-radius: 8px;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 8px 0 0;
    padding: 8px 12px;
  }

  .tests-panel {
    position: sticky;
    top: 6rem;
  }

  .test-card__meta,
  .text-muted {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .test-card__meta {
    margin: 0.35rem 0 0;
  }

  .test-card__divider {
    background: var(--color-border);
    height: 1px;
    margin: 14px 0 12px;
  }

  .test-card__footer {
    align-items: center;
    display: flex;
    gap: 0.75rem;
    justify-content: space-between;
  }

  .test-card__button {
    font-size: 0.85rem;
    padding: 6px 16px;
  }

  .empty-card {
    text-align: center;
  }

  .empty-card p {
    margin: 0.5rem 0 0;
  }

  @media (min-width: 920px) {
    .topic-layout {
      grid-template-columns: minmax(0, 1.85fr) minmax(280px, 1fr);
    }
  }

  @media (max-width: 640px) {
    .test-card__footer {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
