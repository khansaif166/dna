---
export const prerender = false;

import { and, asc, desc, eq, isNotNull, sql } from 'drizzle-orm';

import Base from '../../layouts/Base.astro';
import { db, subjects, testAttempts, tests, topics } from '../../db';
import { requireAuth } from '../../lib/auth';

const authResult = await requireAuth(Astro, 'student');

if (authResult instanceof Response) {
  return authResult;
}

const profile = authResult;

const [
  allSubjects,
  topicCountRows,
  testCountRows,
  submittedAttemptRows,
  topicProgressRows,
  recentAttempts,
] = await Promise.all([
  db.select().from(subjects).orderBy(asc(subjects.order)),
  db
    .select({
      subjectId: topics.subjectId,
      topicCount: sql<number>`count(*)::int`,
    })
    .from(topics)
    .groupBy(topics.subjectId),
  db
    .select({
      subjectId: tests.subjectId,
      testCount: sql<number>`count(*)::int`,
    })
    .from(tests)
    .groupBy(tests.subjectId),
  db
    .select({
      score: testAttempts.score,
      totalQuestions: testAttempts.totalQuestions,
      submittedAt: testAttempts.submittedAt,
    })
    .from(testAttempts)
    .where(and(eq(testAttempts.studentId, profile.id), isNotNull(testAttempts.submittedAt))),
  db
    .select({
      subjectId: tests.subjectId,
      topicId: tests.topicId,
      submittedAt: testAttempts.submittedAt,
    })
    .from(testAttempts)
    .innerJoin(tests, eq(testAttempts.testId, tests.id))
    .where(and(eq(testAttempts.studentId, profile.id), isNotNull(testAttempts.submittedAt))),
  db
    .select({
      id: testAttempts.id,
      score: testAttempts.score,
      totalQuestions: testAttempts.totalQuestions,
      submittedAt: testAttempts.submittedAt,
      testTitle: tests.title,
      subjectName: subjects.name,
    })
    .from(testAttempts)
    .innerJoin(tests, eq(testAttempts.testId, tests.id))
    .leftJoin(subjects, eq(tests.subjectId, subjects.id))
    .where(and(eq(testAttempts.studentId, profile.id), isNotNull(testAttempts.submittedAt)))
    .orderBy(desc(testAttempts.submittedAt))
    .limit(5),
]);

const now = new Date();
const dayMs = 24 * 60 * 60 * 1000;
const weekAgo = new Date(now.getTime() - 7 * dayMs);
const twoWeeksAgo = new Date(now.getTime() - 14 * dayMs);

const fullNameParts = profile.fullName.trim().split(/\s+/).filter(Boolean);
const firstName = fullNameParts[0] ?? 'Student';
const lastName = fullNameParts[fullNameParts.length - 1] ?? '';
const initials = `${firstName[0] ?? 'S'}${lastName[0] ?? firstName[1] ?? ''}`.toUpperCase();

const welcomeDate = new Intl.DateTimeFormat('en-IN', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
}).format(now);

const tableDateFormatter = new Intl.DateTimeFormat('en-IN', {
  dateStyle: 'medium',
});

const subjectTopicCounts = new Map(topicCountRows.map((row) => [row.subjectId, row.topicCount]));
const subjectTestCounts = new Map(
  testCountRows
    .filter((row): row is { subjectId: string; testCount: number } => Boolean(row.subjectId))
    .map((row) => [row.subjectId, row.testCount])
);

const subjectAttemptedTopics = topicProgressRows.reduce((map, row) => {
  if (!row.subjectId || !row.topicId) {
    return map;
  }

  const topicIds = map.get(row.subjectId) ?? new Set<string>();
  topicIds.add(row.topicId);
  map.set(row.subjectId, topicIds);
  return map;
}, new Map<string, Set<string>>());

const topicsCovered = new Set(
  topicProgressRows
    .map((row) => row.topicId)
    .filter((topicId): topicId is string => Boolean(topicId))
).size;

const topicsCoveredThisWeek = new Set(
  topicProgressRows
    .filter((row) => row.submittedAt && row.submittedAt >= weekAgo)
    .map((row) => row.topicId)
    .filter((topicId): topicId is string => Boolean(topicId))
).size;

const topicsCoveredPreviousWeek = new Set(
  topicProgressRows
    .filter((row) => row.submittedAt && row.submittedAt >= twoWeeksAgo && row.submittedAt < weekAgo)
    .map((row) => row.topicId)
    .filter((topicId): topicId is string => Boolean(topicId))
).size;

const totalTestsAttempted = submittedAttemptRows.length;
const testsThisWeek = submittedAttemptRows.filter((attempt) => attempt.submittedAt && attempt.submittedAt >= weekAgo).length;
const testsPreviousWeek = submittedAttemptRows.filter(
  (attempt) => attempt.submittedAt && attempt.submittedAt >= twoWeeksAgo && attempt.submittedAt < weekAgo
).length;

function averagePercent(
  attempts: Array<{ score: number | null; totalQuestions: number | null; submittedAt?: Date | null }>
) {
  if (attempts.length === 0) {
    return 0;
  }

  const total = attempts.reduce((sum, attempt) => {
    const totalQuestions = attempt.totalQuestions ?? 0;
    const score = attempt.score ?? 0;
    return totalQuestions > 0 ? sum + (score / totalQuestions) * 100 : sum;
  }, 0);

  return Math.round(total / attempts.length);
}

const averageScore = averagePercent(submittedAttemptRows);
const averageScoreThisWeek = averagePercent(
  submittedAttemptRows.filter((attempt) => attempt.submittedAt && attempt.submittedAt >= weekAgo)
);
const averageScorePreviousWeek = averagePercent(
  submittedAttemptRows.filter((attempt) => attempt.submittedAt && attempt.submittedAt >= twoWeeksAgo && attempt.submittedAt < weekAgo)
);

const distinctAttemptDays = Array.from(
  new Set(
    submittedAttemptRows
      .map((attempt) => attempt.submittedAt)
      .filter((submittedAt): submittedAt is Date => Boolean(submittedAt))
      .map((submittedAt) => submittedAt.toISOString().slice(0, 10))
  )
)
  .sort()
  .reverse();

let streakDays = 0;
let previousDay: Date | null = null;

for (const dayKey of distinctAttemptDays) {
  const currentDay = new Date(`${dayKey}T00:00:00.000Z`);

  if (!previousDay) {
    streakDays = 1;
    previousDay = currentDay;
    continue;
  }

  const diffDays = Math.round((previousDay.getTime() - currentDay.getTime()) / dayMs);

  if (diffDays === 1) {
    streakDays += 1;
    previousDay = currentDay;
    continue;
  }

  break;
}

const streakThisWeek = distinctAttemptDays.filter((dayKey) => new Date(`${dayKey}T00:00:00.000Z`) >= weekAgo).length;

const subjectStyles = {
  physics: {
    gradient: 'linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%)',
    border: '#BFDBFE',
    iconBg: '#3B82F6',
    text: '#1E3A8A',
    meta: '#3B82F6',
    progress: '#3B82F6',
    button: '#3B82F6',
  },
  chemistry: {
    gradient: 'linear-gradient(135deg, #F0FDF4 0%, #DCFCE7 100%)',
    border: '#BBF7D0',
    iconBg: '#10B981',
    text: '#14532D',
    meta: '#059669',
    progress: '#10B981',
    button: '#10B981',
  },
  biology: {
    gradient: 'linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%)',
    border: '#FDE68A',
    iconBg: '#F59E0B',
    text: '#78350F',
    meta: '#D97706',
    progress: '#F59E0B',
    button: '#F59E0B',
  },
  default: {
    gradient: 'linear-gradient(135deg, #F8F9FF 0%, #EEF2FF 100%)',
    border: '#D6DBFF',
    iconBg: '#2D3A6B',
    text: '#1A2544',
    meta: '#2D3A6B',
    progress: '#2D3A6B',
    button: '#0A0F1E',
  },
} as const;

const preferredSubjectOrder = ['physics', 'chemistry', 'biology'];

const subjectCards = allSubjects
  .map((subject) => {
    const key = subject.name.toLowerCase() as keyof typeof subjectStyles;
    const style = subjectStyles[key] ?? subjectStyles.default;
    const totalTopics = subjectTopicCounts.get(subject.id) ?? 0;
    const attemptedTopics = subjectAttemptedTopics.get(subject.id)?.size ?? 0;
    const totalTests = subjectTestCounts.get(subject.id) ?? 0;
    const progress = totalTopics > 0 ? Math.round((attemptedTopics / totalTopics) * 100) : 0;

    return {
      ...subject,
      style,
      key,
      totalTopics,
      totalTests,
      progress,
    };
  })
  .sort((a, b) => {
    const aIndex = preferredSubjectOrder.indexOf(a.name.toLowerCase());
    const bIndex = preferredSubjectOrder.indexOf(b.name.toLowerCase());
    const safeA = aIndex === -1 ? preferredSubjectOrder.length : aIndex;
    const safeB = bIndex === -1 ? preferredSubjectOrder.length : bIndex;
    return safeA - safeB;
  })
  .slice(0, 3);

const recentActivity = recentAttempts.map((attempt) => {
  const totalQuestions = attempt.totalQuestions ?? 0;
  const score = attempt.score ?? 0;
  const percent = totalQuestions > 0 ? Math.round((score / totalQuestions) * 100) : 0;

  return {
    ...attempt,
    percent,
  };
});

const scoreBadgeClass = (percent: number) => {
  if (percent >= 70) return 'score-pill score-pill--good';
  if (percent >= 40) return 'score-pill score-pill--mid';
  return 'score-pill score-pill--low';
};

const testsTrend =
  testsThisWeek > testsPreviousWeek
    ? `+${testsThisWeek - testsPreviousWeek} this week`
    : testsThisWeek === testsPreviousWeek
      ? 'same as last week'
      : `${testsPreviousWeek - testsThisWeek} fewer than last week`;

const averageTrend =
  averageScoreThisWeek > averageScorePreviousWeek
    ? `+${averageScoreThisWeek - averageScorePreviousWeek}% vs last week`
    : averageScoreThisWeek === averageScorePreviousWeek
      ? 'same as last week'
      : `${averageScorePreviousWeek - averageScoreThisWeek}% below last week`;

const streakTrend = streakDays > 0 ? `${streakThisWeek} active days this week` : 'start your streak today';

const topicsTrend =
  topicsCoveredThisWeek > topicsCoveredPreviousWeek
    ? `+${topicsCoveredThisWeek - topicsCoveredPreviousWeek} new this week`
    : topicsCoveredThisWeek === topicsCoveredPreviousWeek
      ? 'same as last week'
      : `${topicsCoveredPreviousWeek - topicsCoveredThisWeek} fewer than last week`;

const firstSubjectLink = subjectCards[0] ? `/student/subjects/${subjectCards[0].id}` : '/student';
---

<Base title="Student Dashboard | Dream Neet Academy">
  <div class="dashboard-shell">
    <aside class="sidebar">
      <div class="sidebar__inner">
        <div class="sidebar__top">
          <a href="/student" class="brand">
            <img src="/images/logo.jpeg" alt="Dream Neet Academy logo" class="brand__logo" />
            <span class="brand__text">Dream Neet Academy</span>
          </a>

          <div class="student-card">
            <div class="student-card__avatar">{initials}</div>
            <div class="student-card__meta">
              <div class="student-card__name">{profile.fullName}</div>
              <span class="student-card__role">Student</span>
            </div>
          </div>

          <div class="sidebar__divider"></div>
        </div>

        <nav class="sidebar__nav" aria-label="Student dashboard">
          <a href="/student" class="sidebar__link sidebar__link--active">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3 10.5 12 3l9 7.5v9a1.5 1.5 0 0 1-1.5 1.5h-5V14h-5v7H4.5A1.5 1.5 0 0 1 3 19.5z"></path>
            </svg>
            Dashboard
          </a>
          <a href="#subjects" class="sidebar__link">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 4.5A2.5 2.5 0 0 1 7.5 2H20v16H7.5A2.5 2.5 0 0 0 5 20.5z"></path>
              <path d="M5 4.5v16"></path>
              <path d="M8.5 7H16"></path>
              <path d="M8.5 11H16"></path>
            </svg>
            Subjects
          </a>
          <a href="/student/analysis" class="sidebar__link">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 19h16"></path>
              <path d="M7 16V9"></path>
              <path d="M12 16V5"></path>
              <path d="M17 16v-4"></path>
            </svg>
            Analysis
          </a>
        </nav>

        <div class="sidebar__bottom">
          <form action="/api/auth/logout" method="POST" class="logout-form">
            <button type="submit" class="logout-btn">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <path d="m16 17 5-5-5-5"></path>
                <path d="M21 12H9"></path>
              </svg>
              Logout
            </button>
          </form>
        </div>
      </div>
    </aside>

    <main class="dashboard-main">
      <section class="welcome-strip">
        <div>
          <h1 class="welcome-strip__title">Good morning, {firstName}! 👋</h1>
          <p class="welcome-strip__meta">{welcomeDate} · NEET preparation</p>
        </div>

        <div class="streak-card">
          <div class="streak-card__emoji">🔥</div>
          <div>
            <p class="streak-card__value">{streakDays} day streak</p>
            <p class="streak-card__note">Keep it up!</p>
          </div>
        </div>
      </section>

      <section class="stats-grid" aria-label="Study overview">
        <article class="stat-card">
          <div class="stat-card__top">
            <span class="stat-card__icon stat-card__icon--blue">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 19h16"></path>
                <path d="M7 16V9"></path>
                <path d="M12 16V5"></path>
                <path d="M17 16v-4"></path>
              </svg>
            </span>
            <div>
              <div class="stat-card__value">{totalTestsAttempted}</div>
              <div class="stat-card__label">Tests Attempted</div>
            </div>
          </div>
          <p class:list={['stat-card__trend', { 'stat-card__trend--up': testsThisWeek > testsPreviousWeek }]}>
            {testsTrend}
          </p>
        </article>

        <article class="stat-card">
          <div class="stat-card__top">
            <span class="stat-card__icon stat-card__icon--yellow">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 3v18"></path>
                <path d="M7 8.5c0-1.7 2.2-3 5-3s5 1.3 5 3-2.2 3-5 3-5 1.3-5 3 2.2 3 5 3 5-1.3 5-3"></path>
              </svg>
            </span>
            <div>
              <div class="stat-card__value">{averageScore}%</div>
              <div class="stat-card__label">Avg Score</div>
            </div>
          </div>
          <p class:list={['stat-card__trend', { 'stat-card__trend--up': averageScoreThisWeek > averageScorePreviousWeek }]}>
            {averageTrend}
          </p>
        </article>

        <article class="stat-card">
          <div class="stat-card__top">
            <span class="stat-card__icon stat-card__icon--orange">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 3c.7 2.8 3 4.9 5.8 5.6-.9 4.8-4.7 8.6-9.5 9.5C7.6 15.3 9.7 13 12.5 12 13 8.8 10.7 6 7.5 5.5A8.9 8.9 0 0 1 12 3z"></path>
              </svg>
            </span>
            <div>
              <div class="stat-card__value">{streakDays}</div>
              <div class="stat-card__label">Study Streak</div>
            </div>
          </div>
          <p class:list={['stat-card__trend', { 'stat-card__trend--up': streakDays > 0 }]}>
            {streakTrend}
          </p>
        </article>

        <article class="stat-card">
          <div class="stat-card__top">
            <span class="stat-card__icon stat-card__icon--green">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 4.5A2.5 2.5 0 0 1 7.5 2H20v16H7.5A2.5 2.5 0 0 0 5 20.5z"></path>
                <path d="M5 4.5v16"></path>
                <path d="M8.5 7H16"></path>
                <path d="M8.5 11H16"></path>
              </svg>
            </span>
            <div>
              <div class="stat-card__value">{topicsCovered}</div>
              <div class="stat-card__label">Topics Covered</div>
            </div>
          </div>
          <p class:list={['stat-card__trend', { 'stat-card__trend--up': topicsCoveredThisWeek > topicsCoveredPreviousWeek }]}>
            {topicsTrend}
          </p>
        </article>
      </section>

      <section id="subjects" class="subjects-section">
        <div class="section-heading">
          <h2>Continue Learning</h2>
          <a href="#subjects">View all →</a>
        </div>

        {subjectCards.length ? (
          <div class="subjects-grid">
            {subjectCards.map((subject) => (
              <article
                class="subject-card"
                style={`background:${subject.style.gradient}; border-color:${subject.style.border};`}
              >
                <div class="subject-card__top">
                  <span class="subject-card__icon" style={`background:${subject.style.iconBg};`}>
                    {
                      subject.name.toLowerCase() === 'physics' ? (
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                          <circle cx="12" cy="12" r="1.4"></circle>
                          <path d="M4 12c2.1-3.6 5-5.5 8-5.5s5.9 1.9 8 5.5c-2.1 3.6-5 5.5-8 5.5S6.1 15.6 4 12z"></path>
                          <path d="M7.2 5.7c4.2.1 7.5 1.6 9 4.2 1.5 2.6 1 6.1-1 9.7-4.2-.1-7.5-1.6-9-4.2-1.5-2.6-1-6.1 1-9.7z"></path>
                          <path d="M7.2 18.3c-.1-4.2 1.4-7.6 4-9.1 2.6-1.5 6.1-1.1 9.8.8.1 4.2-1.4 7.6-4 9.1-2.6 1.5-6.1 1.1-9.8-.8z"></path>
                        </svg>
                      ) : subject.name.toLowerCase() === 'chemistry' ? (
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M10 3v5l-4.8 8.3A3 3 0 0 0 7.8 21h8.4a3 3 0 0 0 2.6-4.7L14 8V3"></path>
                          <path d="M9 8h6"></path>
                          <path d="M8.5 15h7"></path>
                        </svg>
                      ) : (
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M12 21s-6.5-4.2-6.5-10.3A4.7 4.7 0 0 1 10.2 6c1 .1 1.8.6 1.8.6s.8-.5 1.8-.6a4.7 4.7 0 0 1 4.7 4.7C18.5 16.8 12 21 12 21z"></path>
                        </svg>
                      )
                    }
                  </span>
                  <span class="subject-card__badge" style={`color:${subject.style.meta};`}>
                    {subject.progress}% done
                  </span>
                </div>

                <h3 class="subject-card__title" style={`color:${subject.style.text};`}>{subject.name}</h3>
                <p class="subject-card__meta" style={`color:${subject.style.meta};`}>
                  {subject.totalTopics} topics · {subject.totalTests} tests
                </p>

                <div class="subject-card__progress">
                  <span
                    class="subject-card__progress-fill"
                    style={`width:${subject.progress}%; background:${subject.style.progress};`}
                  ></span>
                </div>

                <a
                  href={`/student/subjects/${subject.id}`}
                  class="subject-card__cta"
                  style={`background:${subject.style.button};`}
                >
                  Continue →
                </a>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty-card">
            No subjects available yet. Your study dashboard will light up here once content is added.
          </div>
        )}
      </section>

      <section class="bottom-grid">
        <article class="table-card">
          <div class="table-card__header">
            <h2>Recent Tests</h2>
            <a href="/student/analysis">View all</a>
          </div>

          {recentActivity.length ? (
            <div class="table-wrap">
              <table class="activity-table">
                <thead>
                  <tr>
                    <th scope="col">Test</th>
                    <th scope="col">Score</th>
                    <th scope="col">Date</th>
                    <th scope="col">Action</th>
                  </tr>
                </thead>
                <tbody>
                  {recentActivity.map((attempt) => (
                    <tr>
                      <td>
                        <div class="activity-table__test">{attempt.testTitle}</div>
                      </td>
                      <td>
                        <span class={scoreBadgeClass(attempt.percent)}>{attempt.percent}%</span>
                      </td>
                      <td>{attempt.submittedAt ? tableDateFormatter.format(attempt.submittedAt) : '-'}</td>
                      <td>
                        <a href={`/student/attempts/${attempt.id}`} class="review-link">Review →</a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="table-card__empty">No tests attempted yet — pick a subject above</div>
          )}
        </article>

        <aside class="quick-card">
          <p class="quick-card__eyebrow">Quick Actions</p>

          <a href={firstSubjectLink} class="quick-card__item">
            <span class="quick-card__icon">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M8 4h8l4 4v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"></path>
                <path d="M8 12h8"></path>
                <path d="M12 8v8"></path>
              </svg>
            </span>
            <span class="quick-card__text">
              <strong>Take a Practice Test</strong>
              <small>Choose from 200+ tests</small>
            </span>
            <span class="quick-card__arrow">→</span>
          </a>

          <a href="/student/analysis" class="quick-card__item">
            <span class="quick-card__icon">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 19h16"></path>
                <path d="M7 16V9"></path>
                <path d="M12 16V5"></path>
                <path d="M17 16v-4"></path>
              </svg>
            </span>
            <span class="quick-card__text">
              <strong>View Analysis</strong>
              <small>See your strengths & weaknesses</small>
            </span>
            <span class="quick-card__arrow">→</span>
          </a>

          <a href={firstSubjectLink} class="quick-card__item">
            <span class="quick-card__icon">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 4.5A2.5 2.5 0 0 1 7.5 2H20v16H7.5A2.5 2.5 0 0 0 5 20.5z"></path>
                <path d="M5 4.5v16"></path>
                <path d="M8.5 7H16"></path>
                <path d="M8.5 11H16"></path>
              </svg>
            </span>
            <span class="quick-card__text">
              <strong>Study Videos</strong>
              <small>Watch topic-wise explanations</small>
            </span>
            <span class="quick-card__arrow">→</span>
          </a>
        </aside>
      </section>
    </main>
  </div>
</Base>

<style>
  :global(body) {
    margin: 0;
    min-height: 100vh;
    padding-top: 0;
    background: #f8f9ff;
    color: #0a0f1e;
  }

  :global(main > section) {
    content-visibility: visible;
    contain-intrinsic-size: auto;
  }

  .dashboard-shell {
    min-height: 100vh;
    background: #f8f9ff;
  }

  .sidebar {
    position: fixed;
    inset: 0 auto 0 0;
    width: 240px;
    background: #0a0f1e;
    padding: 24px 0;
    z-index: 10;
  }

  .sidebar__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .sidebar__top {
    padding: 0 20px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 32px;
  }

  .brand__logo {
    width: 36px;
    height: 36px;
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid rgba(255, 255, 255, 0.08);
