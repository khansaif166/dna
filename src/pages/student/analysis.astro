---
export const prerender = false;

import { and, count, eq, isNotNull } from 'drizzle-orm';

import AnalyticsChart from '../../components/AnalyticsChart';
import PlatformLayout from '../../layouts/PlatformLayout.astro';
import { db, testAttempts } from '../../db';
import { requireAuth } from '../../lib/auth';
import {
  getRecentAttempts,
  getSubjectAccuracy,
  getWeakAndStrongTopics,
} from '../../lib/analytics';

const authResult = await requireAuth(Astro, 'student');

if (authResult instanceof Response) {
  return authResult;
}

const profile = authResult;

const [subjectAccuracy, recentAttempts, topicBuckets, attemptCountRows] = await Promise.all([
  getSubjectAccuracy(profile.id),
  getRecentAttempts(profile.id),
  getWeakAndStrongTopics(profile.id),
  db
    .select({ value: count() })
    .from(testAttempts)
    .where(and(eq(testAttempts.studentId, profile.id), isNotNull(testAttempts.submittedAt))),
]);

const { strong, weak } = topicBuckets;
const totalAttempts = attemptCountRows[0]?.value ?? recentAttempts.length;

const dateFormatter = new Intl.DateTimeFormat('en-IN', {
  dateStyle: 'medium',
  timeStyle: 'short',
});

function subjectTone(percent: number) {
  if (percent >= 70) {
    return {
      text: '#065F46',
      fill: 'linear-gradient(90deg, #10B981, #059669)',
    };
  }

  if (percent >= 40) {
    return {
      text: '#92400E',
      fill: 'linear-gradient(90deg, #F59E0B, #D97706)',
    };
  }

  return {
    text: '#991B1B',
    fill: 'linear-gradient(90deg, #EF4444, #DC2626)',
  };
}
---

<PlatformLayout title="Performance Analysis | Dream Neet Academy">
  <section class="analysis-hero">
    <div class="analysis-hero__inner">
      <h1 class="heading-xl">Your Performance Analysis</h1>
      <p>Based on {totalAttempts} total attempts</p>
    </div>
  </section>

  <div class="analysis-page">
    <section class="subject-cards-section">
      {subjectAccuracy.length ? (
        <div class="subject-cards-grid">
          {subjectAccuracy.map((row) => {
            const tone = subjectTone(row.percent);

            return (
              <article class="card subject-card">
                <div class="subject-card__header">
                  <h2 class="heading-md">{row.subjectName}</h2>
                  <strong style={`color: ${tone.text};`}>{row.percent}%</strong>
                </div>
                <div class="subject-card__track" aria-hidden="true">
                  <span class="subject-card__fill" style={`width: ${row.percent}%; background: ${tone.fill};`}></span>
                </div>
                <p class="text-muted">{row.correct} correct out of {row.total} questions</p>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="card empty-card">
          <p class="text-muted">No submitted attempts yet, so there is nothing to analyze.</p>
        </div>
      )}
    </section>

    <section class="card chart-card">
      <h2 class="heading-md">Subject-wise Accuracy</h2>
      <AnalyticsChart
        client:load
        data={subjectAccuracy.map((row) => ({
          subjectName: row.subjectName,
          percent: row.percent,
        }))}
      />
    </section>

    <section class="topics-grid">
      <article class="card topic-card topic-card--strong">
        <h2 class="heading-md topic-card__heading topic-card__heading--strong">💪 Strong Topics</h2>

        {strong.length ? (
          <div>
            {strong.map((topic) => (
              <div class="topic-row">
                <span class="topic-row__name">{topic.topicName}</span>
                <div class="topic-row__metric">
                  <span class="badge-success">{topic.percent}%</span>
                  <span class="mini-track" aria-hidden="true">
                    <span class="mini-fill mini-fill--strong" style={`width: ${topic.percent}%;`}></span>
                  </span>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p class="text-muted">Keep practicing to identify strengths!</p>
        )}
      </article>

      <article class="card topic-card topic-card--weak">
        <h2 class="heading-md topic-card__heading topic-card__heading--weak">📈 Needs Work</h2>

        {weak.length ? (
          <div>
            {weak.map((topic) => (
              <div class="topic-row">
                <span class="topic-row__name">{topic.topicName}</span>
                <div class="topic-row__metric">
                  <span class="weak-badge">{topic.percent}%</span>
                  <span class="mini-track" aria-hidden="true">
                    <span class="mini-fill mini-fill--weak" style={`width: ${topic.percent}%;`}></span>
                  </span>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p class="text-muted">Great job! No weak areas found.</p>
        )}
      </article>
    </section>

    <section class="card table-card">
      <div class="section-head">
        <h2 class="heading-md">Recent Attempts</h2>
      </div>

      {recentAttempts.length ? (
        <div class="table-wrap">
          <table class="activity-table">
            <thead>
              <tr>
                <th scope="col">Test Name</th>
                <th scope="col">Score</th>
                <th scope="col">Percent</th>
                <th scope="col">Submitted</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody>
              {recentAttempts.map((attempt) => (
                <tr>
                  <td>{attempt.testTitle}</td>
                  <td>{attempt.score}/{attempt.total}</td>
                  <td>{attempt.percent}%</td>
                  <td>{dateFormatter.format(attempt.submittedAt)}</td>
                  <td>
                    <a href={`/student/attempts/${attempt.attemptId}`} class="view-link">View</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <p class="text-muted">No submitted attempts yet.</p>
      )}
    </section>
  </div>
</PlatformLayout>

<style>
  .analysis-hero {
    background: var(--color-navy);
    padding: 40px 16px;
  }

  .analysis-hero__inner,
  .analysis-page {
    margin: 0 auto;
    max-width: 64rem;
  }

  .heading-xl,
  .heading-md {
    margin: 0;
  }

  .heading-xl {
    color: var(--color-surface);
    font-size: clamp(2rem, 3vw, 2.75rem);
    font-weight: 800;
  }

  .heading-md {
    color: var(--color-navy);
    font-size: 1.25rem;
    font-weight: 700;
  }

  .analysis-hero p {
    color: rgba(255, 255, 255, 0.6);
    margin: 0.5rem 0 0;
  }

  .analysis-page {
    padding: 2rem 1rem 3.5rem;
  }

  .subject-cards-section,
  .chart-card,
  .topics-grid,
  .table-card {
    margin-bottom: 1.75rem;
  }

  .subject-cards-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .subject-card {
    display: grid;
    gap: 0.9rem;
  }

  .subject-card__header {
    align-items: start;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
  }

  .subject-card__header strong {
    font-size: 1.7rem;
    font-weight: 800;
    line-height: 1;
  }

  .subject-card__track {
    background: var(--color-border);
    border-radius: 999px;
    height: 8px;
    overflow: hidden;
  }

  .subject-card__fill {
    border-radius: 999px;
    display: block;
    height: 100%;
  }

  .text-muted {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  .chart-card .heading-md {
    margin-bottom: 20px;
  }

  .topics-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .topic-card--strong {
    background: #f0fdf4;
  }

  .topic-card--weak {
    background: #fef2f2;
  }

  .topic-card__heading {
    margin-bottom: 16px;
  }

  .topic-card__heading--strong {
    color: #065f46;
  }

  .topic-card__heading--weak {
    color: #991b1b;
  }

  .topic-row {
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    padding: 10px 0;
  }

  .topic-row:last-child {
    border-bottom: none;
  }

  .topic-row__name {
    color: var(--color-text);
    font-weight: 500;
  }

  .topic-row__metric {
    align-items: center;
    display: flex;
    gap: 0.75rem;
  }

  .mini-track {
    background: rgba(148, 163, 184, 0.2);
    border-radius: 999px;
    display: inline-flex;
    height: 4px;
    overflow: hidden;
    width: 60px;
  }

  .mini-fill {
    border-radius: 999px;
    display: block;
    height: 100%;
  }

  .mini-fill--strong {
    background: linear-gradient(90deg, #10b981, #059669);
  }

  .mini-fill--weak {
    background: linear-gradient(90deg, #ef4444, #dc2626);
  }

  .weak-badge {
    align-items: center;
    background: #fee2e2;
    border-radius: 999px;
    color: #991b1b;
    display: inline-flex;
    font-size: 0.75rem;
    font-weight: 600;
    justify-content: center;
    padding: 3px 10px;
  }

  .section-head {
    margin-bottom: 0.5rem;
  }

  .table-wrap {
    overflow-x: auto;
  }

  .activity-table {
    border-collapse: collapse;
    width: 100%;
  }

  .activity-table th {
    background: #f8f9ff;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 14px 16px;
    text-align: left;
    text-transform: uppercase;
  }

  .activity-table td {
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    padding: 14px 16px;
    vertical-align: middle;
  }

  .activity-table tbody tr:last-child td {
    border-bottom: none;
  }

  .activity-table td:first-child {
    color: var(--color-navy);
    font-weight: 600;
  }

  .view-link {
    color: var(--color-navy);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .empty-card {
    text-align: center;
  }

  @media (max-width: 920px) {
    .subject-cards-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .topics-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .subject-cards-grid {
      grid-template-columns: 1fr;
    }

    .activity-table {
      min-width: 680px;
    }

    .subject-card__header,
    .topic-row {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
