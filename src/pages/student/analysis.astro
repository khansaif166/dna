---
export const prerender = false;

import { and, count, eq, isNotNull, sql } from 'drizzle-orm';

import AnalyticsChart from '../../components/AnalyticsChart';
import StudentLayout from '../../layouts/StudentLayout.astro';
import { db, testAttempts } from '../../db';
import { requireAuth } from '../../lib/auth';
import { getMasterySummary, getRecentAttempts, getSubjectAccuracy, getWeakAndStrongTopics } from '../../lib/analytics';

const authResult = await requireAuth(Astro, 'student');

if (authResult instanceof Response) {
  return authResult;
}

const profile = authResult;

const [subjectAccuracy, recentAttempts, topicBuckets, masterySummary, attemptCountRows] = await Promise.all([
  getSubjectAccuracy(profile.id),
  getRecentAttempts(profile.id),
  getWeakAndStrongTopics(profile.id),
  getMasterySummary(profile.id),
  db
    .select({
      value: count(),
      correct: sql<number>`coalesce(sum(${testAttempts.score}), 0)::int`,
      total: sql<number>`coalesce(sum(${testAttempts.totalQuestions}), 0)::int`,
    })
    .from(testAttempts)
    .where(and(eq(testAttempts.studentId, profile.id), isNotNull(testAttempts.submittedAt))),
]);

const { strong, weak } = topicBuckets;
const totalAttempts = attemptCountRows[0]?.value ?? recentAttempts.length;
const totalCorrect = attemptCountRows[0]?.correct ?? 0;
const totalQuestions = attemptCountRows[0]?.total ?? 0;
const {
  masteryPercent,
  earnedPoints,
  totalPoints,
  totalTopics,
  levelCounts: masteryLevelCounts,
} = masterySummary;

const bestSubject =
  subjectAccuracy.length > 0
    ? [...subjectAccuracy].sort((a, b) => b.percent - a.percent)[0]
    : null;

const weakestSubject =
  subjectAccuracy.length > 0
    ? [...subjectAccuracy].sort((a, b) => a.percent - b.percent)[0]
    : null;

const chartData = subjectAccuracy.map((row) => ({
  subjectName: row.subjectName,
  percent: row.percent,
  correct: row.correct,
  total: row.total,
}));

const relativeDate = (date: Date) => {
  const diffDays = Math.floor((Date.now() - date.getTime()) / (24 * 60 * 60 * 1000));
  if (diffDays <= 0) return 'Today';
  if (diffDays === 1) return '1 day ago';
  if (diffDays < 7) return `${diffDays} days ago`;

  return new Intl.DateTimeFormat('en-IN', {
    day: 'numeric',
    month: 'short',
  }).format(date);
};

function thresholdColor(percent: number) {
  if (percent >= 70) return '#10B981';
  if (percent >= 40) return '#F59E0B';
  return '#EF4444';
}

function subjectPill(subjectName: string) {
  const key = subjectName.toLowerCase();

  if (key.includes('physics')) {
    return {
      bg: '#EFF6FF',
      text: '#1D4ED8',
      fill: 'linear-gradient(90deg, #3B82F6, #1D4ED8)',
    };
  }

  if (key.includes('chemistry')) {
    return {
      bg: '#F0FDF4',
      text: '#059669',
      fill: 'linear-gradient(90deg, #10B981, #059669)',
    };
  }

  return {
    bg: '#FFFBEB',
    text: '#D97706',
    fill: 'linear-gradient(90deg, #F59E0B, #D97706)',
  };
}
---

<StudentLayout title="Performance Analysis | Dream Neet Academy" fullName={profile.fullName} activeNav="analysis">
  <div class="mobile-page-header">
    <div class="mobile-breadcrumb">
      <span>Student</span>
      <span>/</span>
      <span>Analysis</span>
    </div>
    <div class="mobile-page-title">Performance Analysis</div>
    <div class="mobile-page-subtitle">Based on {totalAttempts} test attempts</div>
  </div>
  <section class="page-header">
    <div>
      <h1 class="page-title">Performance Analysis</h1>
      <p class="page-subtitle">Based on {totalAttempts} test attempts · Updated just now</p>
    </div>

    <div class="range-pill">All time ▾</div>
  </section>

  <section class="stats-grid">
    <article class="hero-stat">
      <div class="hero-stat__label">Mastery Progress</div>
      <div class="hero-stat__value">{masteryPercent}%</div>
      <div class="hero-stat__sub">{earnedPoints} of {totalPoints} mastery points across {totalTopics} topics</div>
      <div class="hero-stat__meta">
        <span>{masteryLevelCounts.proficient} proficient</span>
        <span>{masteryLevelCounts.familiar} familiar</span>
        <span>{masteryLevelCounts.attempted} attempted</span>
      </div>
      <div class="hero-stat__bar">
        <span class="hero-stat__fill" style={`width:${masteryPercent}%;`}></span>
      </div>
    </article>

    <article class="mini-stat">
      <span class="mini-stat__icon mini-stat__icon--blue">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <path d="M14 2v6h6"></path>
          <path d="M8 13h8"></path>
          <path d="M8 17h5"></path>
        </svg>
      </span>
      <div class="mini-stat__value">{totalAttempts}</div>
      <div class="mini-stat__label">Tests Attempted</div>
      <div class="mini-stat__sub">{totalCorrect} correct out of {totalQuestions} questions</div>
    </article>

    <article class="mini-stat">
      <span class="mini-stat__icon mini-stat__icon--green">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 17 6.1 20l1.1-6.4L2.5 9l6.5-.9L12 2.5l3 5.6 6.5.9-4.7 4.6 1.1 6.4z"></path>
        </svg>
      </span>
      <div class="mini-stat__text-value">{bestSubject?.subjectName ?? 'Not enough data'}</div>
      <div class="mini-stat__label">Best Subject</div>
      <div class="mini-stat__sub mini-stat__sub--green">{bestSubject ? `${bestSubject.percent}% accuracy` : 'Take more tests'}</div>
    </article>

    <article class="mini-stat">
      <span class="mini-stat__icon mini-stat__icon--amber">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="8"></circle>
          <circle cx="12" cy="12" r="3"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.9 4.9 1.4 1.4"></path>
          <path d="m17.7 17.7 1.4 1.4"></path>
        </svg>
      </span>
      <div class="mini-stat__text-value">{weakestSubject?.subjectName ?? 'Not enough data'}</div>
      <div class="mini-stat__label">Focus Area</div>
      <div class="mini-stat__sub mini-stat__sub--amber">{weakestSubject ? `${weakestSubject.percent}% accuracy` : 'Take more tests'}</div>
    </article>
  </section>

  <section class="subject-layout">
    <article class="chart-card">
      <div class="chart-card__head">
        <h2>Subject-wise Accuracy</h2>
        <p>Percentage of correct answers per subject</p>
      </div>

      <AnalyticsChart client:load data={chartData} />

      <div class="chart-legend">
        <span class="legend-chip"><i class="legend-dot legend-dot--green"></i>Strong (≥70%)</span>
        <span class="legend-chip"><i class="legend-dot legend-dot--amber"></i>Average (40-69%)</span>
        <span class="legend-chip"><i class="legend-dot legend-dot--red"></i>Needs Work (&lt;40%)</span>
      </div>
    </article>

    <aside class="breakdown-card">
      <h2>Breakdown</h2>

      {subjectAccuracy.length ? (
        <div>
          {subjectAccuracy.map((row) => {
            const colors = subjectPill(row.subjectName);
            return (
              <div class="subject-row">
                <div class="subject-row__top">
                  <span>{row.subjectName}</span>
                  <strong style={`color:${thresholdColor(row.percent)};`}>{row.percent}%</strong>
                </div>
                <div class="subject-row__bar">
                  <span class="subject-row__fill" style={`width:${row.percent}%; background:${colors.fill};`}></span>
                </div>
                <div class="subject-row__meta">
                  <span>{row.correct} correct</span>
                  <span>out of {row.total}</span>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="empty-inline">Take a few tests to unlock your subject breakdown.</div>
      )}
    </aside>
  </section>

  <section class="topics-grid">
    <article class="topics-card topics-card--strong">
      <div class="topics-card__head topics-card__head--strong">
        <h2>💪 Strong Topics</h2>
        <span>{strong.length} topics</span>
      </div>

      {strong.length ? (
        <div>
          {strong.map((topic) => {
            const colors = subjectPill(topic.subjectName);
            return (
              <div class="topic-row topic-row--strong">
                <div>
                  <div class="topic-row__name">{topic.topicName}</div>
                  <span class="subject-pill" style={`background:${colors.bg}; color:${colors.text};`}>
                    {topic.subjectName}
                  </span>
                </div>
                <div class="topic-row__right">
                  <strong>{topic.percent}%</strong>
                  <div class="mini-bar mini-bar--strong">
                    <span style={`width:${topic.percent}%;`}></span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="topics-empty">
          <div class="topics-empty__icon">🎯</div>
          <div class="topics-empty__title">Keep practicing!</div>
          <div class="topics-empty__text">Answer 5+ questions per topic to see your strengths</div>
        </div>
      )}
    </article>

    <article class="topics-card topics-card--weak">
      <div class="topics-card__head topics-card__head--weak">
        <h2>📈 Needs Work</h2>
        <span>{weak.length} topics</span>
      </div>

      {weak.length ? (
        <div>
          {weak.map((topic) => {
            const colors = subjectPill(topic.subjectName);
            return (
              <div class="topic-row topic-row--weak">
                <div>
                  <div class="topic-row__name">{topic.topicName}</div>
                  <span class="subject-pill" style={`background:${colors.bg}; color:${colors.text};`}>
                    {topic.subjectName}
                  </span>
                </div>
                <div class="topic-row__right">
                  <strong>{topic.percent}%</strong>
                  <div class="mini-bar mini-bar--weak">
                    <span style={`width:${topic.percent}%;`}></span>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="topics-empty">
          <div class="topics-empty__title">Great work! No weak areas detected 🎉</div>
        </div>
      )}
    </article>
  </section>

  <section class="table-card">
    <div class="table-card__head">
      <h2>Recent Test Attempts</h2>
      <a href="/student">View all</a>
    </div>

    {recentAttempts.length ? (
      <div class="table-wrap">
        <table class="attempt-table">
          <thead>
            <tr>
              <th scope="col">Test Name</th>
              <th scope="col">Subject</th>
              <th scope="col">Score</th>
              <th scope="col">Accuracy</th>
              <th scope="col">Date</th>
              <th scope="col">Action</th>
            </tr>
          </thead>
          <tbody>
            {recentAttempts.map((attempt) => {
              const colors = subjectPill(attempt.subjectName);
              return (
                <tr>
                  <td>
                    <div class="attempt-title">{attempt.testTitle}</div>
                  </td>
                  <td>
                    <span class="subject-pill" style={`background:${colors.bg}; color:${colors.text};`}>
                      {attempt.subjectName}
                    </span>
                  </td>
                  <td class="score-cell">{attempt.score}/{attempt.total}</td>
                  <td>
                    <span
                      class:list={[
                        'accuracy-pill',
                        attempt.percent >= 70
                          ? 'accuracy-pill--good'
                          : attempt.percent >= 40
                            ? 'accuracy-pill--mid'
                            : 'accuracy-pill--low',
                      ]}
                    >
                      {attempt.percent}%
                    </span>
                  </td>
                  <td class="date-cell">{relativeDate(attempt.submittedAt)}</td>
                  <td>
                    <a href={`/student/attempts/${attempt.attemptId}`} class="review-link">Review →</a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="table-empty">
        <div class="table-empty__icon">📝</div>
        <div class="table-empty__title">No test attempts yet</div>
        <div class="table-empty__text">Take your first test to see results here</div>
      </div>
    )}
  </section>
</StudentLayout>

