---
interface Props {
  activePage?: 'dashboard' | 'subjects' | 'analysis' | 'profile';
}

const { activePage = 'dashboard' } = Astro.props;

const items = [
  {
    key: 'dashboard',
    label: 'Home',
    href: '/student',
    icon: 'home',
  },
  {
    key: 'subjects',
    label: 'Subjects',
    href: '/student#subjects',
    icon: 'book',
  },
  {
    key: 'analysis',
    label: 'Analysis',
    href: '/student/analysis',
    icon: 'chart',
  },
  {
    key: 'profile',
    label: 'Profile',
    href: '/student/profile',
    icon: 'user',
  },
] as const;
---

<nav class="mobile-nav" aria-label="Student mobile navigation">
  {items.map((item) => (
    <a href={item.href} class:list={['mobile-nav__tab', { 'mobile-nav__tab--active': activePage === item.key }]}>
      <span class="mobile-nav__indicator" aria-hidden="true"></span>
      <span class="mobile-nav__icon" aria-hidden="true">
        {
          item.icon === 'home' ? (
            <svg viewBox="0 0 24 24">
              <path d="M3 10.5 12 3l9 7.5v9a1.5 1.5 0 0 1-1.5 1.5h-5V14h-5v7H4.5A1.5 1.5 0 0 1 3 19.5z"></path>
            </svg>
          ) : item.icon === 'book' ? (
            <svg viewBox="0 0 24 24">
              <path d="M5 4.5A2.5 2.5 0 0 1 7.5 2H20v16H7.5A2.5 2.5 0 0 0 5 20.5z"></path>
              <path d="M5 4.5v16"></path>
              <path d="M8.5 7H16"></path>
              <path d="M8.5 11H16"></path>
            </svg>
          ) : item.icon === 'chart' ? (
            <svg viewBox="0 0 24 24">
              <path d="M4 19h16"></path>
              <path d="M7 16V9"></path>
              <path d="M12 16V5"></path>
              <path d="M17 16v-4"></path>
            </svg>
          ) : (
            <svg viewBox="0 0 24 24">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          )
        }
      </span>
      <span class="mobile-nav__label">{item.label}</span>
    </a>
  ))}
</nav>

<style>
  .mobile-nav {
    display: none;
  }

  .mobile-nav__tab {
    color: #9aa5b4;
  }

  .mobile-nav__icon svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  @media (max-width: 768px) {
    .mobile-nav {
      position: fixed;
      right: 0;
      bottom: 0;
      left: 0;
      z-index: 100;
      display: flex;
      height: 64px;
      padding-bottom: env(safe-area-inset-bottom);
      background: #fff;
      border-top: 1px solid #e2e8f0;
      box-shadow: 0 -4px 20px rgba(10, 15, 30, 0.08);
    }

    .mobile-nav__tab {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 3px;
      padding: 8px 4px;
      text-decoration: none;
      transition: color 0.15s ease;
      min-height: 64px;
    }

    .mobile-nav__indicator {
      width: 4px;
      height: 4px;
      border-radius: 999px;
      background: transparent;
      margin-bottom: 2px;
    }

    .mobile-nav__label {
      font-size: 0.6rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .mobile-nav__tab--active {
      color: #0a0f1e;
    }

    .mobile-nav__tab--active .mobile-nav__indicator {
      background: #f5c518;
    }
  }
</style>
