---
import { Icon } from 'astro-icon/components';

const cards = [
  {
    icon: 'tabler:user-check',
    title: 'Monitored by Expert Faculties',
    body: 'Physics, Chemistry and Biology mentors keep the study day accountable and focused.',
  },
  {
    icon: 'tabler:clipboard-data',
    title: 'Regular Tests & Analysis',
    body: 'Daily performance tracking helps students fix weak areas before the final exam.',
  },
  {
    icon: 'tabler:list-check',
    title: 'Customized Study Plan',
    body: 'Every student gets a structured plan for making the last 20 days productive.',
  },
  {
    icon: 'tabler:message-question',
    title: 'Doubt Clearance Every Day',
    body: 'Individual attention and doubt support reduce confusion during revision.',
  },
];
---

<section class="program-highlights">
  <div class="program-highlights__inner">
    <div class="program-highlights__math" aria-label="Effective study hours" data-reveal>
      <p>This program is for you</p>
      <div class="program-highlights__equation">
        <span class="program-highlights__term program-highlights__term--days">
          <strong>20</strong>
          <span>Days</span>
        </span>
        <b class="program-highlights__operator" aria-hidden="true">×</b>
        <span class="program-highlights__term program-highlights__term--hours">
          <strong>12</strong>
          <span>Hours/Day</span>
        </span>
        <b class="program-highlights__operator" aria-hidden="true">=</b>
        <span class="program-highlights__term program-highlights__term--result">
          <strong>240</strong>
          <span>Hours</span>
        </span>
      </div>
      <small>of effective and focused study</small>
    </div>

    <div class="program-highlights__intro" data-reveal>
      <p>100% Effective Guided Self-Study</p>
      <h2>Execute the last 20 days with discipline and expert supervision.</h2>
      <span aria-hidden="true"></span>
      <div>
        The offline program is built for students who already know planning is not enough. It creates the routine,
        monitoring and environment needed to convert study time into real output.
      </div>
    </div>

    <div class="program-highlights__cards">
      {cards.map((card, index) => (
        <article class="program-highlights__card" data-reveal style={`--reveal-delay: ${index * 90}ms;`}>
          <div class="program-highlights__icon">
            <Icon name={card.icon} size="22" aria-hidden="true" />
          </div>
          <div>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .program-highlights {
    background: linear-gradient(180deg, #f7f8fb 0%, #eef4ff 100%);
  }

  .program-highlights__inner {
    display: grid;
    grid-template-columns: minmax(360px, 0.82fr) minmax(0, 1.18fr);
    gap: clamp(1.75rem, 4vw, 5rem);
    width: 100%;
    margin: 0 auto;
    padding: var(--section-pad-y) var(--section-pad-x);
  }

  .program-highlights__math {
    display: grid;
    align-content: center;
    border: 1px solid rgba(11, 105, 61, 0.28);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.92);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    box-shadow: var(--shadow-soft);
  }

  .program-highlights__math p {
    width: fit-content;
    margin: 0 0 16px;
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, #0f7a49 0%, #0b693d 100%);
    color: var(--white);
    font-size: 16px;
    font-weight: 900;
    line-height: 1;
    padding: 10px 14px;
    text-transform: uppercase;
  }

  .program-highlights__equation {
    display: grid;
    grid-template-columns: minmax(110px, 0.92fr) 40px minmax(110px, 0.92fr) 40px minmax(150px, 1.18fr);
    align-items: stretch;
    gap: 10px;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, #031846 0%, #06235c 100%);
    color: var(--white);
    padding: clamp(1rem, 2.4vw, 1.35rem);
  }

  .program-highlights__term {
    display: grid;
    min-width: 0;
    align-content: center;
    justify-items: center;
    gap: 8px;
    min-height: 148px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.08);
    padding: 18px 12px 16px;
    text-align: center;
    overflow: hidden;
  }

  .program-highlights__term--result {
    background: rgba(249, 221, 23, 0.12);
    box-shadow: inset 0 0 0 1px rgba(249, 221, 23, 0.26);
  }

  .program-highlights__math strong {
    color: #f9dd17;
    font-size: clamp(34px, 4vw, 62px);
    font-weight: 900;
    line-height: 0.88;
    white-space: nowrap;
  }

  .program-highlights__math span,
  .program-highlights__operator {
    font-weight: 900;
    text-transform: uppercase;
  }

  .program-highlights__term span {
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(12px, 1.1vw, 16px);
    line-height: 1.1;
  }

  .program-highlights__operator {
    display: grid;
    width: 40px;
    height: 40px;
    place-self: center;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
    font-size: 18px;
    line-height: 1;
  }

  .program-highlights__term--result strong {
    font-size: clamp(38px, 4.2vw, 60px);
  }

  .program-highlights__term--result span {
    font-size: clamp(13px, 1vw, 15px);
  }

  .program-highlights__math small {
    width: fit-content;
    margin-top: 12px;
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, #0f7a49 0%, #0b693d 100%);
    color: var(--white);
    font-size: 14px;
    font-weight: 900;
    line-height: 1.2;
    padding: 9px 12px;
    text-transform: uppercase;
  }

  .program-highlights__intro p {
    margin: 0 0 0.75rem;
    color: #b90505;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .program-highlights__intro h2 {
    margin: 0 0 1rem;
    color: #031846;
    font-size: clamp(30px, 3.7vw, 44px);
    font-weight: 900;
    line-height: 1.06;
  }

  .program-highlights__intro span {
    display: block;
    width: 56px;
    height: 5px;
    margin-bottom: 1.25rem;
    background: #f9dd17;
  }

  .program-highlights__intro div {
    max-width: 760px;
    color: #43506d;
    font-size: 15.5px;
    font-weight: 600;
    line-height: 1.7;
  }

  .program-highlights__cards {
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(0.875rem, 1.6vw, 1.5rem);
  }

  .program-highlights__card {
    display: grid;
    gap: 16px;
    min-width: 0;
    border: 1px solid rgba(3, 24, 70, 0.12);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.94);
    padding: clamp(1.25rem, 2vw, 2rem);
    box-shadow: 0 12px 32px rgba(3, 24, 70, 0.07);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .program-highlights__card:hover,
  .program-highlights__card:focus-within {
    border-color: #0b693d;
    box-shadow: var(--shadow-lift);
    transform: translateY(-5px);
  }

  .program-highlights__icon {
    display: grid;
    width: 46px;
    height: 46px;
    place-items: center;
    border-radius: 999px;
    background: linear-gradient(135deg, #031846 0%, #09296b 100%);
    color: #f9dd17;
  }

  .program-highlights__card h3 {
    margin: 0 0 6px;
    color: #031846;
    font-size: 17px;
    font-weight: 900;
    line-height: 1.25;
  }

  .program-highlights__card p {
    margin: 0;
    color: #43506d;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.55;
  }

  @media (max-width: 1023px) {
    .program-highlights__inner,
    .program-highlights__cards {
      grid-template-columns: 1fr 1fr;
    }

    .program-highlights__math,
    .program-highlights__intro {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 767px) {
    .program-highlights__cards {
      grid-template-columns: 1fr;
    }

    .program-highlights__equation {
      grid-template-columns: 1fr;
    }

    .program-highlights__term {
      min-height: 120px;
    }

    .program-highlights__operator {
      width: 40px;
      height: 40px;
      justify-self: center;
    }
  }
</style>
