---
import { Icon } from 'astro-icon/components';

const cards = [
  {
    icon: 'tabler:user-check',
    title: 'Monitored by Expert Faculties',
    body: 'Physics, Chemistry and Biology mentors keep the study day accountable and focused.',
  },
  {
    icon: 'tabler:clipboard-data',
    title: 'Regular Tests & Analysis',
    body: 'Daily performance tracking helps students fix weak areas before the final exam.',
  },
  {
    icon: 'tabler:list-check',
    title: 'Customized Study Plan',
    body: 'Every student gets a structured plan for making the last 20 days productive.',
  },
  {
    icon: 'tabler:message-question',
    title: 'Doubt Clearance Every Day',
    body: 'Individual attention and doubt support reduce confusion during revision.',
  },
];
---

<section class="program-highlights">
  <div class="program-highlights__inner">
    <div class="program-highlights__intro" data-reveal>
      <p>100% Effective Guided Self-Study</p>
      <h2>Execute the last 20 days with discipline and expert supervision.</h2>
      <span class="program-highlights__accent" aria-hidden="true"></span>
      <div>
        The offline program is built for students who already know planning is not enough. It creates the routine,
        monitoring and environment needed to convert study time into real output.
      </div>
      <ul class="program-highlights__points" aria-label="Program outcomes">
        <li>Disciplined offline schedule that protects your final revision window</li>
        <li>Faculty monitoring that keeps daily execution measurable and accountable</li>
        <li>Focused study blocks designed to turn effort into actual completed hours</li>
      </ul>
    </div>

    <div class="program-highlights__math" aria-label="Effective study hours" data-reveal>
      <div class="program-highlights__math-shell">
        <p>This program is for you</p>
        <div class="program-highlights__equation">
          <span class="program-highlights__term program-highlights__term--days">
            <small>Revision Window</small>
            <strong>20</strong>
            <span>Days</span>
          </span>
          <b class="program-highlights__operator" aria-hidden="true">×</b>
          <span class="program-highlights__term program-highlights__term--hours">
            <small>Study Commitment</small>
            <strong>12</strong>
            <span>Hours / Day</span>
          </span>
          <b class="program-highlights__operator" aria-hidden="true">=</b>
          <span class="program-highlights__term program-highlights__term--result">
            <small>Total Output</small>
            <strong>240</strong>
            <span>Focused Hours</span>
          </span>
        </div>
      </div>
    </div>

    <div class="program-highlights__cards">
      {cards.map((card, index) => (
        <article class="program-highlights__card" data-reveal style={`--reveal-delay: ${index * 90}ms;`}>
          <div class="program-highlights__icon">
            <Icon name={card.icon} size="22" aria-hidden="true" />
          </div>
          <div>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .program-highlights {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 10% 12%, rgba(249, 221, 23, 0.16), transparent 22%),
      radial-gradient(circle at 88% 20%, rgba(11, 105, 61, 0.12), transparent 18%),
      linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
  }

  .program-highlights::before {
    position: absolute;
    top: 12%;
    right: -6%;
    width: min(36vw, 360px);
    aspect-ratio: 1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(6, 35, 92, 0.08), transparent 70%);
    content: "";
    pointer-events: none;
  }

  .program-highlights__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
    gap: clamp(1.75rem, 4vw, 4.5rem);
    width: 100%;
    margin: 0 auto;
    padding: var(--section-pad-y) var(--section-pad-x);
  }

  .program-highlights__intro {
    display: grid;
    align-content: center;
    min-width: 0;
  }

  .program-highlights__intro p {
    margin: 0 0 0.9rem;
    color: #b90505;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .program-highlights__intro h2 {
    max-width: 12ch;
    margin: 0 0 1rem;
    color: #031846;
    font-size: clamp(34px, 4.5vw, 58px);
    font-weight: 900;
    line-height: 0.96;
    letter-spacing: -0.04em;
  }

  .program-highlights__accent {
    display: block;
    width: 82px;
    height: 6px;
    margin-bottom: 1.3rem;
    border-radius: 999px;
    background: linear-gradient(90deg, #f9dd17 0%, #ffd400 100%);
  }

  .program-highlights__intro div {
    max-width: 720px;
    color: #43506d;
    font-size: clamp(15px, 1.15vw, 18px);
    font-weight: 600;
    line-height: 1.75;
  }

  .program-highlights__points {
    display: grid;
    gap: 12px;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .program-highlights__points li {
    display: grid;
    grid-template-columns: 18px minmax(0, 1fr);
    gap: 12px;
    align-items: start;
    color: #203257;
    font-size: 14.5px;
    font-weight: 700;
    line-height: 1.55;
  }

  .program-highlights__points li::before {
    width: 18px;
    height: 18px;
    border-radius: 999px;
    background: linear-gradient(135deg, #0f7a49 0%, #0b693d 100%);
    box-shadow: 0 8px 18px rgba(11, 105, 61, 0.18);
    content: "";
  }

  .program-highlights__math {
    position: relative;
    display: grid;
    align-content: center;
    min-width: 0;
  }

  .program-highlights__math-shell {
    position: relative;
    min-width: 0;
    border: 1px solid rgba(3, 24, 70, 0.12);
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 251, 255, 0.96)),
      rgba(255, 255, 255, 0.96);
    padding: clamp(1.25rem, 3vw, 1.9rem);
    box-shadow:
      0 28px 70px rgba(3, 24, 70, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
    transition:
      transform 280ms ease,
      box-shadow 280ms ease;
    transform-style: preserve-3d;
  }

  .program-highlights__math-shell::after {
    position: absolute;
    inset: auto 10% -14% 10%;
    height: 22%;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(6, 35, 92, 0.12), transparent 70%);
    content: "";
    filter: blur(20px);
    pointer-events: none;
    opacity: 0.7;
  }

  .program-highlights__math-shell p {
    width: fit-content;
    margin: 0 0 18px;
    border-radius: 999px;
    background: linear-gradient(135deg, #0f7a49 0%, #0b693d 100%);
    color: var(--white);
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 11px 14px;
    text-transform: uppercase;
  }

  .program-highlights__equation {
    display: grid;
    grid-template-columns: minmax(96px, 0.9fr) 44px minmax(96px, 0.9fr) 44px minmax(132px, 1.15fr);
    align-items: stretch;
    gap: 12px;
    min-width: 0;
    border-radius: 24px;
    background:
      radial-gradient(circle at 50% 0%, rgba(249, 221, 23, 0.12), transparent 38%),
      linear-gradient(135deg, #041742 0%, #09296b 100%);
    color: var(--white);
    padding: clamp(1rem, 2.4vw, 1.35rem);
  }

  .program-highlights__term {
    display: grid;
    min-width: 0;
    align-content: center;
    justify-items: center;
    gap: 6px;
    min-height: 172px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.08);
    padding: 16px 14px;
    text-align: center;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition:
      transform 240ms ease,
      background-color 240ms ease,
      box-shadow 240ms ease;
  }

  .program-highlights__term small {
    color: rgba(235, 241, 255, 0.66);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.16em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .program-highlights__math strong {
    color: #f9dd17;
    font-size: clamp(38px, 4vw, 64px);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.04em;
    white-space: nowrap;
  }

  .program-highlights__term span {
    color: rgba(255, 255, 255, 0.94);
    font-size: clamp(12px, 1vw, 15px);
    font-weight: 900;
    line-height: 1.15;
    text-transform: uppercase;
  }

  .program-highlights__operator {
    display: grid;
    width: 44px;
    height: 44px;
    place-self: center;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    color: #ffffff;
    font-size: 20px;
    font-weight: 900;
    line-height: 1;
    transition:
      transform 240ms ease,
      background-color 240ms ease;
  }

  .program-highlights__term--result {
    position: relative;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(249, 221, 23, 0.08));
    box-shadow:
      inset 0 0 0 1px rgba(249, 221, 23, 0.28),
      0 10px 26px rgba(3, 24, 70, 0.18);
  }

  .program-highlights__term--result strong {
    font-size: clamp(42px, 4.5vw, 70px);
  }

  .program-highlights__cards {
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(0.875rem, 1.6vw, 1.5rem);
  }

  .program-highlights__card {
    display: grid;
    gap: 16px;
    min-width: 0;
    border: 1px solid rgba(3, 24, 70, 0.12);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.94);
    padding: clamp(1.25rem, 2vw, 2rem);
    box-shadow: 0 12px 32px rgba(3, 24, 70, 0.07);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .program-highlights__card:hover,
  .program-highlights__card:focus-within {
    border-color: #0b693d;
    box-shadow: var(--shadow-lift);
    transform: translateY(-5px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .program-highlights::before {
      animation: dna-orbit 14s ease-in-out infinite;
    }

    .program-highlights__accent {
      animation: dna-glow-pulse 3.6s ease-in-out infinite;
      transform-origin: left center;
    }

    .program-highlights__math-shell:hover,
    .program-highlights__math-shell:focus-within {
      transform: translateY(-6px) rotateX(1.8deg) rotateY(-1.8deg);
      box-shadow:
        0 34px 80px rgba(3, 24, 70, 0.14),
        inset 0 1px 0 rgba(255, 255, 255, 0.85);
    }

    .program-highlights__math-shell:hover .program-highlights__term--days,
    .program-highlights__math-shell:hover .program-highlights__term--hours,
    .program-highlights__math-shell:hover .program-highlights__term--result {
      transform: translateY(-3px);
      background: rgba(255, 255, 255, 0.11);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
    }

    .program-highlights__math-shell:hover .program-highlights__operator {
      transform: scale(1.06);
      background: rgba(255, 255, 255, 0.2);
    }

    .program-highlights__term--result {
      animation: dna-glow-pulse 3s ease-in-out 1s infinite;
    }

    .program-highlights__term--days {
      animation: dna-float 5.6s ease-in-out 1s infinite;
    }

    .program-highlights__term--hours {
      animation: dna-float 5.9s ease-in-out 1.4s infinite;
    }
  }

  .program-highlights__icon {
    display: grid;
    width: 46px;
    height: 46px;
    place-items: center;
    border-radius: 999px;
    background: linear-gradient(135deg, #031846 0%, #09296b 100%);
    color: #f9dd17;
  }

  .program-highlights__card h3 {
    margin: 0 0 6px;
    color: #031846;
    font-size: 17px;
    font-weight: 900;
    line-height: 1.25;
  }

  .program-highlights__card p {
    margin: 0;
    color: #43506d;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.55;
  }

  @media (max-width: 1023px) {
    .program-highlights__inner {
      grid-template-columns: 1fr;
    }

    .program-highlights__intro h2 {
      max-width: 14ch;
    }

    .program-highlights__cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 767px) {
    .program-highlights__inner {
      gap: 2rem;
    }

    .program-highlights__intro h2 {
      max-width: none;
      font-size: clamp(30px, 10vw, 44px);
    }

    .program-highlights__cards {
      grid-template-columns: 1fr;
    }

    .program-highlights__equation {
      grid-template-columns: 1fr;
    }

    .program-highlights__term {
      min-height: 120px;
    }

    .program-highlights__operator {
      width: 42px;
      height: 42px;
      justify-self: center;
    }
  }
</style>
