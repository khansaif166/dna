---
import { Image, getImage } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import logo from '../../assets/images/logo.jpeg';
import heroDesktopSource from '../../assets/images/bleed-web.png';
import heroMobileSource from '../../assets/images/bleed-mob.png';

const stats = [
  { icon: 'tabler:calendar-event', value: '1 Jun', label: 'Batch Starts' },
  { icon: 'tabler:clock-hour-4', value: '12 Hrs', label: 'Daily Study' },
  { icon: 'tabler:chart-bar', value: '240 Hrs', label: 'Focused Revision' },
];

const mobilePoints = ['PCB Faculty Monitoring', 'Zero-Distraction Routine', 'Offline Guided Revision'];

const heroDesktop = await getImage({
  src: heroDesktopSource,
  width: 1672,
  format: 'webp',
  quality: 82,
});

const heroMobile = await getImage({
  src: heroMobileSource,
  width: 941,
  format: 'webp',
  quality: 80,
});
---

<section
  id="program"
  class="hero"
  style={`--hero-desktop-bg: url("${heroDesktop.src}"); --hero-mobile-bg: url("${heroMobile.src}");`}
>
  <div class="hero__backdrop" aria-hidden="true"></div>

  <div class="hero__content">
    <div class="hero__date-band" data-reveal>
      <Image
        class="hero__logo"
        src={logo}
        alt="Dream Neet Academy logo"
        widths={[40, 80]}
        sizes="40px"
        format="webp"
        quality={90}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <span>Re-NEET Examination on <strong>21st June 2026</strong></span>
    </div>

    <h1 class="hero__headline" data-reveal>
      <span>One more <em>chance.</em></span>
      <span>Make these <em>20 days</em></span>
      <span>count.</span>
    </h1>

    <p class="hero__lead" data-reveal>
      Structured offline revision with faculty monitoring, disciplined study hours and daily execution support.
    </p>

    <div class="hero__mobile-points" data-reveal aria-label="Program highlights">
      {mobilePoints.map((point, index) => (
        <div class="hero__mobile-point" style={`--reveal-delay: ${index * 80}ms;`}>
          <Icon name="tabler:check" size="14" aria-hidden="true" />
          <span>{point}</span>
        </div>
      ))}
    </div>

    <div class="hero__actions" data-reveal>
      <button class="hero__primary" type="button" data-modal-open>
        <Icon name="tabler:user-plus" size="19" aria-hidden="true" />
        Enroll Now
      </button>
      <a class="hero__secondary" href="tel:+918123080202">
        <Icon name="tabler:phone" size="19" aria-hidden="true" />
        Call +91 81230 80202
      </a>
    </div>

    <div class="hero__stats" aria-label="20 day Re-NEET program summary" data-reveal>
      {stats.map((stat, index) => (
        <div class="hero__stat" data-reveal style={`--reveal-delay: ${index * 110}ms;`}>
          <Icon name={stat.icon} size="20" aria-hidden="true" />
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: calc(100vh - 40px);
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(1, 10, 31, 0.94) 0%, rgba(1, 10, 31, 0.72) 34%, rgba(1, 10, 31, 0.26) 58%, rgba(1, 10, 31, 0.04) 75%),
      var(--hero-desktop-bg) center center / cover no-repeat;
    color: var(--white);
  }

  .hero__backdrop {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 22% 18%, rgba(249, 221, 23, 0.12), transparent 22%),
      linear-gradient(180deg, rgba(1, 10, 31, 0.1), rgba(1, 10, 31, 0.22));
    pointer-events: none;
  }

  .hero__backdrop::before,
  .hero__backdrop::after {
    position: absolute;
    content: "";
    pointer-events: none;
  }

  .hero__backdrop::before {
    top: 10%;
    right: -4%;
    width: min(34vw, 420px);
    aspect-ratio: 1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(249, 221, 23, 0.18), transparent 66%);
    filter: blur(6px);
    opacity: 0.75;
  }

  .hero__backdrop::after {
    bottom: 6%;
    left: 8%;
    width: min(28vw, 320px);
    aspect-ratio: 1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.08), transparent 70%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: center;
    min-height: calc(100vh - 40px);
    width: min(100%, 660px);
    padding: clamp(7rem, 10vw, 9.5rem) 0 clamp(4rem, 8vw, 6rem) var(--section-pad-x);
  }

  .hero__logo {
    width: 40px;
    height: 40px;
    flex: 0 0 auto;
    border-radius: 999px;
    object-fit: cover;
    box-shadow: 0 14px 30px rgba(1, 10, 31, 0.28);
  }

  .hero__date-band {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    width: fit-content;
    margin-bottom: 1.2rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.94);
    font-size: clamp(12px, 0.96vw, 14px);
    font-weight: 800;
    line-height: 1.2;
    padding: 10px 16px 10px 10px;
    text-transform: uppercase;
    backdrop-filter: blur(12px);
  }

  .hero__date-band strong {
    color: #ffe65a;
    font-weight: 900;
  }

  .hero__headline {
    margin: 0;
    max-width: 10ch;
    color: var(--white);
    font-size: clamp(52px, 6vw, 84px);
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 0.94;
  }

  .hero__headline span {
    display: block;
  }

  .hero__headline em {
    color: #ffe65a;
    font-style: normal;
    text-shadow: 0 0 24px rgba(249, 221, 23, 0.18);
  }

  .hero__lead {
    max-width: 520px;
    margin: 1.4rem 0 0;
    color: rgba(235, 241, 255, 0.84);
    font-size: clamp(16px, 1.18vw, 19px);
    font-weight: 500;
    line-height: 1.75;
  }

  .hero__mobile-points {
    display: none;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 1.9rem;
  }

  .hero__primary,
  .hero__secondary {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    min-height: 52px;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border-radius: 999px;
    font: inherit;
    font-size: 15px;
    font-weight: 800;
    padding: 13px 24px;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .hero__primary::after,
  .hero__secondary::after {
    position: absolute;
    inset: 0;
    width: 34%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.34), transparent);
    content: "";
    transform: translateX(-120%) skewX(-18deg);
  }

  .hero__primary {
    border: 0;
    background: linear-gradient(135deg, #ffe65a 0%, #f9dd17 100%);
    color: #031846;
    cursor: pointer;
    box-shadow: 0 16px 36px rgba(249, 221, 23, 0.22);
  }

  .hero__secondary {
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.08);
    color: var(--white);
    backdrop-filter: blur(12px);
    box-shadow: 0 12px 30px rgba(1, 10, 31, 0.16);
  }

  .hero__primary:hover,
  .hero__primary:focus-visible,
  .hero__secondary:hover,
  .hero__secondary:focus-visible {
    transform: translateY(-2px);
  }

  .hero__primary:hover::after,
  .hero__primary:focus-visible::after,
  .hero__secondary:hover::after,
  .hero__secondary:focus-visible::after {
    animation: dna-shine 720ms ease;
  }

  .hero__primary:hover,
  .hero__primary:focus-visible {
    background: linear-gradient(135deg, #fff0a0 0%, #ffe65a 100%);
    box-shadow: 0 20px 42px rgba(249, 221, 23, 0.28);
  }

  .hero__secondary:hover,
  .hero__secondary:focus-visible {
    border-color: rgba(255, 255, 255, 0.38);
    background: rgba(255, 255, 255, 0.12);
    box-shadow: 0 18px 38px rgba(1, 10, 31, 0.24);
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    max-width: 560px;
    margin-top: 1.7rem;
  }

  .hero__stat {
    min-width: 0;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.08);
    padding: 16px;
    backdrop-filter: blur(10px);
    box-shadow: 0 14px 34px rgba(1, 10, 31, 0.12);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .hero__stat:hover {
    border-color: rgba(255, 230, 90, 0.32);
    box-shadow: var(--shadow-soft);
    transform: translateY(-3px);
  }

  .hero__stat [data-icon] {
    color: #ffe65a;
  }

  .hero__stat strong {
    display: block;
    margin-top: 10px;
    color: var(--white);
    font-size: clamp(22px, 2.2vw, 30px);
    font-weight: 900;
    line-height: 1;
  }

  .hero__stat span {
    display: block;
    margin-top: 6px;
    color: rgba(235, 241, 255, 0.78);
    font-size: 12px;
    font-weight: 800;
    line-height: 1.3;
    text-transform: uppercase;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__date-band {
      animation: dna-fade-up 520ms cubic-bezier(0.22, 1, 0.36, 1) both, dna-glow-pulse 3.8s ease-in-out 1s infinite;
    }

    .hero__headline span:nth-child(1) {
      animation: dna-text-rise 700ms cubic-bezier(0.22, 1, 0.36, 1) 120ms both;
    }

    .hero__headline span:nth-child(2) {
      animation: dna-text-rise 700ms cubic-bezier(0.22, 1, 0.36, 1) 240ms both;
    }

    .hero__headline span:nth-child(3) {
      animation: dna-text-rise 700ms cubic-bezier(0.22, 1, 0.36, 1) 360ms both;
    }

    .hero__primary {
      animation: dna-breathe-shadow 3.2s ease-in-out 1.2s infinite;
    }

    .hero__backdrop::before {
      animation: dna-ambient-shift 14s ease-in-out infinite;
    }

    .hero__backdrop::after {
      animation: dna-orbit 10s ease-in-out infinite;
    }

    .hero__stat:nth-child(1) {
      animation: dna-scale-in 520ms cubic-bezier(0.22, 1, 0.36, 1) both, dna-float 5.4s ease-in-out 0.8s infinite;
    }

    .hero__stat:nth-child(2) {
      animation: dna-scale-in 520ms cubic-bezier(0.22, 1, 0.36, 1) both, dna-float 5.8s ease-in-out 1.2s infinite;
    }

    .hero__stat:nth-child(3) {
      animation: dna-scale-in 520ms cubic-bezier(0.22, 1, 0.36, 1) both, dna-float 6.2s ease-in-out 1.6s infinite;
    }
  }

  @media (max-width: 1180px) {
    .hero__content {
      width: min(100%, 620px);
      padding-right: var(--section-pad-x);
    }

    .hero__headline {
      font-size: clamp(46px, 6vw, 72px);
    }
  }

  @media (max-width: 900px) {
    .hero {
      min-height: auto;
      background:
        linear-gradient(180deg, rgba(1, 10, 31, 0.34) 0%, rgba(1, 10, 31, 0.76) 44%, rgba(1, 10, 31, 0.96) 100%),
        var(--hero-mobile-bg) center top / cover no-repeat;
    }

    .hero__content {
      width: 100%;
      min-height: calc(100vh - 40px);
      padding: 7rem 1rem 3rem;
      align-content: end;
    }

    .hero__headline {
      max-width: 100%;
      font-size: clamp(42px, 10vw, 58px);
    }

    .hero__lead,
    .hero__stats {
      max-width: 100%;
    }
  }

  @media (max-width: 767px) {
    .hero__date-band {
      gap: 10px;
      font-size: 11px;
      padding: 9px 12px 9px 9px;
    }

    .hero__logo {
      width: 34px;
      height: 34px;
    }

    .hero__lead {
      font-size: 15px;
      line-height: 1.65;
    }

    .hero__mobile-points {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 1rem;
    }

    .hero__mobile-point {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      min-height: 34px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.08);
      color: rgba(245, 248, 255, 0.9);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.05em;
      line-height: 1;
      padding: 0 11px;
      text-transform: uppercase;
      backdrop-filter: blur(10px);
    }

    .hero__mobile-point [data-icon] {
      color: #ffe65a;
      flex: 0 0 auto;
    }

    .hero__primary,
    .hero__secondary {
      width: 100%;
    }

    .hero__actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .hero__stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 1.3rem;
    }

    .hero__stat {
      padding: 12px 10px;
      border-radius: 14px;
      text-align: center;
    }

    .hero__stat strong {
      margin-top: 8px;
      font-size: 18px;
    }

    .hero__stat span {
      margin-top: 4px;
      font-size: 10px;
      line-height: 1.25;
    }
  }
</style>
