  <div class="mx-auto grid max-w-(--max-width) gap-8 px-(--section-pad-x) py-10 md:grid-cols-[1fr_auto] md:items-center">
    <div>
      <p class="font-serif text-2xl font-bold text-white">Dream Neet Academy</p>
      <p class="mt-2 max-w-xl text-sm leading-6 text-gray-400">
        Focused academic mentoring, calm systems, and measurable preparation habits.
      </p>
    </div>
    <p class="text-sm text-gray-400">&copy; {year} Dream Neet Academy. All rights reserved.</p>
  </div>
</footer>
